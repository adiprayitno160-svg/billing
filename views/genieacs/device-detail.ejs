<%- contentFor('body') %>

<div class="space-y-6">
    <!-- Premium Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white/50 backdrop-blur-md p-6 rounded-3xl border border-white/20 shadow-sm transition-all duration-300">
        <div class="flex items-center gap-4">
            <div class="p-3 bg-indigo-600 rounded-2xl shadow-lg shadow-indigo-200 text-white">
                <i class="fas fa-server text-2xl"></i>
            </div>
            <div>
                <nav class="flex text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1" aria-label="Breadcrumb">
                    <ol class="list-none p-0 inline-flex">
                        <li class="flex items-center">
                            <a href="/genieacs/devices" class="hover:text-indigo-600 font-black">Devices</a>
                            <i class="fas fa-chevron-right mx-2 text-[8px]"></i>
                        </li>
                        <li class="text-indigo-600 font-black">Detail Device</li>
                    </ol>
                </nav>
                <div class="flex items-center gap-3">
                    <h2 class="text-2xl font-black text-slate-800 uppercase tracking-tight"><%= deviceInfo.serialNumber %></h2>
                    <% if (deviceInfo.online) { %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-100 text-emerald-600 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm shadow-emerald-50">
                            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                            Online
                        </span>
                    <% } else { %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-rose-100 text-rose-600 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm shadow-rose-50">
                            <span class="w-1.5 h-1.5 bg-rose-500 rounded-full"></span>
                            Offline
                        </span>
                    <% } %>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <form action="/genieacs/devices/<%= encodeURIComponent(device._id) %>/refresh" method="POST" class="inline">
                <button type="submit"
                    class="flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-white border border-slate-200 text-indigo-600 font-bold text-xs hover:bg-indigo-50 shadow-sm transition-all active:scale-95">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </form>
            <form action="/genieacs/devices/<%= encodeURIComponent(device._id) %>/reboot" method="POST" class="inline"
                onsubmit="return confirm('Reboot device ini?');">
                <button type="submit"
                    class="flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-rose-600 text-white font-bold text-xs hover:bg-rose-700 shadow-lg shadow-rose-200 transition-all active:scale-95">
                    <i class="fas fa-power-off"></i> Reboot
                </button>
            </form>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="bg-white/70 backdrop-blur-md p-1.5 rounded-2xl border border-white/20 shadow-sm inline-flex w-full md:w-auto">
        <button onclick="switchTab('overview')" id="tab-overview"
            class="tab-btn flex-1 md:flex-none px-8 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 bg-indigo-600 text-white shadow-lg shadow-indigo-100">
            <i class="fas fa-chart-pie mr-2 text-[10px]"></i> Overview
        </button>
        <button onclick="switchTab('config')" id="tab-config"
            class="tab-btn flex-1 md:flex-none px-8 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 text-slate-400 hover:text-slate-600">
            <i class="fas fa-sliders-h mr-2 text-[10px]"></i> Configuration
        </button>
        <button onclick="switchTab('system')" id="tab-system"
            class="tab-btn flex-1 md:flex-none px-8 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 text-slate-400 hover:text-slate-600">
            <i class="fas fa-hdd mr-2 text-[10px]"></i> System & Logs
        </button>
    </div>

    <!-- Tab Contents -->

    <!-- 1. OVERVIEW TAB -->
    <div id="content-overview" class="tab-content space-y-6">
        <!-- Key Metrics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Signal RX -->
            <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-6 transition-all hover:scale-[1.02]">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Optical RX Power</p>
                <div class="flex items-end gap-2">
                    <span class="text-3xl font-black <%= (parseFloat(signalInfo.rxPower) > -27 && parseFloat(signalInfo.rxPower) < -10) ? 'text-emerald-600' : 'text-rose-600' %> tracking-tight">
                        <%= signalInfo.rxPower %>
                    </span>
                    <span class="text-xs font-bold text-slate-400 mb-1.5">dBm</span>
                </div>
                <div class="mt-4 w-full bg-slate-50 h-1.5 rounded-full overflow-hidden">
                    <div class="h-full <%= (parseFloat(signalInfo.rxPower) > -27 && parseFloat(signalInfo.rxPower) < -10) ? 'bg-emerald-500' : 'bg-rose-500' %>" 
                        style="width: <%= Math.min(100, Math.max(0, (parseFloat(signalInfo.rxPower) + 40) / 40 * 100)) %>%"></div>
                </div>
            </div>

            <!-- Signal TX -->
            <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-6 transition-all hover:scale-[1.02]">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Optical TX Power</p>
                <div class="flex items-end gap-2">
                    <span class="text-3xl font-black text-slate-800 tracking-tight">
                        <%= signalInfo.txPower %>
                    </span>
                    <span class="text-xs font-bold text-slate-400 mb-1.5">dBm</span>
                </div>
                <div class="mt-4 flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Normal Operating Range</span>
                </div>
            </div>

            <!-- Temperature -->
            <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-6 transition-all hover:scale-[1.02]">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Temperature</p>
                <div class="flex items-end gap-2">
                    <span class="text-3xl font-black text-slate-800 tracking-tight">
                        <%= signalInfo.temperature %>
                    </span>
                    <span class="text-xs font-bold text-slate-400 mb-1.5">°C</span>
                </div>
                <div class="mt-4 flex items-center gap-2 text-amber-500">
                    <i class="fas fa-thermometer-half text-xs"></i>
                    <span class="text-[9px] font-black uppercase tracking-tighter">Hardware Health OK</span>
                </div>
            </div>

            <!-- WiFi Clients -->
            <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-6 transition-all hover:scale-[1.02]">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Active WiFi Clients</p>
                <div class="flex items-end gap-2">
                    <span class="text-3xl font-black text-indigo-600 tracking-tight">
                        <%= signalInfo.wifiClients %>
                    </span>
                    <span class="text-xs font-bold text-slate-400 mb-1.5">Devices</span>
                </div>
                <div class="mt-4 flex -space-x-2">
                    <% for(let i=0; i<Math.min(5, signalInfo.wifiClients); i++) { %>
                        <div class="w-6 h-6 rounded-full bg-indigo-50 border-2 border-white flex items-center justify-center text-[8px] text-indigo-600 font-black">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                    <% } %>
                    <% if(signalInfo.wifiClients > 5) { %>
                        <div class="w-6 h-6 rounded-full bg-slate-100 border-2 border-white flex items-center justify-center text-[8px] text-slate-500 font-black">
                            +<%= signalInfo.wifiClients - 5 %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Device Info Card -->
            <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 overflow-hidden relative group">
                <div class="absolute -right-16 -top-16 w-48 h-48 bg-slate-50 rounded-full blur-3xl group-hover:bg-indigo-50 transition-colors"></div>
                <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight mb-8 flex items-center gap-3 relative z-10">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center text-sm shadow-sm">
                        <i class="fas fa-info-circle"></i>
                    </span>
                    Hardware Information
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6 relative z-10">
                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100/50">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Manufacturer</p>
                        <p class="text-sm font-black text-slate-700 uppercase tracking-tight"><%= deviceInfo.manufacturer %></p>
                    </div>
                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100/50">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Product Class</p>
                        <p class="text-sm font-black text-slate-700 uppercase tracking-tight"><%= deviceInfo.productClass %></p>
                    </div>
                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100/50">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Hardware Version</p>
                        <p class="text-sm font-black text-slate-700 uppercase tracking-tight"><%= deviceInfo.hardwareVersion %></p>
                    </div>
                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100/50">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Software Version</p>
                        <p class="text-sm font-black text-slate-700 uppercase tracking-tight"><%= deviceInfo.softwareVersion %></p>
                    </div>
                    <div class="sm:col-span-2 p-4 bg-indigo-50/30 rounded-2xl border border-indigo-100/30 flex items-center justify-between">
                        <div>
                            <p class="text-[9px] font-black text-indigo-400 uppercase tracking-widest mb-1">Uptime Duration</p>
                            <p class="text-sm font-black text-indigo-700">
                                <%= Math.floor(deviceInfo.uptime / 3600) %>h <%= Math.floor((deviceInfo.uptime % 3600) / 60) %>m
                            </p>
                        </div>
                        <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-100">
                            <i class="fas fa-clock text-xs"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Customer & Connection Card -->
            <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8">
                <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight mb-8 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center text-sm shadow-sm">
                            <i class="fas fa-network-wired"></i>
                        </span>
                        Network Connectivity
                    </div>
                    <span class="px-3 py-1 bg-emerald-100 text-emerald-600 rounded-full text-[9px] font-black uppercase tracking-widest">
                        <%= wanStatus.status %>
                    </span>
                </h3>

                <div class="space-y-4 mb-8">
                    <div class="flex items-center justify-between py-3 border-b border-slate-50">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Connection Mode</span>
                        <span class="text-xs font-black text-slate-700"><%= wanStatus.mode %> (VLAN <%= wanStatus.vlan %>)</span>
                    </div>
                    <div class="flex items-center justify-between py-3 border-b border-slate-50">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">IP Address</span>
                        <span class="text-xs font-black text-indigo-600 font-mono"><%= wanStatus.ip %></span>
                    </div>
                    <div class="flex items-center justify-between py-3 border-b border-slate-50">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">WiFi SSID</span>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-wifi text-indigo-500 text-[10px]"></i>
                            <span class="text-xs font-black text-slate-700"><%= wifiSettings.ssid %></span>
                        </div>
                    </div>
                    <div class="flex items-center justify-between py-3 border-b border-slate-50">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">WiFi Password</span>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-key text-amber-500 text-[10px]"></i>
                            <span class="text-xs font-black text-slate-700 font-mono"><%= wifiSettings.password %></span>
                        </div>
                    </div>
                </div>

                <!-- Customer Assignment -->
                <div class="mt-6">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Linked Customer</p>
                    <% if (customer) { %>
                        <div class="bg-indigo-50/50 rounded-3xl border border-indigo-100 p-5 group relative overflow-hidden">
                            <div class="flex items-center justify-between relative z-10">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-indigo-600 text-white flex items-center justify-center text-lg shadow-lg shadow-indigo-200 group-hover:scale-110 transition-transform">
                                        <i class="fas fa-user-circle"></i>
                                    </div>
                                    <div>
                                        <p class="text-sm font-black text-slate-800 tracking-tight leading-tight mb-1"><%= customer.name %></p>
                                        <p class="text-[10px] text-slate-400 font-bold tracking-tight"><%= customer.phone || '-' %> • ID: <%= customer.customer_code || 'N/A' %></p>
                                    </div>
                                </div>
                                <button type="button" onclick="unlinkCustomer()"
                                    class="w-8 h-8 rounded-xl bg-white border border-rose-100 text-rose-500 flex items-center justify-center hover:bg-rose-500 hover:text-white transition-all shadow-sm active:scale-90"
                                    title="Unlink Customer">
                                    <i class="fas fa-unlink text-[10px]"></i>
                                </button>
                            </div>
                            <div class="mt-4 pt-4 border-t border-indigo-100/50 relative z-10">
                                <a href="/customers/<%= customer.id %>" class="text-[9px] font-black text-indigo-600 uppercase tracking-widest hover:underline flex items-center gap-2">
                                    View Customer Profile <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    <% } else { %>
                        <form method="POST" action="/genieacs/devices/<%= encodeURIComponent(device._id) %>/assign-customer" id="assignCustomerForm">
                            <div class="space-y-4">
                                <div class="relative group">
                                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
                                        <i class="fas fa-user-plus text-xs"></i>
                                    </span>
                                    <select name="customer_id" required
                                        class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3 pl-11 pr-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-black text-slate-700 appearance-none cursor-pointer">
                                        <option value="">Select Customer to Link...</option>
                                        <% if (typeof allCustomers !== 'undefined' && allCustomers) { %>
                                            <% allCustomers.forEach(function(cust) { %>
                                                <option value="<%= cust.id %>">
                                                    <%= cust.name %> <%= cust.customer_code ? '(' + cust.customer_code + ')' : '' %>
                                                </option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[8px]">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </div>
                                <button type="submit"
                                    class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-black text-xs uppercase tracking-widest rounded-2xl shadow-lg shadow-indigo-100 transition-all active:scale-[0.98]">
                                    <i class="fas fa-link mr-2"></i>Link Customer to ONT
                                </button>
                            </div>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. CONFIGURATION TAB -->
    <div id="content-config" class="tab-content space-y-6 hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- WAN Configuration Form -->
            <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight flex items-center gap-3">
                        <span class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center text-sm">
                            <i class="fas fa-network-wired"></i>
                        </span>
                        WAN Setup
                    </h3>
                    <span class="px-3 py-1 bg-slate-50 text-slate-400 rounded-full text-[9px] font-black uppercase tracking-widest border border-slate-100">
                        Mode: <%= wanStatus.mode %>
                    </span>
                </div>

                <form action="/genieacs/devices/<%= encodeURIComponent(device._id) %>/configure-wan" method="POST">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Connection Protocol</label>
                            <div class="relative">
                                <select name="wanMode" id="wanMode" onchange="toggleWanFields()"
                                    class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3.5 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-black text-slate-700 appearance-none cursor-pointer">
                                    <option value="pppoe" <%= wanStatus.mode === 'PPPoE' ? 'selected' : '' %>>PPPoE (Route Mode)</option>
                                    <option value="bridge" <%= wanStatus.mode === 'Bridge' ? 'selected' : '' %>>Bridge Mode</option>
                                    <option value="static" <%= wanStatus.mode === 'Static IP' ? 'selected' : '' %>>Static Assignment</option>
                                    <option value="dhcp" <%= wanStatus.mode === 'DHCP' ? 'selected' : '' %>>DHCP Client</option>
                                </select>
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[8px]">
                                    <i class="fas fa-chevron-down"></i>
                                </span>
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">VLAN Identifier</label>
                            <input type="number" name="vlanId" required min="1" max="4094"
                                value="<%= wanStatus.vlan !== '-' ? wanStatus.vlan : '' %>"
                                class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3.5 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-black text-slate-700"
                                placeholder="Example: 100">
                        </div>

                        <!-- PPPoE Fields -->
                        <div id="field-pppoe" class="p-6 bg-slate-50 rounded-3xl border border-slate-100 space-y-4">
                            <div>
                                <label class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">PPP Username</label>
                                <input type="text" name="pppUsername"
                                    value="<%= wanStatus.username !== '-' ? wanStatus.username : '' %>"
                                    class="w-full bg-white border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 transition-all text-sm font-bold text-slate-700">
                            </div>
                            <div>
                                <label class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">PPP Password</label>
                                <div class="relative">
                                    <input type="password" name="pppPassword"
                                        class="w-full bg-white border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 transition-all text-sm font-bold text-slate-700">
                                    <i class="fas fa-lock absolute right-4 top-1/2 -translate-y-1/2 text-slate-200 text-xs"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Static IP Fields -->
                        <div id="field-static" class="p-6 bg-slate-50 rounded-3xl border border-slate-100 space-y-4 hidden">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">IP Address</label>
                                    <input type="text" name="ipAddress" placeholder="10.10.1.50"
                                        class="w-full bg-white border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 transition-all text-sm font-mono text-slate-700">
                                </div>
                                <div>
                                    <label class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Subnet Mask</label>
                                    <input type="text" name="subnetMask" placeholder="255.255.255.0"
                                        class="w-full bg-white border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 transition-all text-sm font-mono text-slate-700">
                                </div>
                            </div>
                            <div>
                                <label class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Default Gateway</label>
                                <input type="text" name="gateway" placeholder="10.10.1.1"
                                    class="w-full bg-white border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 transition-all text-sm font-mono text-slate-700">
                            </div>
                        </div>

                        <div class="flex items-center gap-3 p-1">
                            <input type="checkbox" name="enableConnection" id="enableConnection" checked
                                class="w-5 h-5 text-indigo-600 border-slate-300 rounded-lg focus:ring-indigo-500 transition-all cursor-pointer">
                            <label for="enableConnection" class="text-[10px] font-black text-slate-500 uppercase tracking-widest cursor-pointer">
                                Enable WAN Connection After Apply
                            </label>
                        </div>

                        <button type="submit"
                            class="w-full py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-black text-xs uppercase tracking-widest rounded-2xl shadow-lg shadow-indigo-100 transition-all active:scale-[0.98]">
                            <i class="fas fa-save mr-2"></i> Apply Network Settings
                        </button>
                    </div>
                </form>
            </div>

            <!-- WiFi Configuration -->
            <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight flex items-center gap-3">
                        <span class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center text-sm shadow-sm">
                            <i class="fas fa-wifi"></i>
                        </span>
                        WiFi Access Point
                    </h3>
                    <form action="/genieacs/devices/<%= encodeURIComponent(device._id) %>/refresh" method="POST" class="inline">
                        <button type="submit"
                            class="flex items-center gap-2 px-3 py-1.5 rounded-xl bg-slate-50 border border-slate-100 text-slate-400 hover:text-indigo-600 hover:bg-white hover:border-indigo-100 transition-all text-[9px] font-black uppercase tracking-widest">
                            <i class="fas fa-sync-alt"></i> Refresh Data
                        </button>
                    </form>
                </div>

                <div class="p-6 bg-amber-50/50 rounded-3xl border border-amber-100/50 mb-8 flex items-center justify-between group">
                    <div>
                        <p class="text-[9px] font-black text-amber-400 uppercase tracking-widest mb-1">Active Credentials</p>
                        <div class="flex items-center gap-4">
                            <div>
                                <span class="text-[10px] text-slate-400 font-bold">SSID:</span>
                                <span class="text-xs font-black text-slate-700 ml-1"><%= wifiSettings.ssid || '-' %></span>
                            </div>
                            <div class="h-4 w-px bg-amber-200"></div>
                            <div>
                                <span class="text-[10px] text-slate-400 font-bold">KEY:</span>
                                <span class="text-xs font-black text-slate-700 font-mono ml-1"><%= wifiSettings.password || '-' %></span>
                            </div>
                        </div>
                    </div>
                    <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-amber-500 shadow-sm border border-amber-100 transition-transform group-hover:rotate-12">
                        <i class="fas fa-shield-alt text-sm"></i>
                    </div>
                </div>

                <form action="/genieacs/devices/<%= encodeURIComponent(device._id) %>/change-wifi" method="POST">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Network SSID Name</label>
                            <input type="text" name="ssid" value="<%= wifiSettings.ssid %>" required
                                class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3.5 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-black text-slate-700"
                                placeholder="Enter SSID Name">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Security Key (WPA2)</label>
                            <div class="relative">
                                <input type="text" name="password" value="<%= wifiSettings.password %>" required minlength="8"
                                    class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3.5 px-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-black text-slate-700 font-mono"
                                    placeholder="Enter Security Key">
                                <i class="fas fa-eye absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 text-xs cursor-pointer hover:text-indigo-500"></i>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 p-4 bg-rose-50 rounded-2xl border border-rose-100">
                            <i class="fas fa-exclamation-triangle text-rose-500 text-xs mt-0.5"></i>
                            <p class="text-[9px] font-bold text-rose-600 uppercase tracking-tighter leading-relaxed">
                                Updating WiFi settings will disconnect all currently connected wireless devices. They will need to reconnect using the new credentials.
                            </p>
                        </div>
                        <button type="submit"
                            class="w-full py-4 bg-slate-800 hover:bg-slate-900 text-white font-black text-xs uppercase tracking-widest rounded-2xl shadow-lg shadow-slate-200 transition-all active:scale-[0.98]">
                            <i class="fas fa-broadcast-tower mr-2"></i> Update WiFi Broadcast
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 3. SYSTEM TAB -->
    <div id="content-system" class="tab-content space-y-6 hidden">
        <!-- Tasks List -->
        <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-50 bg-slate-50/50 flex items-center justify-between">
                <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight flex items-center gap-3">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center text-sm">
                        <i class="fas fa-list-ul"></i>
                    </span>
                    Operation Log (Recent Tasks)
                </h3>
                <span class="px-3 py-1 bg-white text-slate-400 rounded-full text-[9px] font-black border border-slate-100 uppercase tracking-widest">
                    Total: <%= tasks.length %> Events
                </span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50/30">
                        <tr>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Task Operation</th>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Execution Status</th>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Execution Time</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% if (tasks.length === 0) { %>
                            <tr>
                                <td colspan="3" class="px-8 py-16 text-center">
                                    <div class="flex flex-col items-center gap-3 opacity-30">
                                        <i class="fas fa-terminal text-4xl text-slate-300"></i>
                                        <p class="text-[10px] font-black uppercase tracking-widest">No Recent Operations Detected</p>
                                    </div>
                                </td>
                            </tr>
                        <% } else { %>
                            <% tasks.forEach(task => { %>
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="px-8 py-5">
                                        <div class="flex items-center gap-3">
                                            <div class="w-2 h-2 rounded-full <%= task.status === 'fault' ? 'bg-rose-500' : 'bg-emerald-500' %>"></div>
                                            <span class="text-sm font-black text-slate-700 uppercase tracking-tight"><%= task.name %></span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-5">
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest
                                            <%= task.status === 'fault' ? 'bg-rose-50 text-rose-600 border border-rose-100' : 'bg-emerald-50 text-emerald-600 border border-emerald-100' %>">
                                            <%= task.status %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-5">
                                        <div class="flex flex-col">
                                            <span class="text-xs font-bold text-slate-500"><%= new Date(task.timestamp).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %></span>
                                            <span class="text-[10px] font-black text-slate-300 uppercase tracking-tighter"><%= new Date(task.timestamp).toLocaleTimeString('id-ID', {hour: '2-digit', minute: '2-digit'}) %> WIB</span>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Debug Info -->
        <div class="bg-slate-900 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden group">
            <div class="absolute right-0 top-0 p-4 opacity-20 text-indigo-500 group-hover:opacity-40 transition-opacity">
                <i class="fas fa-code text-4xl"></i>
            </div>
            <h3 class="text-xs font-black text-indigo-400 uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
                <span class="w-6 h-6 rounded-md bg-indigo-500/20 flex items-center justify-center text-[10px]">
                    <i class="fas fa-bug"></i>
                </span>
                Raw Parameters (JSON Data Model)
            </h3>
            <div class="bg-black/30 rounded-2xl p-6 border border-white/5">
                <pre class="text-[11px] font-mono text-indigo-300/80 leading-relaxed overflow-x-auto"><%= JSON.stringify(wanStatus, null, 4) %></pre>
            </div>
        </div>
    </div>

</div>

<script>
    function switchTab(tabId) {
        // Buttons
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-100');
            btn.classList.add('text-slate-400');
        });
        const activeBtn = document.getElementById('tab-' + tabId);
        activeBtn.classList.add('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-100');
        activeBtn.classList.remove('text-slate-400');

        // Content
        document.querySelectorAll('.tab-content').forEach(content => {
            content.classList.add('hidden');
        });
        const activeContent = document.getElementById('content-' + tabId);
        activeContent.classList.remove('hidden');
        activeContent.classList.add('animate-fade-in');
    }

    function toggleWanFields() {
        const mode = document.getElementById('wanMode').value;
        const pppoe = document.getElementById('field-pppoe');
        const staticIp = document.getElementById('field-static');

        if (mode === 'pppoe') {
            pppoe.classList.remove('hidden');
            staticIp.classList.add('hidden');
        } else if (mode === 'static') {
            pppoe.classList.add('hidden');
            staticIp.classList.remove('hidden');
        } else {
            pppoe.classList.add('hidden');
            staticIp.classList.add('hidden');
        }
    }

    // Initialize fields
    toggleWanFields();

    // Unlink customer function
    function unlinkCustomer() {
        Swal.fire({
            title: 'Unlink ONT?',
            text: "Yakin ingin memutus hubungan pelanggan dari ONT ini?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#4f46e5',
            cancelButtonColor: '#f43f5e',
            confirmButtonText: 'Ya, Putuskan!',
            cancelButtonText: 'Batal',
            background: '#ffffff',
            borderRadius: '2rem'
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/genieacs/devices/<%= encodeURIComponent(device._id) %>/unlink-customer';
                document.body.appendChild(form);
                form.submit();
            }
        });
    }
</script>

