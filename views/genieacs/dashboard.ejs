<%- contentFor('body') %>

<div class="space-y-6">
    <!-- Premium Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white/50 backdrop-blur-md p-6 rounded-3xl border border-white/20 shadow-sm transition-all duration-300">
        <div class="flex items-center gap-4">
            <div class="p-3 bg-indigo-600 rounded-2xl shadow-lg shadow-indigo-200 text-white">
                <i class="fas fa-microchip text-2xl"></i>
            </div>
            <div>
                <nav class="flex text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1" aria-label="Breadcrumb">
                    <ol class="list-none p-0 inline-flex">
                        <li class="flex items-center">
                            <a href="/genieacs" class="hover:text-indigo-600 font-black">GenieACS</a>
                            <i class="fas fa-chevron-right mx-2 text-[8px]"></i>
                        </li>
                        <li class="text-indigo-600 font-black">Dashboard</li>
                    </ol>
                </nav>
                <h2 class="text-2xl font-black text-slate-800 uppercase tracking-tight">GenieACS Dashboard</h2>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Manajemen Perangkat TR-069 & Provisioning</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="testConnection()"
                class="flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-white border border-slate-200 text-indigo-600 font-bold text-xs hover:bg-indigo-50 shadow-sm transition-all active:scale-95">
                <i class="fas fa-plug"></i> Test Koneksi
            </button>
            <a href="/genieacs/devices"
                class="flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-indigo-600 text-white font-bold text-xs hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all active:scale-95">
                <i class="fas fa-list"></i> Lihat Devices
            </a>
        </div>
    </div>

    <!-- Connection Status Card -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-6 overflow-hidden relative group">
        <div class="absolute -right-12 -top-12 w-32 h-32 bg-indigo-50 rounded-full blur-3xl transition-all group-hover:scale-150 group-hover:bg-indigo-100"></div>
        <div class="flex items-center gap-6 relative z-10">
            <% if (connectionStatus.success) { %>
                <div class="w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 shadow-sm border border-emerald-100/50">
                    <i class="fas fa-check-circle text-3xl animate-pulse"></i>
                </div>
                <div>
                    <h3 class="text-lg font-black text-emerald-700 uppercase tracking-tight">Terhubung ke GenieACS</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest mt-1">
                        API Server: <span class="text-slate-600"><%= config.host %>:<%= config.port %></span>
                    </p>
                </div>
            <% } else { %>
                <div class="w-16 h-16 bg-rose-50 rounded-2xl flex items-center justify-center text-rose-600 shadow-sm border border-rose-100/50">
                    <i class="fas fa-times-circle text-3xl"></i>
                </div>
                <div>
                    <h3 class="text-lg font-black text-rose-700 uppercase tracking-tight">Koneksi Terputus</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest mt-1">
                        Status: <span class="text-rose-500 font-bold italic"><%= connectionStatus.message %></span>
                    </p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total -->
        <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
            <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Total Devices</p>
                <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                    <i class="fas fa-server"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-slate-800 tracking-tight mb-2"><%= stats.totalDevices %></p>
            <p class="text-[10px] text-slate-400 font-bold">Terdaftar di Sistem</p>
        </div>

        <!-- Online -->
        <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
            <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-black text-emerald-400 uppercase tracking-widest">Online Now</p>
                <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-all">
                    <i class="fas fa-signal"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-emerald-600 tracking-tight mb-4"><%= stats.onlineDevices %></p>
            <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                <div class="h-full bg-emerald-500 rounded-full transition-all duration-1000"
                    style="width: <%= stats.totalDevices > 0 ? (stats.onlineDevices / stats.totalDevices * 100) : 0 %>%">
                </div>
            </div>
            <p class="text-[9px] text-slate-400 font-bold mt-2 uppercase tracking-widest">Efficiency: <%= stats.totalDevices > 0 ? Math.round(stats.onlineDevices / stats.totalDevices * 100) : 0 %>%</p>
        </div>

        <!-- Offline -->
        <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
            <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-black text-rose-400 uppercase tracking-widest">Offline</p>
                <div class="w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center text-rose-600 group-hover:bg-rose-600 group-hover:text-white transition-all">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-rose-600 tracking-tight mb-4"><%= stats.offlineDevices %></p>
            <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                <div class="h-full bg-rose-500 rounded-full transition-all duration-1000"
                    style="width: <%= stats.totalDevices > 0 ? (stats.offlineDevices / stats.totalDevices * 100) : 0 %>%">
                </div>
            </div>
            <p class="text-[9px] text-slate-400 font-bold mt-2 uppercase tracking-widest">Require Check: <%= stats.offlineDevices %> Devices</p>
        </div>

        <!-- Faults -->
        <div class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
            <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-black text-amber-400 uppercase tracking-widest">Recent Faults</p>
                <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600 group-hover:bg-amber-600 group-hover:text-white transition-all">
                    <i class="fas fa-bug"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-amber-600 tracking-tight mb-2"><%= stats.recentFaults %></p>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Critical Errors Detected</p>
        </div>
    </div>

    <!-- Quick Actions Grid -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8">
        <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight mb-6 flex items-center gap-3">
            <span class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center text-sm">
                <i class="fas fa-bolt"></i>
            </span>
            Aksi Cepat
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a href="/genieacs/devices"
                class="flex flex-col p-6 bg-slate-50 border border-slate-100 rounded-3xl hover:bg-white hover:border-indigo-200 hover:shadow-lg transition-all duration-300 group">
                <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center mb-4 shadow-lg shadow-indigo-100 group-hover:scale-110 transition-transform">
                    <i class="fas fa-list text-white"></i>
                </div>
                <p class="font-black text-slate-800 uppercase tracking-widest text-xs">Daftar Devices</p>
                <p class="text-[10px] text-slate-400 font-bold mt-1 uppercase tracking-tighter">Manajemen Seluruh Perangkat</p>
            </a>

            <a href="http://<%= config.host %>:3000" target="_blank"
                class="flex flex-col p-6 bg-slate-50 border border-slate-100 rounded-3xl hover:bg-white hover:border-purple-200 hover:shadow-lg transition-all duration-300 group">
                <div class="w-12 h-12 bg-purple-600 rounded-2xl flex items-center justify-center mb-4 shadow-lg shadow-purple-100 group-hover:scale-110 transition-transform">
                    <i class="fas fa-external-link-alt text-white"></i>
                </div>
                <p class="font-black text-slate-800 uppercase tracking-widest text-xs">GenieACS UI</p>
                <p class="text-[10px] text-slate-400 font-bold mt-1 uppercase tracking-tighter">Akses Dashboard Native</p>
            </a>

            <div onclick="refreshAllDevices()"
                class="flex flex-col p-6 bg-slate-50 border border-slate-100 rounded-3xl hover:bg-white hover:border-emerald-200 hover:shadow-lg transition-all duration-300 group cursor-pointer">
                <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center mb-4 shadow-lg shadow-emerald-100 group-hover:scale-110 transition-transform">
                    <i class="fas fa-sync-alt text-white"></i>
                </div>
                <p class="font-black text-slate-800 uppercase tracking-widest text-xs">Refresh Data</p>
                <p class="text-[10px] text-slate-400 font-bold mt-1 uppercase tracking-tighter">Perbarui Status Massal</p>
            </div>
        </div>
    </div>

    <!-- Premium Info Section -->
    <div class="bg-gradient-to-br from-indigo-600 to-blue-700 rounded-[2.5rem] shadow-2xl shadow-indigo-200 p-8 text-white relative overflow-hidden group">
        <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-white/10 rounded-full blur-3xl transition-all group-hover:bg-white/20 group-hover:scale-110"></div>
        <div class="flex items-start gap-6 relative z-10">
            <div class="w-14 h-14 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center flex-shrink-0 border border-white/20">
                <i class="fas fa-info-circle text-2xl"></i>
            </div>
            <div>
                <h3 class="text-lg font-black uppercase tracking-widest mb-3">Sistem Integrasi GenieACS</h3>
                <p class="text-indigo-100 text-xs font-medium leading-relaxed max-w-3xl">
                    GenieACS adalah Auto Configuration Server (ACS) open-source untuk protokol TR-069.
                    Digunakan untuk mengelola perangkat CPE seperti ONT, router, dan modem secara remote.
                    Provisioning otomatis, monitoring performa, dan troubleshooting perangkat dapat dilakukan secara terpusat dari dashboard ini untuk efisiensi operasional jaringan.
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    async function testConnection() {
        try {
            const response = await fetch('/genieacs/api/test-connection');
            const data = await response.json();

            if (data.success) {
                Swal.fire({
                    title: 'Berhasil!',
                    text: 'Koneksi ke GenieACS berhasil terjalin.',
                    icon: 'success',
                    confirmButtonColor: '#4f46e5',
                    background: '#ffffff',
                    borderRadius: '2rem'
                }).then(() => location.reload());
            } else {
                Swal.fire({
                    title: 'Gagal!',
                    text: 'Koneksi gagal: ' + data.message,
                    icon: 'error',
                    confirmButtonColor: '#ef4444',
                    background: '#ffffff',
                    borderRadius: '2rem'
                });
            }
        } catch (error) {
            Swal.fire({
                title: 'Error!',
                text: 'Kesalahan sistem: ' + error.message,
                icon: 'error',
                confirmButtonColor: '#ef4444',
                background: '#ffffff',
                borderRadius: '2rem'
            });
        }
    }

    function refreshAllDevices() {
        Swal.fire({
            title: 'Refresh Data',
            text: 'Fitur refresh massal sedang dalam tahap sinkronisasi background.',
            icon: 'info',
            confirmButtonColor: '#4f46e5',
            background: '#ffffff',
            borderRadius: '2rem'
        });
    }
</script>
