<%- contentFor('body') %>

<div class="space-y-6">
    <!-- Premium Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white/50 backdrop-blur-md p-6 rounded-3xl border border-white/20 shadow-sm transition-all duration-300">
        <div class="flex items-center gap-4">
            <div class="p-3 bg-indigo-600 rounded-2xl shadow-lg shadow-indigo-200 text-white">
                <i class="fas fa-server text-2xl"></i>
            </div>
            <div>
                <nav class="flex text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1" aria-label="Breadcrumb">
                    <ol class="list-none p-0 inline-flex">
                        <li class="flex items-center">
                            <a href="/genieacs" class="hover:text-indigo-600">GenieACS</a>
                            <i class="fas fa-chevron-right mx-2 text-[8px]"></i>
                        </li>
                        <li class="text-indigo-600">Device List</li>
                    </ol>
                </nav>
                <h2 class="text-2xl font-black text-slate-800 uppercase tracking-tight">Daftar Devices</h2>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-widest">Total <%= pagination.totalCount %> perangkat terdaftar</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <form action="/genieacs/devices/sync-tags" method="POST" class="inline-block"
                onsubmit="return confirm('Proses ini akan mengirim tag nama pelanggan ke semua device di GenieACS. Lanjutkan?');">
                <button type="submit"
                    class="flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-white border border-slate-200 text-indigo-600 font-bold text-xs hover:bg-indigo-50 shadow-sm transition-all active:scale-95">
                    <i class="fas fa-tags"></i> Sync Tags
                </button>
            </form>
            <button onclick="location.reload()"
                class="flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-indigo-600 text-white font-bold text-xs hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all active:scale-95">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>
    </div>

    <!-- Stats Summary -->
    <% if (locals.stats) { %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a href="/genieacs/devices"
                class="group bg-white rounded-[2.5rem] border <%= !locals.statusFilter ? 'border-indigo-500 ring-4 ring-indigo-50' : 'border-slate-100' %> shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Total Devices</p>
                        <p class="text-3xl font-black text-slate-800 tracking-tight"><%= stats.total %></p>
                    </div>
                    <div class="w-14 h-14 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                        <i class="fas fa-microchip text-2xl"></i>
                    </div>
                </div>
            </a>

            <a href="/genieacs/devices?status=online"
                class="group bg-white rounded-[2.5rem] border <%= locals.statusFilter === 'online' ? 'border-emerald-500 ring-4 ring-emerald-50' : 'border-slate-100' %> shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black text-emerald-400 uppercase tracking-widest mb-1">Online Now</p>
                        <p class="text-3xl font-black text-emerald-600 tracking-tight"><%= stats.online %></p>
                    </div>
                    <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300">
                        <i class="fas fa-bolt text-2xl animate-pulse"></i>
                    </div>
                </div>
            </a>

            <a href="/genieacs/devices?status=offline"
                class="group bg-white rounded-[2.5rem] border <%= locals.statusFilter === 'offline' ? 'border-rose-500 ring-4 ring-rose-50' : 'border-slate-100' %> shadow-xl shadow-slate-200/50 p-8 transition-all hover:scale-[1.02]">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black text-rose-400 uppercase tracking-widest mb-1">Offline</p>
                        <p class="text-3xl font-black text-rose-600 tracking-tight"><%= stats.offline %></p>
                    </div>
                    <div class="w-14 h-14 bg-rose-50 rounded-2xl flex items-center justify-center text-rose-600 group-hover:bg-rose-600 group-hover:text-white transition-all duration-300">
                        <i class="fas fa-ban text-2xl"></i>
                    </div>
                </div>
            </a>
        </div>
    <% } %>

    <!-- Search & Filter -->
    <div class="bg-white/70 backdrop-blur-md rounded-3xl border border-slate-100 shadow-xl shadow-slate-200/50 p-4">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative group">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                    <i class="fas fa-search"></i>
                </span>
                <input type="text" id="searchInput"
                    placeholder="Cari serial number, manufacturer, atau model..."
                    class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3.5 pl-11 pr-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-bold text-slate-700 shadow-sm">
            </div>
            <div class="relative w-full md:w-64">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <i class="fas fa-filter"></i>
                </span>
                <select id="statusFilter"
                    class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-3.5 pl-11 pr-4 focus:outline-none focus:ring-4 focus:ring-indigo-100 focus:bg-white transition-all text-sm font-black text-slate-700 appearance-none cursor-pointer">
                    <option value="all">Semua Status</option>
                    <option value="online">Online</option>
                    <option value="offline">Offline</option>
                </select>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[10px]">
                    <i class="fas fa-chevron-down"></i>
                </span>
            </div>
        </div>
    </div>

    <!-- Device Table -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead class="bg-slate-50/50 border-b border-slate-100">
                    <tr>
                        <th class="px-6 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Pelanggan</th>
                        <th class="px-6 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Status</th>
                        <th class="px-6 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Identification</th>
                        <th class="px-6 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Model & HW</th>
                        <th class="px-6 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fas fa-wifi mr-1 text-indigo-500"></i>WiFi Info</th>
                        <th class="px-6 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Last Inform</th>
                        <th class="px-6 py-5 text-center text-[10px] font-black text-slate-400 uppercase tracking-widest">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50" id="deviceTableBody">
                    <% if (devices.length === 0) { %>
                        <tr>
                            <td colspan="7" class="px-6 py-24 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-200">
                                        <i class="fas fa-server text-4xl"></i>
                                    </div>
                                    <p class="text-slate-500 font-bold uppercase tracking-widest text-xs">Tidak ada device ditemukan</p>
                                </div>
                            </td>
                        </tr>
                    <% } else { %>
                        <% devices.forEach((device, index) => { %>
                            <tr class="hover:bg-slate-50/50 transition-all group device-row"
                                data-serial="<%= (device.serialNumber || 'unknown').toLowerCase() %>"
                                data-manufacturer="<%= (device.manufacturer || 'unknown').toLowerCase() %>"
                                data-model="<%= (typeof device.model === 'string' ? device.model : (device.model ? JSON.stringify(device.model) : 'unknown')).toLowerCase() %>"
                                data-online="<%= device.isOnline %>">

                                <!-- Pelanggan -->
                                <td class="px-6 py-4">
                                    <% if (device.customer) { %>
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600 font-bold group-hover:scale-110 transition-transform">
                                                <i class="fas fa-user-circle text-lg"></i>
                                            </div>
                                            <div>
                                                <div class="text-sm font-black text-slate-700 leading-none mb-1">
                                                    <%= device.customer.name %>
                                                </div>
                                                <div class="text-[10px] text-slate-400 font-bold tracking-tight">
                                                    <%= device.customer.phone %>
                                                </div>
                                            </div>
                                        </div>
                                    <% } else { %>
                                        <div class="flex items-center gap-3 opacity-50">
                                            <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center text-slate-400">
                                                <i class="fas fa-question-circle"></i>
                                            </div>
                                            <span class="text-[10px] text-slate-400 font-black uppercase italic">Unlinked</span>
                                        </div>
                                    <% } %>
                                </td>

                                <!-- Status -->
                                <td class="px-6 py-4 text-center">
                                    <% if (device.isOnline) { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-100 text-emerald-600 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm shadow-emerald-50">
                                            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                                            Online
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-slate-400 rounded-full text-[10px] font-black uppercase tracking-widest">
                                            <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span>
                                            Offline
                                        </span>
                                    <% } %>
                                </td>

                                <!-- Serial Number -->
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <a href="/genieacs/devices/<%= encodeURIComponent(device.id) %>"
                                            class="text-sm font-black text-indigo-600 hover:text-indigo-800 transition-colors group-hover:underline underline-offset-4 decoration-2">
                                            <%= device.serialNumber %>
                                        </a>
                                        <span class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter mt-0.5">SN: <%= device.manufacturer || 'Unknown' %></span>
                                    </div>
                                </td>

                                <!-- Model -->
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-xs font-black text-slate-700">
                                            <%= typeof device.model === 'string' ? device.model : (device.model._value || 'Unknown') %>
                                        </span>
                                        <span class="text-[9px] text-slate-400 font-bold tracking-widest uppercase mt-0.5">Software Ver: <%= device.softwareVersion || '?' %></span>
                                    </div>
                                </td>

                                <!-- SSID & WiFi -->
                                <td class="px-6 py-4">
                                    <% if (device.wifi && device.wifi.ssid && device.wifi.ssid !== '-') { %>
                                        <div class="flex flex-col gap-1.5">
                                            <div class="flex items-center gap-1.5 px-2 py-1 bg-indigo-50 text-indigo-700 rounded-lg text-[10px] font-black border border-indigo-100/50">
                                                <i class="fas fa-wifi text-[8px]"></i>
                                                <%= device.wifi.ssid %>
                                            </div>
                                            <div class="flex items-center gap-1.5 px-2 py-1 bg-amber-50 text-amber-700 rounded-lg text-[10px] font-mono border border-amber-100/50">
                                                <i class="fas fa-key text-[8px]"></i>
                                                <%= device.wifi.password %>
                                            </div>
                                        </div>
                                    <% } else { %>
                                        <span class="text-[10px] text-slate-300 font-black uppercase italic tracking-widest">- No WiFi Info -</span>
                                    <% } %>
                                </td>

                                <!-- Last Inform -->
                                <td class="px-6 py-4">
                                    <% if (device.lastInform) { %>
                                        <div class="flex flex-col">
                                            <span class="text-xs font-bold text-slate-700">
                                                <%= new Date(device.lastInform).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                                            </span>
                                            <span class="text-[10px] text-slate-400 font-black uppercase">
                                                <%= new Date(device.lastInform).toLocaleTimeString('id-ID', {hour: '2-digit', minute: '2-digit'}) %> WIB
                                            </span>
                                        </div>
                                    <% } else { %>
                                        <span class="text-slate-300 font-bold">-</span>
                                    <% } %>
                                </td>

                                <!-- Actions -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2">
                                        <a href="/genieacs/devices/<%= encodeURIComponent(device.id) %>"
                                            class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:bg-white hover:shadow-md transition-all active:scale-90"
                                            title="View Detail">
                                            <i class="fas fa-eye text-xs"></i>
                                        </a>
                                        <form action="/genieacs/devices/<%= encodeURIComponent(device.id) %>/refresh" method="POST" class="inline">
                                            <button type="submit"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-emerald-500 hover:bg-emerald-500 hover:text-white transition-all active:scale-90"
                                                title="Refresh Data">
                                                <i class="fas fa-sync-alt text-xs"></i>
                                            </button>
                                        </form>
                                        <form action="/genieacs/devices/<%= encodeURIComponent(device.id) %>/reboot" method="POST" class="inline"
                                            onsubmit="return confirm('Yakin ingin mereboot device ini?')">
                                            <button type="submit"
                                                class="px-3 py-1.5 rounded-lg bg-rose-50 border border-rose-100 text-rose-600 hover:bg-rose-500 hover:text-white transition-all text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 active:scale-95">
                                                <i class="fas fa-power-off text-[9px]"></i> Reboot
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% if (pagination.totalPages > 1) { %>
            <div class="px-8 py-6 bg-slate-50/50 border-t border-slate-100 flex items-center justify-between">
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                    Halaman <span class="text-slate-700"><%= pagination.currentPage %></span> dari <span class="text-slate-700"><%= pagination.totalPages %></span>
                </div>
                <div class="flex gap-3">
                    <% if (pagination.hasPrev) { %>
                        <a href="?page=<%= pagination.currentPage - 1 %>"
                            class="flex items-center gap-2 px-5 py-2 rounded-xl bg-white border border-slate-200 text-slate-600 font-black text-[10px] uppercase tracking-widest hover:bg-slate-50 transition-all active:scale-95 shadow-sm">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    <% } %>
                    <% if (pagination.hasNext) { %>
                        <a href="?page=<%= pagination.currentPage + 1 %>"
                            class="flex items-center gap-2 px-5 py-2 rounded-xl bg-indigo-600 text-white font-black text-[10px] uppercase tracking-widest hover:bg-indigo-700 transition-all active:scale-95 shadow-lg shadow-indigo-200">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script>
    // Search and filter functionality
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const deviceRows = document.querySelectorAll('.device-row');

    function filterDevices() {
        const searchTerm = searchInput.value.toLowerCase();
        const statusValue = statusFilter.value;

        deviceRows.forEach(row => {
            const serial = row.dataset.serial || '';
            const manufacturer = row.dataset.manufacturer || '';
            const model = row.dataset.model || '';
            const isOnline = row.dataset.online === 'true';

            const matchesSearch = serial.includes(searchTerm) ||
                manufacturer.includes(searchTerm) ||
                model.includes(searchTerm);

            const matchesStatus = statusValue === 'all' ||
                (statusValue === 'online' && isOnline) ||
                (statusValue === 'offline' && !isOnline);

            if (matchesSearch && matchesStatus) {
                row.style.display = '';
                row.classList.add('animate-fade-in');
            } else {
                row.style.display = 'none';
            }
        });
    }

    searchInput.addEventListener('input', filterDevices);
    statusFilter.addEventListener('change', filterDevices);
</script>

