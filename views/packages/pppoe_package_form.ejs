                                    <!-- 14 Days -->
                                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 space-y-3">
                                        <div class="flex justify-between items-center">
                                            <span class="text-[10px] font-black text-slate-600 uppercase tracking-widest">14 Hari</span>
                                            <label class="relative inline-flex items-center cursor-pointer">
                                                <input type="checkbox" name="is_enabled_14_days" value="1" class="sr-only peer" onchange="togglePriceInput(this, 'price_14_days')">
                                                <div class="w-8 h-4 bg-slate-200 rounded-full peer peer-checked:bg-emerald-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:after:translate-x-4"></div>
                                            </label>
                                        </div>
                                        <input id="price_14_days" name="price_14_days" type="number" step="1000" disabled placeholder="Rp 0"
                                            class="w-full bg-white border border-slate-200 rounded-xl py-2 px-3 text-xs font-bold text-slate-400 focus:text-slate-700 disabled:opacity-50 transition-all" />
                                    </div>

                                    <!-- 30 Days -->
                                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 space-y-3">
                                        <div class="flex justify-between items-center">
                                            <span class="text-[10px] font-black text-slate-600 uppercase tracking-widest">30 Hari</span>
                                            <label class="relative inline-flex items-center cursor-pointer">
                                                <input type="checkbox" name="is_enabled_30_days" value="1" class="sr-only peer" onchange="togglePriceInput(this, 'price_30_days')">
                                                <div class="w-8 h-4 bg-slate-200 rounded-full peer peer-checked:bg-emerald-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:after:translate-x-4"></div>
                                            </label>
                                        </div>
                                        <input id="price_30_days" name="price_30_days" type="number" step="1000" disabled placeholder="Rp 0"
                                            class="w-full bg-white border border-slate-200 rounded-xl py-2 px-3 text-xs font-bold text-slate-400 focus:text-slate-700 disabled:opacity-50 transition-all" />
