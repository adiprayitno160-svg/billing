                            </div>
                        </div>

                        <!-- Hidden Fields -->
                        <input type="hidden" name="duration_days" value="30" />
                    </div>
                </div>
            </form>
</div>

<script>
    // Auto-fill rate limits from MikroTik profile
    function loadProfileRateLimits(profileId) {
        if (!profileId) {
            document.getElementById('rate_limit_rx').value = '';
            document.getElementById('rate_limit_tx').value = '';
            document.getElementById('burst_limit_rx').value = '';
            document.getElementById('burst_limit_tx').value = '';
            document.getElementById('burst_threshold_rx').value = '';
            document.getElementById('burst_threshold_tx').value = '';
            document.getElementById('burst_time_rx').value = '';
            document.getElementById('burst_time_tx').value = '';
            updateSharedPreview();
            return;
        }

        const selectElement = document.getElementById('profile_id');
        const selectedOption = selectElement.options[selectElement.selectedIndex];

        const rateRx = selectedOption.getAttribute('data-rate-rx');
        const rateTx = selectedOption.getAttribute('data-rate-tx');
        const burstRx = selectedOption.getAttribute('data-burst-rx');
        const burstTx = selectedOption.getAttribute('data-burst-tx');
        const burstThresholdRx = selectedOption.getAttribute('data-burst-threshold-rx');
        const burstThresholdTx = selectedOption.getAttribute('data-burst-threshold-tx');
        const burstTimeRx = selectedOption.getAttribute('data-burst-time-rx');
        const burstTimeTx = selectedOption.getAttribute('data-burst-time-tx');

        document.getElementById('rate_limit_rx').value = (rateRx && rateRx.trim() !== '') ? rateRx : '0';
        document.getElementById('rate_limit_tx').value = (rateTx && rateTx.trim() !== '') ? rateTx : '0';

        document.getElementById('burst_limit_rx').value = (burstRx && burstRx.trim() !== '') ? burstRx : '';
        document.getElementById('burst_limit_tx').value = (burstTx && burstTx.trim() !== '') ? burstTx : '';
        document.getElementById('burst_threshold_rx').value = (burstThresholdRx && burstThresholdRx.trim() !== '') ? burstThresholdRx : '';
        document.getElementById('burst_threshold_tx').value = (burstThresholdTx && burstThresholdTx.trim() !== '') ? burstThresholdTx : '';
        document.getElementById('burst_time_rx').value = (burstTimeRx && burstTimeRx.trim() !== '') ? burstTimeRx : '';
        document.getElementById('burst_time_tx').value = (burstTimeTx && burstTimeTx.trim() !== '') ? burstTimeTx : '';
        
        updateSharedPreview();
    }

    function toggleActivationInfo() {
        const checkbox = document.getElementById('auto_activation');
        const status = document.getElementById('activation_status');
        const infoInactive = document.getElementById('activation_info');
        const infoActive = document.getElementById('activation_info_active');

        if (checkbox.checked) {
            status.textContent = 'Aktif';
            status.classList.remove('text-slate-600');
            status.classList.add('text-emerald-600', 'font-black');
            infoInactive.classList.add('hidden');
            infoActive.classList.remove('hidden');
        } else {
            status.textContent = 'Nonaktif';
            status.classList.remove('text-emerald-600', 'font-black');
            status.classList.add('text-slate-600');
            infoActive.classList.add('hidden');
            infoInactive.classList.remove('hidden');
        }
    }

    function toggleProfileMode() {
        const isNew = document.getElementById('create_new_profile').checked;
        const selectContainer = document.getElementById('profile_select_container');
        const newContainer = document.getElementById('new_profile_container');
        const profileSelect = document.getElementById('profile_id');

        if (isNew) {
            selectContainer.classList.add('hidden');
            newContainer.classList.remove('hidden');
            profileSelect.disabled = true;
            loadProfileRateLimits('');
        } else {
            selectContainer.classList.remove('hidden');
            newContainer.classList.add('hidden');
            profileSelect.disabled = false;
        }
    }

    function togglePriceInput(checkbox, inputId) {
        const input = document.getElementById(inputId);
        if (checkbox.checked) {
            input.disabled = false;
            input.classList.remove('text-slate-400');
            input.classList.add('text-slate-700');
            input.focus();
        } else {
            input.disabled = true;
            input.classList.add('text-slate-400');
            input.classList.remove('text-slate-700');
        }
    }

    function toggleBurstInputs() {
        const checkbox = document.getElementById('burst_enabled');
        const container = document.getElementById('burst_inputs_container');
        
        if (checkbox.checked) {
            container.classList.remove('opacity-40', 'pointer-events-none');
        } else {
            container.classList.add('opacity-40', 'pointer-events-none');
        }
    }

    function parseRate(val) {
        if (!val) return 0;
        val = val.toUpperCase().trim();
        let num = parseFloat(val);
        if (val.endsWith('M')) return num;
        if (val.endsWith('K')) return num / 1024;
        if (val.endsWith('G')) return num * 1024;
        return num;
    }

    function formatRate(num) {
        if (num >= 1024) return (num / 1024).toFixed(1) + 'G';
        if (num < 1) return (num * 1024).toFixed(0) + 'K';
        return num.toFixed(1) + 'M';
    }

    function updateSharedPreview() {
        const rateRx = document.getElementById('rate_limit_rx').value;
        const maxClients = parseInt(document.getElementById('max_clients').value) || 1;
        const previewUpto = document.getElementById('preview-upto');
        const previewCir = document.getElementById('preview-cir');
        const sharedInfo = document.getElementById('shared_preview_info');
        const previewTotal = document.getElementById('preview-total');

        if (!rateRx || rateRx === '0') {
            previewUpto.textContent = 'UNL';
            previewCir.textContent = 'UNL';
            sharedInfo.classList.add('hidden');
            return;
        }

        const rxNum = parseRate(rateRx);
        previewUpto.textContent = formatRate(rxNum);

        if (maxClients > 1) {
            sharedInfo.classList.remove('hidden');
            previewTotal.textContent = rateRx;
            const cir = rxNum / maxClients;
            previewCir.textContent = formatRate(cir);
            document.getElementById('limit_at_download').value = formatRate(cir);
        } else {
            sharedInfo.classList.add('hidden');
            previewCir.textContent = formatRate(rxNum);
            document.getElementById('limit_at_download').value = '';
        }

        // Sim Card Pulse Effect
        const simCard = document.querySelector('.bg-gradient-to-br');
        simCard.classList.add('ring-4', 'ring-white/20');
        setTimeout(() => simCard.classList.remove('ring-4', 'ring-white/20'), 300);
    }

    document.addEventListener('DOMContentLoaded', function () {
        toggleActivationInfo();
        
        // Listeners for live preview
        ['rate_limit_rx', 'max_clients'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateSharedPreview);
        });
    });
</script>
