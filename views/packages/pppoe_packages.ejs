<div class="space-y-6">
    <!-- Header Page -->
    <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white/50 backdrop-blur-md p-4 rounded-2xl border border-white/20 shadow-sm transition-all duration-300">
        <div class="flex items-center gap-4">
            <div class="p-3 bg-indigo-600 rounded-xl shadow-lg shadow-indigo-200 text-white">
                <i class="fas fa-network-wired text-xl"></i>
            </div>
            <div>
                <nav class="flex text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1"
                    aria-label="Breadcrumb">
                    <ol class="list-none p-0 inline-flex">
                        <li class="flex items-center">
                            <a href="/dashboard" class="hover:text-indigo-600">Admin</a>
                            <i class="fas fa-chevron-right mx-2 text-[8px]"></i>
                        </li>
                        <li class="text-indigo-600">PPPoE Packages</li>
                    </ol>
                </nav>
                <h2 class="text-xl font-bold text-slate-800 uppercase tracking-tight">Daftar Paket PPPoE</h2>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <a href="/packages/pppoe/packages/create"
                class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-indigo-600 text-white font-bold text-xs hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all active:scale-95">
                <i class="fas fa-plus"></i>
                <span class="hidden sm:inline text-nowrap">Tambah Paket</span>
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    <% if (success && success.length > 0) { %>
        <div
            class="p-4 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-2xl flex items-center gap-3 shadow-sm animate-fade-in-down">
            <i class="fas fa-check-circle text-xl"></i>
            <p class="font-medium text-sm">
                <%= success[0] %>
            </p>
        </div>
    <% } %>

    <% if (error && error.length > 0) { %>
        <div
            class="p-4 bg-rose-50 border border-rose-100 text-rose-700 rounded-2xl flex items-center gap-3 shadow-sm animate-shake">
            <i class="fas fa-exclamation-circle text-xl"></i>
            <p class="font-medium text-sm">
                <%= error[0] %>
            </p>
        </div>
    <% } %>

    <!-- Content Section -->
    <div class="bg-white rounded-3xl border border-slate-100 shadow-xl shadow-slate-200/50 overflow-visible">
        <!-- Desktop Table View -->
        <div class="hidden md:block overflow-visible">
            <table class="min-w-full divide-y divide-slate-100">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-tighter">
                            Nama Paket</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-tighter">
                            Profil / Mikrotik</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-tighter">
                            Speed (RX/TX)</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-tighter text-center">
                            Clients</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-tighter text-center text-nowrap">
                            Harga / Bulan</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-tighter text-center">
                            Status</th>
                        <th class="px-6 py-4 text-center text-[10px] font-black text-slate-400 uppercase tracking-tighter">
                            Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% (packages || []).forEach(function(pkg){ %>
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-slate-500 group-hover:bg-indigo-100 group-hover:text-indigo-600 transition-all font-bold">
                                        <%= pkg.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2">
                                            <span class="font-bold text-slate-700">
                                                <%= pkg.name %>
                                            </span>
                                            <% if ((pkg.max_clients || 1) > 1) { %>
                                                <span class="px-1.5 py-0.5 text-[8px] rounded-md bg-purple-100 text-purple-600 border border-purple-200 font-black uppercase tracking-widest">
                                                    SHARE
                                                </span>
                                            <% } %>
                                        </div>
                                        <p class="text-[10px] text-slate-400 font-medium">PPPoE Service</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col gap-0.5">
                                    <span class="text-xs font-bold text-slate-600 flex items-center gap-1.5">
                                        <i class="fas fa-id-card text-[9px] text-slate-400"></i>
                                        <%= pkg.profile_name || '-' %>
                                    </span>
                                    <span class="text-[10px] text-slate-400 font-medium">MikroTik Profile</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col gap-0.5">
                                    <span class="text-xs font-bold text-slate-600 flex items-center gap-1.5">
                                        <i class="fas fa-arrow-down text-[9px] text-blue-400"></i>
                                        <%= pkg.rate_limit_rx || '?' %>
                                    </span>
                                    <span class="text-xs font-bold text-slate-600 flex items-center gap-1.5">
                                        <i class="fas fa-arrow-up text-[9px] text-orange-400"></i>
                                        <%= pkg.rate_limit_tx || '?' %>
                                    </span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex flex-col items-center gap-1">
                                    <div class="w-24 bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                        <% 
                                            let maxClients = pkg.max_clients || 999;
                                            let isInfinite = !pkg.max_clients || pkg.max_clients >= 999;
                                            let clientPercent = isInfinite ? 0 : Math.min(((pkg.current_clients || 0) / maxClients) * 100, 100); 
                                        %>
                                        <div class="h-full <%= clientPercent >= 90 ? 'bg-rose-500' : 'bg-indigo-500' %>"
                                            style="width: <%= isInfinite ? '0' : clientPercent %>%"></div>
                                    </div>
                                    <span class="text-[10px] font-black tracking-tight <%= (pkg.current_clients || 0) >= maxClients ? 'text-rose-600' : 'text-indigo-600' %>">
                                        <%= pkg.current_clients || 0 %> / <%= isInfinite ? '∞' : maxClients %>
                                    </span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-center text-nowrap">
                                <span class="text-sm font-black text-slate-700">Rp <%= Number(pkg.price).toLocaleString('id-ID') %></span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex flex-col items-center gap-1">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= pkg.status === 'active' ? 'bg-emerald-100 text-emerald-600' : 'bg-slate-100 text-slate-400' %>">
                                        <%= pkg.status === 'active' ? 'Active' : 'Offline' %>
                                    </span>
                                    <% if (!pkg.auto_activation) { %>
                                        <span class="text-[8px] font-black text-amber-500 uppercase tracking-tighter">Manual Activation</span>
                                    <% } %>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-center gap-2">
                                    <button type="button" 
                                        onclick='copyPackage(<%= JSON.stringify(pkg) %>)'
                                        class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:bg-amber-500 hover:text-white hover:border-amber-500 transition-all active:scale-90"
                                        title="Copy Package">
                                        <i class="fas fa-clone text-xs"></i>
                                    </button>
                                    <a href="/packages/pppoe/packages/<%= pkg.id %>/edit"
                                        class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:bg-white hover:shadow-md transition-all active:scale-90"
                                        title="Edit Package">
                                        <i class="fas fa-edit text-xs"></i>
                                    </a>
                                    <button type="button"
                                        onclick="confirmDeletePackage('<%= pkg.id %>', '<%= pkg.name %>')"
                                        class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-rose-400 hover:bg-rose-500 hover:text-white hover:border-rose-500 transition-all active:scale-90"
                                        title="Delete Package">
                                        <i class="fas fa-trash text-xs"></i>
                                    </button>
                                    <form id="delete-form-<%= pkg.id %>" method="post" action="/packages/pppoe/packages/<%= pkg.id %>/delete" class="hidden"></form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (!packages || packages.length === 0) { %>
                        <tr>
                            <td colspan="7" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-300">
                                        <i class="fas fa-box-open text-4xl"></i>
                                    </div>
                                    <p class="text-slate-500 font-bold uppercase tracking-widest text-[10px]">Belum ada paket PPPoE</p>
                                    <a href="/packages/pppoe/packages/create" class="text-indigo-600 font-bold text-xs underline mt-2 hover:text-indigo-700">Buat paket pertama anda</a>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Mobile Card View -->
        <div class="md:hidden divide-y divide-slate-100 p-4 space-y-4">
            <% (packages || []).forEach(function(pkg){ %>
                <div class="flex flex-col gap-4 p-4 rounded-3xl border border-slate-100 bg-white shadow-sm overflow-visible relative">
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-black">
                                <%= pkg.name.charAt(0).toUpperCase() %>
                            </div>
                            <div>
                                <h4 class="font-black text-slate-800 tracking-tight leading-none"><%= pkg.name %></h4>
                                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mt-1">PPPoE Mode</p>
                            </div>
                        </div>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest <%= pkg.status === 'active' ? 'bg-emerald-100 text-emerald-600' : 'bg-slate-100 text-slate-400' %>">
                            <%= pkg.status === 'active' ? 'Active' : 'Offline' %>
                        </span>
                    </div>

                    <div class="grid grid-cols-2 gap-3 pb-3 border-b border-slate-50">
                        <div class="bg-slate-50/50 p-2.5 rounded-2xl border border-slate-100/50">
                            <span class="block text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1">RX/TX Speed</span>
                            <div class="flex flex-col gap-0.5 font-bold text-slate-800">
                                <span class="text-[10px] tracking-tight">DN: <%= pkg.rate_limit_rx %></span>
                                <span class="text-[10px] tracking-tight">UP: <%= pkg.rate_limit_tx %></span>
                            </div>
                        </div>
                        <div class="bg-slate-50/50 p-2.5 rounded-2xl border border-slate-100/50">
                            <span class="block text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1">Profile</span>
                            <div class="flex items-center gap-1.5 font-bold text-slate-800">
                                <i class="fas fa-id-card text-[8px] text-slate-400"></i>
                                <span class="text-[10px] tracking-tight truncate"><%= pkg.profile_name || '-' %></span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between">
                        <div>
                            <span class="block text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Harga / Bulan</span>
                            <span class="text-sm font-black text-slate-800">Rp <%= Number(pkg.price).toLocaleString('id-ID') %></span>
                        </div>
                        <div class="text-right">
                            <span class="block text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Slot Client</span>
                            <span class="text-[10px] font-black text-indigo-600">
                                <%= pkg.current_clients || 0 %> / <%= (!pkg.max_clients || pkg.max_clients >= 999) ? '∞' : pkg.max_clients %>
                            </span>
                        </div>
                    </div>

                    <div class="grid grid-cols-3 gap-2 pt-2">
                        <button type="button" 
                            onclick='copyPackage(<%= JSON.stringify(pkg) %>)'
                            class="flex flex-col items-center justify-center gap-1.5 p-3 rounded-2xl bg-amber-500 text-white shadow-lg shadow-amber-200">
                            <i class="fas fa-clone text-sm"></i>
                            <span class="text-[8px] font-bold uppercase tracking-widest">Copy</span>
                        </button>
                        <a href="/packages/pppoe/packages/<%= pkg.id %>/edit"
                            class="flex flex-col items-center justify-center gap-1.5 p-3 rounded-2xl bg-white border border-slate-200 text-slate-600">
                            <i class="fas fa-edit text-sm"></i>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-slate-500">Edit</span>
                        </a>
                        <button type="button"
                            onclick="confirmDeletePackage('<%= pkg.id %>', '<%= pkg.name %>')"
                            class="flex flex-col items-center justify-center gap-1.5 p-3 rounded-2xl bg-rose-50 border border-rose-100 text-rose-600">
                            <i class="fas fa-trash text-sm"></i>
                            <span class="text-[8px] font-bold uppercase tracking-widest text-rose-600">Hapus</span>
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<!-- Simple Hidden Form for Copy Logic (handled in JS or Controller) -->
<form id="copy-form" method="post" action="/packages/pppoe/packages/create" class="hidden">
    <input type="hidden" name="name" id="copy-name">
    <input type="hidden" name="price" id="copy-price">
    <input type="hidden" name="profile_id" id="copy-profile">
    <input type="hidden" name="rate_limit_rx" id="copy-rx">
    <input type="hidden" name="rate_limit_tx" id="copy-tx">
    <input type="hidden" name="max_clients" id="copy-max">
    <input type="hidden" name="status" value="active">
</form>

<script>
    function copyPackage(pkg) {
        Swal.fire({
            title: 'Duplikasi Paket',
            text: `Apakah Anda ingin menduplikasi paket "${pkg.name}"?`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Ya, Duplikasi',
            cancelButtonText: 'Batal',
            confirmButtonColor: '#4f46e5',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                // We use the existing form structure or redirect to edit page with copy flag
                // For now, let's redirect to create page and fill it if possible, 
                // but simpler is to use a hidden form and submit
                const form = document.getElementById('copy-form');
                document.getElementById('copy-name').value = pkg.name + ' (Copy)';
                document.getElementById('copy-price').value = pkg.price;
                document.getElementById('copy-profile').value = pkg.profile_id || '';
                document.getElementById('copy-rx').value = pkg.rate_limit_rx || '';
                document.getElementById('copy-tx').value = pkg.rate_limit_tx || '';
                document.getElementById('copy-max').value = pkg.max_clients || 1;
                form.submit();
            }
        });
    }

    function confirmDeletePackage(id, name) {
        Swal.fire({
            title: 'Hapus Paket?',
            text: `Paket "${name}" akan dihapus secara permanen dari sistem.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Ya, Hapus!',
            cancelButtonText: 'Batal',
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('delete-form-' + id).submit();
            }
        });
    }
</script>

