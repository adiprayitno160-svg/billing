<div class="px-4 py-6 max-w-[1920px] mx-auto space-y-6">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 tracking-tight">IP Address Checker</h1>
            <p class="text-gray-500 mt-1">Scan alokasi IP Address /30 per subnet — lihat IP kosong & terpakai</p>
        </div>
        <div class="flex gap-2">
            <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-100 text-blue-700 border border-blue-200">
                <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
                <%= totalPackages %> Paket
            </span>
            <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-semibold bg-emerald-100 text-emerald-700 border border-emerald-200">
                <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                <%= totalClients %> Client IP Aktif
            </span>
        </div>
    </div>

    <!-- /30 Subnet Tabs Scanner -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-indigo-50">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">IP Checker /30</h2>
                        <p class="text-xs text-gray-500">Scan per subnet — IP Client: .2, .6, .10, .14, ... .254</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" onclick="rescanCurrentTab()" class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-medium bg-emerald-600 text-white hover:bg-emerald-700 shadow-sm transition-colors">
                        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        Rescan
                    </button>
                    <button type="button" onclick="showAddTabModal()" class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 shadow-sm transition-colors">
                        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Tambah Tab Subnet
                    </button>
                </div>
            </div>
        </div>

        <!-- Subnet Tabs -->
        <div class="border-b border-gray-200 bg-gray-50 px-4 overflow-x-auto" id="subnetTabsContainer">
            <div class="flex gap-1 py-2" id="subnetTabs">
                <% if (savedTabs && savedTabs.length > 0) { savedTabs.forEach(function(tab, idx) { %>
                <button type="button" 
                    class="subnet-tab relative group px-4 py-2 rounded-lg text-sm font-medium transition-all whitespace-nowrap <%= idx === 0 ? 'bg-blue-600 text-white shadow-sm' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>"
                    data-subnet="<%= tab %>"
                    onclick="switchTab(this, '<%= tab %>')">
                    <%= tab %>.x
                    <span class="hidden group-hover:inline-flex absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white rounded-full items-center justify-center text-[10px] cursor-pointer" 
                          onclick="event.stopPropagation(); deleteTab('<%= tab %>')">×</span>
                </button>
                <% }); } %>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="px-6 py-3 border-b border-gray-200 bg-white" id="statsBar" style="display:none;">
            <div class="flex flex-wrap gap-4 items-center">
                <div class="flex items-center gap-2">
                    <span class="text-xs text-gray-500">Total Slot:</span>
                    <span class="text-sm font-bold text-gray-900" id="stat30Total">-</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-red-500 rounded-full"></span>
                    <span class="text-xs text-gray-500">Terpakai:</span>
                    <span class="text-sm font-bold text-red-600" id="stat30Used">-</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
                    <span class="text-xs text-gray-500">Tersedia:</span>
                    <span class="text-sm font-bold text-emerald-600" id="stat30Available">-</span>
                </div>
                <div class="ml-auto flex gap-2">
                    <button type="button" onclick="filter30('all')" class="filter30-btn px-3 py-1 text-xs font-medium rounded-full bg-gray-800 text-white">Semua</button>
                    <button type="button" onclick="filter30('used')" class="filter30-btn px-3 py-1 text-xs font-medium rounded-full bg-red-100 text-red-700 hover:bg-red-200">Terpakai</button>
                    <button type="button" onclick="filter30('available')" class="filter30-btn px-3 py-1 text-xs font-medium rounded-full bg-emerald-100 text-emerald-700 hover:bg-emerald-200">Kosong</button>
                </div>
            </div>
        </div>

        <!-- Loading -->
        <div id="scanLoading" class="hidden px-6 py-12 text-center">
            <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto mb-3" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-100" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="text-sm text-gray-500">Memindai IP address...</p>
        </div>

        <!-- Scan Results Table -->
        <div id="scan30Results" class="hidden">
            <div class="overflow-x-auto max-h-[600px] overflow-y-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50 sticky top-0 z-10">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">No</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Subnet /30</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Client IP</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Gateway</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Pemilik</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Paket</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase bg-gray-50">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="scan30TableBody" class="bg-white divide-y divide-gray-100"></tbody>
                </table>
            </div>
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-center">
                <button type="button" onclick="rescanCurrentTab()" class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 shadow-sm transition-colors">
                    <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    Refresh Scan
                </button>
            </div>
        </div>

        <!-- Initial State -->
        <div id="scan30Initial" class="px-6 py-12 text-center">
            <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <p class="text-gray-500 text-sm">Pilih tab subnet untuk memulai scan</p>
            <p class="text-gray-400 text-xs mt-1">IP akan di-scan otomatis saat tab dipilih</p>
        </div>
    </div>

    <!-- Summary Stats per Package -->
    <% if (packages && packages.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <% packages.forEach(function(pkg) { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <h3 class="font-semibold text-gray-900 text-sm truncate"><%= pkg.name %></h3>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                    <%= pkg.used_clients %>/<%= pkg.max_clients || '∞' %>
                </span>
            </div>
            <div class="flex items-center gap-2">
                <div class="flex-1 bg-gray-100 rounded-full h-2">
                    <div class="bg-blue-500 h-2 rounded-full transition-all" style="width: <%= pkg.max_clients ? Math.min((pkg.used_clients / pkg.max_clients) * 100, 100) : 0 %>%"></div>
                </div>
                <span class="text-xs text-gray-500 whitespace-nowrap"><%= pkg.max_clients ? Math.round((pkg.used_clients / pkg.max_clients) * 100) : 0 %>%</span>
            </div>
            <p class="text-xs text-gray-400 mt-2">
                Speed: <%= pkg.max_limit_upload || '-' %> / <%= pkg.max_limit_download || '-' %> |
                Rp <%= pkg.price ? Number(pkg.price).toLocaleString('id-ID') : '-' %>
            </p>
        </div>
        <% }); %>
    </div>
    <% } %>


</div>

<!-- Add Tab Modal -->
<div id="addTabModal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50" onclick="hideAddTabModal()"></div>
    <div class="fixed inset-0 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md relative">
            <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-bold text-gray-900">Tambah Tab Subnet</h3>
                <p class="text-xs text-gray-500 mt-1">Masukkan 3 oktet pertama dari subnet (contoh: 192.168.101)</p>
            </div>
            <div class="px-6 py-4">
                <input type="text" id="newTabInput" placeholder="192.168.101" 
                    class="w-full rounded-xl border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm py-2.5"
                    pattern="[0-9]+\.[0-9]+\.[0-9]+" maxlength="15">
                <p class="text-xs text-gray-400 mt-2">Format: xxx.xxx.xxx (3 oktet). Contoh: 192.168.101, 10.0.0</p>
            </div>
            <div class="px-6 py-3 border-t border-gray-200 flex gap-2 justify-end">
                <button type="button" onclick="hideAddTabModal()" class="px-4 py-2 text-sm rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50">Batal</button>
                <button type="button" onclick="addNewTab()" class="px-4 py-2 text-sm rounded-lg bg-blue-600 text-white hover:bg-blue-700 font-medium">Tambah & Scan</button>
            </div>
        </div>
    </div>
</div>

<script>
    let current30Data = [];
    let currentFilter30 = 'all';
    let currentSubnet = '';

    // Auto-scan first tab on page load
    document.addEventListener('DOMContentLoaded', () => {
        const firstTab = document.querySelector('.subnet-tab');
        if (firstTab) {
            const subnet = firstTab.getAttribute('data-subnet');
            scan30(subnet);
        }
    });

    function switchTab(btn, subnet) {
        document.querySelectorAll('.subnet-tab').forEach(t => {
            t.className = t.className.replace('bg-blue-600 text-white shadow-sm', 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200');
        });
        btn.className = btn.className.replace('bg-white text-gray-600 hover:bg-gray-100 border border-gray-200', 'bg-blue-600 text-white shadow-sm');
        scan30(subnet);
    }

    async function scan30(baseNetwork) {
        currentSubnet = baseNetwork;
        const loading = document.getElementById('scanLoading');
        const results = document.getElementById('scan30Results');
        const initial = document.getElementById('scan30Initial');
        const statsBar = document.getElementById('statsBar');

        initial.style.display = 'none';
        results.classList.add('hidden');
        loading.classList.remove('hidden');

        try {
            const response = await fetch('/network/ip-checker/scan30', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ baseNetwork })
            });
            const result = await response.json();
            if (!result.success) throw new Error(result.message);

            current30Data = result.data.ips;
            document.getElementById('stat30Total').textContent = result.data.totalSlots;
            document.getElementById('stat30Used').textContent = result.data.usedCount;
            document.getElementById('stat30Available').textContent = result.data.availableCount;
            statsBar.style.display = '';

            currentFilter30 = 'all';
            render30Table(current30Data);
            results.classList.remove('hidden');
        } catch (error) {
            console.error('Scan error:', error);
            results.classList.add('hidden');
            initial.style.display = '';
            initial.innerHTML = '<p class="text-red-500 text-sm py-8">Error: ' + error.message + '</p>';
        } finally {
            loading.classList.add('hidden');
        }
    }

    function rescanCurrentTab() {
        if (currentSubnet) {
            scan30(currentSubnet);
        } else {
            alert('Pilih tab subnet terlebih dahulu');
        }
    }

    function render30Table(ips) {
        const tbody = document.getElementById('scan30TableBody');
        tbody.innerHTML = '';
        let num = 0;
        ips.forEach(item => {
            num++;
            const tr = document.createElement('tr');
            const isManual = item.owner && item.owner.is_manual;
            tr.className = item.status === 'used' 
                ? (isManual ? 'bg-amber-50/30 hover:bg-amber-50' : 'bg-red-50/30 hover:bg-red-50') 
                : 'hover:bg-emerald-50/30';
            tr.setAttribute('data-status30', item.status);
            
            let statusBadge;
            if (isManual) {
                statusBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800"><span class="w-1.5 h-1.5 bg-amber-500 rounded-full mr-1"></span>Manual</span>';
            } else if (item.status === 'used') {
                statusBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1"></span>Terpakai</span>';
            } else {
                statusBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800"><span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-1"></span>Kosong</span>';
            }

            const ownerName = item.owner ? item.owner.customer_name : '<span class="text-gray-300">—</span>';
            const ownerCode = item.owner && item.owner.customer_code ? '<span class="text-xs text-gray-400">' + item.owner.customer_code + '</span>' : '';
            const ownerStatus = item.owner && item.owner.customer_status === 'inactive' ? ' <span class="text-xs text-red-500">(Nonaktif)</span>' : '';
            const pkgName = item.owner && item.owner.package_name 
                ? '<span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium ' + (isManual ? 'bg-amber-50 text-amber-700 border border-amber-200' : 'bg-indigo-50 text-indigo-700 border border-indigo-200') + '">' + item.owner.package_name + '</span>' 
                : '<span class="text-gray-300">—</span>';

            // Build action buttons
            let actionHtml = '';
            if (item.owner && item.owner.customer_id) {
                actionHtml += '<a href="/customers/' + item.owner.customer_id + '" class="text-blue-600 hover:underline text-xs mr-2">Detail</a>';
            }
            // Edit/Add label button - always available
            const currentLabel = item.owner ? (item.owner.customer_name || '') : '';
            const escapedLabel = currentLabel.replace(/'/g, "\\'").replace(/"/g, '&quot;');
            if (isManual) {
                actionHtml += '<button onclick="openEditLabelModal(\'' + item.ip + '\', \'' + escapedLabel + '\')" class="text-amber-600 hover:text-amber-800 text-xs mr-1" title="Edit Label"><svg class="w-3.5 h-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>';
                actionHtml += '<button onclick="deleteManualLabel(\'' + item.ip + '\')" class="text-red-500 hover:text-red-700 text-xs" title="Hapus Label"><svg class="w-3.5 h-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>';
            } else if (!item.owner) {
                actionHtml += '<button onclick="openEditLabelModal(\'' + item.ip + '\', \'\')" class="inline-flex items-center px-2 py-0.5 text-xs font-medium text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 rounded-md border border-blue-200 transition-colors" title="Tambah Nama"><svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>Label</button>';
            } else {
                actionHtml += '<button onclick="openEditLabelModal(\'' + item.ip + '\', \'' + escapedLabel + '\')" class="text-gray-400 hover:text-blue-600 text-xs" title="Edit Label"><svg class="w-3.5 h-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>';
            }

            tr.innerHTML = `
                <td class="px-4 py-2.5 text-sm text-gray-400">${num}</td>
                <td class="px-4 py-2.5 text-xs font-mono text-gray-500">${item.subnet}</td>
                <td class="px-4 py-2.5"><span class="text-sm font-mono font-semibold ${item.status === 'used' ? 'text-gray-900' : 'text-emerald-700'}">${item.ip}</span></td>
                <td class="px-4 py-2.5 text-sm font-mono text-gray-500">${item.gateway}</td>
                <td class="px-4 py-2.5">${statusBadge}</td>
                <td class="px-4 py-2.5 text-sm text-gray-900">${ownerName} ${ownerCode} ${ownerStatus}</td>
                <td class="px-4 py-2.5">${pkgName}</td>
                <td class="px-4 py-2.5">${actionHtml}</td>
            `;
            tbody.appendChild(tr);
        });
    }

    function filter30(type) {
        currentFilter30 = type;
        // Update button styles
        document.querySelectorAll('.filter30-btn').forEach(btn => {
            btn.className = btn.className.replace('bg-gray-800 text-white', 'bg-gray-200 text-gray-700 hover:bg-gray-300');
        });
        
        if (type === 'all') {
            render30Table(current30Data);
            document.querySelectorAll('.filter30-btn')[0].className = document.querySelectorAll('.filter30-btn')[0].className.replace('bg-gray-200 text-gray-700 hover:bg-gray-300', 'bg-gray-800 text-white');
        } else if (type === 'used') {
            render30Table(current30Data.filter(ip => ip.status === 'used'));
            document.querySelectorAll('.filter30-btn')[1].className = document.querySelectorAll('.filter30-btn')[1].className.replace('bg-red-100 text-red-700 hover:bg-red-200', 'bg-gray-800 text-white');
        } else {
            render30Table(current30Data.filter(ip => ip.status === 'available'));
            document.querySelectorAll('.filter30-btn')[2].className = document.querySelectorAll('.filter30-btn')[2].className.replace('bg-emerald-100 text-emerald-700 hover:bg-emerald-200', 'bg-gray-800 text-white');
        }
    }

    // Tab management
    function showAddTabModal() { document.getElementById('addTabModal').classList.remove('hidden'); document.getElementById('newTabInput').focus(); }
    function hideAddTabModal() { document.getElementById('addTabModal').classList.add('hidden'); }

    async function addNewTab() {
        const input = document.getElementById('newTabInput');
        const subnet = input.value.trim();
        if (!subnet) return;

        const octets = subnet.split('.');
        if (octets.length !== 3 || octets.some(o => isNaN(parseInt(o)) || parseInt(o) < 0 || parseInt(o) > 255)) {
            alert('Format tidak valid. Gunakan 3 oktet, contoh: 192.168.101');
            return;
        }

        try {
            const res = await fetch('/network/ip-checker/tabs', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subnet })
            });
            const data = await res.json();
            if (data.success) {
                hideAddTabModal();
                window.location.reload();
            } else {
                alert(data.message || 'Gagal menambah tab');
            }
        } catch (e) {
            alert('Error: ' + e.message);
        }
    }

    async function deleteTab(subnet) {
        if (!confirm('Hapus tab ' + subnet + '?')) return;
        try {
            const res = await fetch('/network/ip-checker/tabs', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subnet })
            });
            const data = await res.json();
            if (data.success) window.location.reload();
        } catch (e) { alert('Error: ' + e.message); }
    }



    // Enter key in modal
    document.getElementById('newTabInput')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); addNewTab(); }
    });

    // ======= Manual IP Label Functions =======
    function openEditLabelModal(ip, currentLabel) {
        document.getElementById('editLabelIp').textContent = ip;
        document.getElementById('editLabelIpHidden').value = ip;
        document.getElementById('editLabelInput').value = currentLabel || '';
        document.getElementById('editLabelModal').classList.remove('hidden');
        setTimeout(() => document.getElementById('editLabelInput').focus(), 100);
    }

    function hideEditLabelModal() {
        document.getElementById('editLabelModal').classList.add('hidden');
    }

    async function saveManualLabel() {
        const ip = document.getElementById('editLabelIpHidden').value;
        const comment = document.getElementById('editLabelInput').value.trim();
        if (!comment) { alert('Nama/Komentar tidak boleh kosong'); return; }

        const btn = document.getElementById('saveLabelBtn');
        const origText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg class="animate-spin h-4 w-4 mr-1.5 inline" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Menyimpan...';

        try {
            const res = await fetch('/network/ip-checker/update-comment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ip_address: ip, comment })
            });
            const data = await res.json();
            if (data.success) {
                hideEditLabelModal();
                // Show success toast
                showToast(data.message || 'Label berhasil disimpan', 'success');
                // Rescan to refresh the table
                if (currentSubnet) scan30(currentSubnet);
            } else {
                alert(data.message || 'Gagal menyimpan label');
            }
        } catch (e) {
            alert('Error: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = origText;
        }
    }

    async function deleteManualLabel(ip) {
        if (!confirm('Hapus label manual untuk ' + ip + '?')) return;
        try {
            const res = await fetch('/network/ip-checker/delete-comment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ip_address: ip })
            });
            const data = await res.json();
            if (data.success) {
                showToast('Label berhasil dihapus', 'success');
                if (currentSubnet) scan30(currentSubnet);
            } else {
                alert(data.message || 'Gagal menghapus label');
            }
        } catch (e) {
            alert('Error: ' + e.message);
        }
    }

    function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `fixed bottom-6 right-6 z-[9999] px-5 py-3 rounded-xl shadow-lg text-sm font-medium text-white transition-all transform translate-y-2 opacity-0 ${
            type === 'success' ? 'bg-emerald-600' : type === 'error' ? 'bg-red-600' : 'bg-blue-600'
        }`;
        toast.textContent = message;
        document.body.appendChild(toast);
        requestAnimationFrame(() => {
            toast.style.transform = 'translateY(0)';
            toast.style.opacity = '1';
        });
        setTimeout(() => {
            toast.style.transform = 'translateY(10px)';
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // Enter key in edit label modal
    document.getElementById('editLabelInput')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); saveManualLabel(); }
    });
</script>

