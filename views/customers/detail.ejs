<div class="space-y-6">
    <!-- Header Section -->
    <nav class="flex flex-col md:flex-row items-center justify-between gap-6 py-4 px-2">
        <div class="flex items-center gap-5 w-full md:w-auto">
            <div class="relative group">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl blur opacity-30 group-hover:opacity-50 transition duration-1000"></div>
                <div class="relative p-3.5 bg-white border border-slate-100 shadow-sm rounded-2xl text-blue-600 transform hover:scale-105 transition-all">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </div>
            </div>
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-1">
                    <h1 class="text-2xl font-black text-slate-800 tracking-tight leading-none uppercase"><%= customer.name %></h1>
                    <span class="px-2.5 py-0.5 rounded-full text-[10px] uppercase font-black tracking-widest <%= customer.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                        <%= customer.status === 'active' ? '● Aktif' : '● Terisolir' %>
                    </span>
                </div>
                <div class="flex items-center gap-4 text-slate-400">
                    <div class="flex items-center gap-1.5 font-bold tracking-tight text-xs">
                        <span class="bg-slate-100 px-2 py-0.5 rounded-md"><%= customer.customer_code || '-' %></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-3 w-full md:w-auto">
            <a href="/customers/list"
                class="flex-1 md:px-6 py-3 bg-white border border-slate-200 text-slate-500 rounded-2xl hover:bg-slate-50 hover:text-slate-700 transition-all font-bold text-xs uppercase tracking-widest text-center shadow-sm">
                Kembali
            </a>
            <a href="/customers/<%= customer.id %>/edit"
                class="flex-1 md:flex-none md:px-7 py-3 bg-slate-900 icon-white text-white rounded-2xl hover:bg-black shadow-xl shadow-slate-200 transition-all font-bold text-xs uppercase tracking-widest flex items-center justify-center gap-2">
                <i class="fas fa-edit"></i> Edit
            </a>
            <button onclick="deleteCustomer(<%= customer.id %>, '<%= customer.name %>')"
                class="flex-1 md:flex-none md:px-6 py-3 bg-red-50 text-red-600 border border-red-100 rounded-2xl hover:bg-red-600 hover:text-white transition-all font-bold text-xs uppercase tracking-widest flex items-center justify-center gap-2">
                <i class="fas fa-trash-alt"></i> Hapus
            </button>
        </div>
    </nav>

    <!-- Quick Stats Bar -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 px-1">
        <div class="bg-white rounded-3xl border border-slate-100 p-5 shadow-sm hover:shadow-md transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Layanan</p>
            <div class="flex items-center justify-between">
                <p class="text-sm font-black text-slate-800 uppercase"><%= customer.connection_type === 'pppoe' ? 'PPPoE' : 'Static IP' %></p>
                <div class="w-8 h-8 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center">
                    <i class="fas fa-bolt text-xs"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-3xl border border-slate-100 p-5 shadow-sm hover:shadow-md transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Akses</p>
            <div class="flex items-center justify-between">
                <p class="text-xs font-mono font-bold text-slate-800 pr-2 truncate"><%= customer.pppoe_username || customer.static_ip_address || '-' %></p>
                <div class="w-8 h-8 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center">
                    <i class="fas fa-key text-xs"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-3xl border border-slate-100 p-5 shadow-sm hover:shadow-md transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Paket</p>
            <div class="flex items-center justify-between pr-1">
                <% 
                   let quickPkgName = '-';
                   let quickPkgPrice = 0;
                   if (customer.connection_type === 'pppoe') {
                       quickPkgName = customer.pppoe_package_name || '-';
                       quickPkgPrice = customer.pppoe_package_price || 0;
                   } else {
                       quickPkgName = customer.static_ip_package_name || '-';
                       quickPkgPrice = customer.static_ip_package_price || 0;
                   }
                %>
                <div>
                   <p class="text-xs font-black text-slate-800 truncate max-w-[80px]"><%= quickPkgName %></p>
                   <p class="text-[10px] font-bold text-indigo-500">Rp <%= parseFloat(quickPkgPrice).toLocaleString('id-ID') %></p>
                </div>
                <div class="w-8 h-8 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center">
                    <i class="fas fa-box-open text-xs"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-3xl border border-slate-100 p-5 shadow-sm hover:shadow-md transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Signal / Status</p>
            <div class="flex items-center justify-between">
                <% if (typeof deviceDetails !== 'undefined' && deviceDetails) { %>
                    <div>
                        <p class="text-xs font-black <%= parseFloat(deviceDetails.signal.rxPower) < -27 ? 'text-red-600' : 'text-green-600' %>">
                            <%= deviceDetails.signal.rxPower %> dBm
                        </p>
                        <p class="text-[10px] font-bold text-slate-400 uppercase leading-none mt-1"><%= deviceDetails.online ? 'Online' : 'Offline' %></p>
                    </div>
                <% } else { %>
                    <p class="text-xs font-black text-slate-400">N/A</p>
                <% } %>
                <div class="w-8 h-8 rounded-xl bg-cyan-50 text-cyan-600 flex items-center justify-center font-bold">
                    <i class="fas fa-signal text-xs"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Main Content (Left Column) -->
        <div class="lg:col-span-8 space-y-8">

            <!-- Bandwidth Usage Card -->
            <div class="rounded-[2.5rem] border border-slate-200 bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md">
                <div class="px-8 py-6 bg-slate-50/50 border-b border-slate-100 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-2xl bg-blue-600 text-white flex items-center justify-center shadow-lg shadow-blue-100">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z">
                                </path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-black text-slate-800 text-sm uppercase tracking-tight">Traffic Usage</h3>
                            <p class="text-[10px] font-bold text-slate-400">Monitoring 12 Jam Terakhir</p>
                        </div>
                    </div>
                    <button id="refreshTrafficBtn" onclick="loadBandwidthData()"
                        class="px-4 py-2 bg-white border border-slate-200 text-blue-600 rounded-xl hover:bg-blue-50 font-black text-[10px] uppercase tracking-widest transition-all shadow-sm">
                        🔄 Refresh
                    </button>
                </div>
                <div class="p-8">
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-8">
                        <div class="space-y-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Avg Download</p>
                            <p class="text-2xl font-black text-blue-600"><span id="avgDownload">0</span> <span class="text-xs font-normal text-slate-400 ml-0.5">Mbps</span></p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Avg Upload</p>
                            <p class="text-2xl font-black text-green-600"><span id="avgUpload">0</span> <span class="text-xs font-normal text-slate-400 ml-0.5">Mbps</span></p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Total DL</p>
                            <p class="text-xl font-black text-slate-800" id="totalDownload">0 B</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Total UL</p>
                            <p class="text-xl font-black text-slate-800" id="totalUpload">0 B</p>
                        </div>
                    </div>
                    <div class="relative h-[300px] w-full">
                        <canvas id="usageChart"></canvas>
                        <div id="usageLoader"
                            class="absolute inset-0 flex items-center justify-center bg-white/80 backdrop-blur-sm rounded-xl z-10 transition-opacity duration-300">
                            <div class="flex flex-col items-center">
                                <div class="w-10 h-10 border-4 border-blue-50 border-t-blue-600 rounded-full animate-spin mb-4"></div>
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest animate-pulse">Sinkronisasi Data...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Connection & Specs -->
            <div class="grid <%= (typeof deviceDetails !== 'undefined' && deviceDetails) ? 'grid-cols-1 md:grid-cols-2' : 'grid-cols-1' %> gap-8">
                <!-- Connectivity Details -->
                <div class="rounded-[2.5rem] border border-slate-200 bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md">
                    <div class="px-8 py-5 bg-slate-50/50 border-b border-slate-100 flex items-center gap-4">
                        <div class="w-9 h-9 rounded-2xl bg-purple-100 text-purple-600 flex items-center justify-center">
                            <i class="fas fa-network-wired text-sm"></i>
                        </div>
                        <h3 class="font-black text-slate-800 text-xs uppercase tracking-widest">Detail Konektivitas</h3>
                    </div>
                    <div class="p-8 space-y-4">
                        <div class="flex justify-between items-center pb-3 border-b border-slate-50">
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Metode</span>
                            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= customer.connection_type === 'pppoe' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
                                <%= customer.connection_type==='pppoe' ? 'PPPoE' : 'Static IP' %>
                            </span>
                        </div>
						<% if (customer.connection_type==='pppoe' ) { %>
                            <div class="flex justify-between items-center pb-3 border-b border-slate-50">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Username</span>
                                <span class="font-black text-slate-800 font-mono text-xs"><%= customer.pppoe_username || '-' %></span>
                            </div>
                            <div class="flex justify-between items-center pb-3 border-b border-slate-50">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Password</span>
                                <div class="flex items-center gap-2">
                                    <span class="font-bold text-slate-500 font-mono text-xs password-masked">••••••</span>
                                    <span class="font-black text-slate-800 font-mono text-xs password-text hidden"><%= customer.pppoe_password || '12345' %></span>
                                    <button onclick="togglePassword(this)" class="text-slate-300 hover:text-blue-500 transition-colors">
                                        <i class="fas fa-eye text-[10px]"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Profile</span>
                                <span class="font-black text-slate-800 text-xs"><%= customer.pppoe_profile_id || '-' %></span>
                            </div>
<% } else { %>
                            <div class="flex justify-between items-center pb-3 border-b border-slate-50">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">IP Address</span>
                                <span class="font-black text-slate-800 font-mono text-xs"><%= customer.static_ip_address || '-' %></span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Interface</span>
                                <span class="font-black text-slate-800 font-mono text-xs"><%= customer.static_ip_interface || '-' %></span>
                            </div>
<% } %>
                        <div class="pt-2">
                             <div class="flex justify-between items-center">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Detail Paket</span>
                                <div class="text-right">
                                    <div class="font-black text-slate-800 text-sm"><%= (customer.connection_type === 'pppoe' ? customer.pppoe_package_name : customer.static_ip_package_name) || '-' %></div>
                                    <div class="text-[10px] text-indigo-500 font-black uppercase tracking-tight">
                                        Rp <%= parseFloat(customer.connection_type === 'pppoe' ? customer.pppoe_package_price : customer.static_ip_package_price || 0).toLocaleString('id-ID') %>
                                    </div>
                                </div>
                             </div>
                        </div>
                    </div>
                </div>

                <!-- Device Status (GenieACS) -->
                <% if (typeof deviceDetails !=='undefined' && deviceDetails) { %>
                    <div class="rounded-[2.5rem] border border-slate-200 bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md">
                        <div class="px-8 py-5 bg-slate-50/50 border-b border-slate-100 flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-9 h-9 rounded-2xl bg-cyan-100 text-cyan-600 flex items-center justify-center">
                                    <i class="fas fa-microchip text-sm"></i>
                                </div>
                                <h3 class="font-black text-slate-800 text-xs uppercase tracking-widest">Status ONT</h3>
                            </div>
                            <div class="flex items-center gap-2 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest <%= deviceDetails.online ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                                <div class="w-1.5 h-1.5 rounded-full <%= deviceDetails.online ? 'bg-green-500 animate-pulse' : 'bg-red-500' %>"></div>
                                <%= deviceDetails.online ? 'Online' : 'Offline' %>
                            </div>
                        </div>
                        <div class="p-8 space-y-6">
                            <div class="grid grid-cols-2 gap-4">
                                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 text-center">
                                    <span class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Signal</span>
                                    <span class="font-black text-lg <%= parseFloat(deviceDetails.signal.rxPower) < -27 ? 'text-red-500' : 'text-slate-800' %>">
                                        <%= deviceDetails.signal.rxPower %> <small class="text-[10px] text-slate-400">dBm</small>
                                    </span>
                                </div>
                                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 text-center">
                                    <span class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Temp</span>
                                    <span class="font-black text-lg text-slate-800">
                                        <%= deviceDetails.signal.temperature %> <small class="text-[10px] text-slate-400">°C</small>
                                    </span>
                                </div>
                            </div>

                            <div class="bg-indigo-50/30 p-4 rounded-2xl border border-indigo-100/50 flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <i class="fas fa-wifi text-indigo-500"></i>
                                    <span class="text-[10px] font-black text-indigo-900 uppercase tracking-widest">WiFi Clients</span>
                                </div>
                                <span class="font-black text-indigo-600 text-sm"><%= deviceDetails.signal.wifiClients %> Perangkat</span>
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                <button onclick="refreshONT('<%= deviceDetails.id %>')"
                                    class="py-3 bg-white border border-slate-200 text-slate-600 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                                    <i class="fas fa-sync-alt"></i> Refresh
                                </button>
                                <button onclick="rebootONT('<%= deviceDetails.id %>')"
                                    class="py-3 bg-red-50 text-red-600 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-red-600 hover:text-white transition-all flex items-center justify-center gap-2">
                                    <i class="fas fa-power-off"></i> Reboot
                                </button>
                            </div>
                        </div>
                    </div>
<% } %>
            </div>

            <!-- History Tabs Section -->
            <div class="rounded-[2.5rem] border border-slate-200 bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md">
                <div class="border-b border-slate-100 bg-slate-50/30 px-4 pt-4">
                    <div class="flex flex-wrap -mb-px">
                        <button onclick="switchTab('invoices')" id="tab-btn-invoices" 
                            class="tab-btn active px-6 py-4 text-xs font-black uppercase tracking-widest border-b-2 border-blue-600 text-blue-600 transition-all flex items-center gap-2">
                             <i class="fas fa-file-invoice-dollar"></i> Tagihan
                        </button>
                        <button onclick="switchTab('jobs')" id="tab-btn-jobs" 
                            class="tab-btn px-6 py-4 text-xs font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all flex items-center gap-2">
                             <i class="fas fa-tools"></i> Teknisi
                        </button>
                        <button onclick="switchTab('compensations')" id="tab-btn-compensations" 
                            class="tab-btn px-6 py-4 text-xs font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all flex items-center gap-2">
                             <i class="fas fa-hand-holding-usd"></i> Kompensasi
                        </button>
                    </div>
                </div>

                <div class="p-0">
                    <!-- Invoices Tab -->
                    <div id="tab-content-invoices" class="tab-content">
                        <% if (typeof invoices !== 'undefined' && invoices && invoices.length > 0) { %>
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-left">
                                    <thead class="bg-slate-50/50 text-slate-400 font-black uppercase text-[10px] tracking-widest">
                                        <tr>
                                            <th class="px-8 py-4">Invoice</th>
                                            <th class="px-8 py-4">Periode</th>
                                            <th class="px-8 py-4 text-right">Total</th>
                                            <th class="px-8 py-4 text-center">Status</th>
                                            <th class="px-8 py-4">Tanggal</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-50">
                                        <% invoices.forEach(invoice => { %>
                                            <tr class="hover:bg-slate-50/30 transition-colors">
                                                <td class="px-8 py-5 font-mono font-bold text-slate-800">#<%= invoice.invoice_number %></td>
                                                <td class="px-8 py-5 text-slate-600 font-medium"><%= invoice.period %></td>
                                                <td class="px-8 py-5 text-right font-black text-slate-900 font-mono">
                                                    Rp <%= parseFloat(invoice.total_amount).toLocaleString('id-ID') %>
                                                </td>
                                                <td class="px-8 py-5 text-center">
                                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest
                                                        <%= invoice.status === 'paid' ? 'bg-green-100 text-green-700' : 
                                                           invoice.status === 'overdue' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
                                                        <%= invoice.status %>
                                                    </span>
                                                </td>
                                                <td class="px-8 py-5 text-slate-400 text-[10px] font-bold">
                                                    <%= new Date(invoice.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="p-12 text-center">
                                <div class="w-16 h-16 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <i class="fas fa-file-invoice text-2xl"></i>
                                </div>
                                <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Belum Ada Tagihan</p>
                            </div>
                        <% } %>
                    </div>

                    <!-- Jobs Tab -->
                    <div id="tab-content-jobs" class="tab-content hidden">
                        <% if (typeof technicianJobs !== 'undefined' && technicianJobs && technicianJobs.length > 0) { %>
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-left">
                                    <thead class="bg-slate-50/50 text-slate-400 font-black uppercase text-[10px] tracking-widest">
                                        <tr>
                                            <th class="px-8 py-4">Pekerjaan</th>
                                            <th class="px-8 py-4">Teknisi</th>
                                            <th class="px-8 py-4 text-center">Status</th>
                                            <th class="px-8 py-4">Proof</th>
                                            <th class="px-8 py-4">Tanggal</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-50">
                                        <% technicianJobs.forEach(job => { %>
                                            <tr class="hover:bg-slate-50/30 transition-colors">
                                                <td class="px-8 py-5">
                                                    <p class="font-bold text-slate-800"><%= job.title %></p>
                                                    <% if (job.job_type) { %>
                                                        <span class="text-[9px] text-slate-400 uppercase font-black tracking-tight"><%= job.job_type %></span>
                                                    <% } %>
                                                </td>
                                                <td class="px-8 py-5 text-slate-600 font-semibold"><%= job.technician_name || '-' %></td>
                                                <td class="px-8 py-5 text-center">
                                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest
                                                        <%= job.status === 'completed' ? 'bg-green-100 text-green-700' : 
                                                           job.status === 'pending' ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-700' %>">
                                                        <%= job.status === 'completed' ? 'Selesai' : job.status %>
                                                    </span>
                                                </td>
                                                <td class="px-8 py-5">
                                                    <% if (job.completion_proof) { %>
                                                        <a href="<%= job.completion_proof %>" target="_blank"
                                                            class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all">
                                                            <i class="fas fa-camera text-xs"></i>
                                                        </a>
                                                    <% } else { %>
                                                        <span class="text-slate-300">-</span>
                                                    <% } %>
                                                </td>
                                                <td class="px-8 py-5 text-slate-400 text-[10px] font-bold font-mono">
                                                    <%= new Date(job.created_at).toLocaleDateString('id-ID') %>
                                                </td>
