<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Billing Kasir
    </title>
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/assets/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#f0f9ff',
                            100: '#e0f2fe',
                            200: '#bae6fd',
                            300: '#7dd3fc',
                            400: '#38bdf8',
                            500: '#0ea5e9',
                            600: '#0284c7',
                            700: '#0369a1',
                            800: '#075985',
                            900: '#0c4a6e',
                        },
                        premium: {
                            dark: '#0f172a',
                            sidebar: '#1e293b',
                            accent: '#6366f1'
                        }
                    }
                }
            }
        }
    </script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .glass-sidebar {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .premium-gradient {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        }

        .sidebar-item {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .sidebar-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0;
            background: #6366f1;
            transition: width 0.3s ease;
            z-index: -1;
        }

        .sidebar-item.active {
            background: rgba(99, 102, 241, 0.1);
            color: #818cf8;
            border-left: 4px solid #6366f1;
        }

        .sidebar-item:hover:not(.active) {
            background: rgba(255, 255, 255, 0.03);
            transform: translateX(4px);
        }

        .main-content {
            background-color: #f8fafc;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        .top-nav-glass {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
        }

        .btn-premium {
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .btn-premium:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>

<body class="bg-gray-50 text-slate-800">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="glass-sidebar w-72 flex-shrink-0 text-slate-300 flex flex-col z-50">
            <!-- Brand -->
            <div class="p-8 flex items-center gap-4">
                <div class="w-12 h-12 premium-gradient rounded-xl flex items-center justify-center shadow-lg shadow-indigo-500/20">
                    <i class="fas fa-cash-register text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="font-display font-black text-white text-xl tracking-tight leading-none">BILLING</h1>
                    <p class="text-[10px] font-bold text-indigo-400 tracking-[0.2em] uppercase mt-1">Cashier Portal</p>
                </div>
            </div>

            <!-- User Status Card -->
            <div class="px-6 mb-8">
                <div class="bg-slate-800/50 border border-slate-700/50 p-4 rounded-2xl flex items-center gap-4">
                    <div class="relative">
                        <div class="w-12 h-12 bg-indigo-500/20 rounded-full flex items-center justify-center border border-indigo-500/30">
                            <i class="fas fa-user-tie text-indigo-400"></i>
                        </div>
                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 border-2 border-slate-800 rounded-full"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-white font-bold text-sm truncate">
                            <%= (typeof user !=='undefined' && user) ? user.full_name : 'Kasir' %>
                        </p>
                        <p class="text-[10px] text-slate-400 font-medium font-mono">ONLINE</p>
                    </div>
                </div>
            </div>

            <!-- Navigation Scroll Area -->
            <nav class="flex-1 overflow-y-auto px-4 space-y-1 py-4">
                <p class="px-4 text-[10px] font-black tracking-widest text-slate-500 uppercase mb-4">Core Menu</p>
                
                <a href="/kasir/dashboard" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm <%= currentPath === '/kasir/dashboard' ? 'active' : 'hover:bg-slate-800/50' %>">
                    <i class="fas fa-shapes w-5"></i>
                    Dashboard
                </a>
                
                <a href="/kasir/payments" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm <%= currentPath === '/kasir/payments' ? 'active' : 'hover:bg-slate-800/50' %>">
                    <i class="fas fa-rocket w-5"></i>
                    Proses Pembayaran
                </a>
                
                <a href="/kasir/transactions" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm <%= currentPath === '/kasir/transactions' ? 'active' : 'hover:bg-slate-800/50' %>">
                    <i class="fas fa-receipt w-5"></i>
                    Riwayat Transaksi
                </a>

                <a href="/kasir/debt" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm <%= currentPath === '/kasir/debt' ? 'active' : 'hover:bg-slate-800/50' %>">
                    <i class="fas fa-hand-holding-dollar w-5"></i>
                    Daftar Hutang
                </a>

                <p class="px-4 text-[10px] font-black tracking-widest text-slate-500 uppercase mt-8 mb-4">Management</p>

                <a href="/kasir/print-group" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm <%= currentPath === '/kasir/print-group' ? 'active' : 'hover:bg-slate-800/50' %>">
                    <i class="fas fa-layer-group w-5"></i>
                    Print Kelompok
                </a>

                <a href="/kasir/reports" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm <%= currentPath === '/kasir/reports' ? 'active' : 'hover:bg-slate-800/50' %>">
                    <i class="fas fa-chart-line w-5"></i>
                    Laporan Kasir
                </a>

                <a href="/kasir/payment-records/export" class="sidebar-item flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-sm hover:bg-slate-800/50">
                    <i class="fas fa-file-export w-5 text-indigo-400"></i>
                    Export Data
                </a>
            </nav>

            <!-- Bottom Actions -->
            <div class="p-4 mt-auto border-t border-slate-800/50 bg-slate-900/50 backdrop-blur">
                <a href="/kasir/logout" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-bold text-sm text-rose-400 hover:bg-rose-500/10 transition-all">
                    <i class="fas fa-power-off w-5"></i>
                    Sign Out
                </a>
            </div>
        </aside>

        <!-- Main Workspace -->
        <div class="flex-1 flex flex-col min-w-0">
            <!-- Top Navigation Bar -->
            <header class="top-nav-glass h-20 flex items-center justify-between px-10 flex-shrink-0 z-40">
                <div class="flex flex-col">
                    <h2 class="font-display font-extrabold text-xl text-slate-900 leading-none">
                        <%= title %>
                    </h2>
                    <p class="text-xs font-semibold text-slate-400 mt-1 uppercase tracking-wider">
                        Session Active &bull; <span id="currentDate"></span>
                    </p>
                </div>

                <div class="flex items-center gap-8">
                    <div class="flex flex-col items-end">
                        <div class="flex items-center gap-2 text-indigo-600 font-mono font-bold text-lg leading-none" id="currentTime">
                            00:00:00
                        </div>
                    </div>
                    
                    <div class="h-10 w-px bg-slate-200"></div>

                    <button class="w-11 h-11 bg-white border border-slate-200 rounded-full flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm">
                        <i class="fas fa-bell"></i>
                    </button>
                </div>
            </header>

            <!-- Content Container -->
            <main class="flex-1 overflow-y-auto main-content p-8">
                <!-- Inner Container for max width scaling -->
                <div class="max-w-[1600px] mx-auto">
                    <!-- Flash Feedback Messages -->
                    <% if (typeof flash !=='undefined' && flash.error && flash.error.length> 0) { %>
                        <div class="mb-8 p-4 bg-rose-50 border-l-4 border-rose-500 text-rose-800 rounded-xl shadow-sm flex items-center gap-4 animate-[slideIn_0.3s_ease-out]">
                            <div class="w-10 h-10 bg-rose-100 rounded-full flex items-center justify-center flex-shrink-0 text-rose-600">
                                <i class="fas fa-circle-exclamation"></i>
                            </div>
                            <p class="font-semibold text-sm tracking-tight"><%= flash.error[0] %></p>
                        </div>
                    <% } %>

                    <% if (typeof flash !=='undefined' && flash.success && flash.success.length> 0) { %>
                        <div class="mb-8 p-4 bg-emerald-50 border-l-4 border-emerald-500 text-emerald-800 rounded-xl shadow-sm flex items-center gap-4 animate-[slideIn_0.3s_ease-out]">
                            <div class="w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center flex-shrink-0 text-emerald-600">
                                <i class="fas fa-circle-check"></i>
                            </div>
                            <p class="font-semibold text-sm tracking-tight"><%= flash.success[0] %></p>
                        </div>
                    <% } %>

                    <!-- Actual Page Body -->
                    <div class="fade-in">
                        <%- body %>
                    </div>
                </div>
                
                <!-- Footer Info -->
                <footer class="mt-20 py-8 border-t border-slate-200 flex items-center justify-between text-[11px] font-bold text-slate-400 tracking-widest uppercase">
                    <div>© 2026 PRO INTERNET NETWORK &bull; ALL RIGHTS RESERVED</div>
                    <div>BUILD VERSION 2.4.16.REFINED</div>
                </footer>
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // Real-time Clock
        function updateTimeline() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('id-ID', { hour12: false });
            const dateString = now.toLocaleDateString('id-ID', { 
                weekday: 'long', 
                day: 'numeric', 
                month: 'long', 
                year: 'numeric' 
            });
            
            const timeEl = document.getElementById('currentTime');
            if(timeEl) timeEl.innerText = timeString;
            
            const dateEl = document.getElementById('currentDate');
            if(dateEl) dateEl.innerText = dateString;
        }
        setInterval(updateTimeline, 1000);
        updateTimeline();

        // Smooth Fade-in effect via CSS
        document.addEventListener('DOMContentLoaded', () => {
            const mainBody = document.querySelector('.fade-in');
            if(mainBody) {
                mainBody.style.opacity = '1';
                mainBody.style.transform = 'translateY(0)';
            }
        });
    </script>
    
    <style>
        .fade-in {
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        @keyframes slideIn {
            from { transform: translateX(-10px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</body>
</html>