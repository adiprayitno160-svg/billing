<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Print Thermal <%= invoice.invoice_number %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #fff;
            color: #000;
            width: 48mm;
            padding: 2mm 4mm 4mm 2mm;
            font-family: 'Tahoma', 'Segoe UI', Arial, sans-serif !important;
            font-size: 9px !important;
            line-height: 1.2;
            font-weight: 600;
        }
        .header { text-align: center; margin-bottom: 1.5mm; }
        .company-name { font-size: 11px !important; font-weight: bold; text-transform: uppercase; margin-bottom: 1px; }
        .sep { border-top: 1px dashed black; height: 1px; margin: 1mm 0; clear: both; }
        .sep-bold { border-top: 1px solid black; height: 1px; margin: 1mm 0; clear: both; }
        .row { clear: both; overflow: hidden; margin-bottom: 0.8mm; width: 100%; }
        .lbl { float: left; width: 35%; text-align: left; }
        .val { float: right; width: 63%; text-align: right; word-break: break-word; }
        .total-row {
            font-size: 10px !important;
            font-weight: bold;
            padding-top: 1.5mm;
            margin-top: 1mm;
            border-top: 1px solid black;
            clear: both;
            overflow: hidden;
        }
        .paid-badge {
            text-align: center; border: 1.5px solid #000; padding: 2px; margin: 2mm 0; font-weight: 900; font-size: 10pt; text-transform: uppercase;
        }
        @media print {
            body { width: 48mm; padding-right: 4mm; }
        }
    </style>
</head>
<body onload="window.print()">
    <div class="header">
        <div class="company-name"><%= typeof companyInfo !== 'undefined' ? (companyInfo.company_name || 'ID.NET BY DBN') : 'ID.NET BY DBN' %></div>
        <div style="font-size: 8px;">LAYANAN INTERNET BROADBAND</div>
    </div>

    <div class="sep-bold"></div>

    <div class="row">
        <div class="lbl" style="width: 30%; font-size: 8px;"><%= new Date(invoice.created_at).toLocaleDateString('id-ID') %></div>
        <div class="val" style="width: 68%; font-size: 8px;"><%= invoice.invoice_number %></div>
    </div>

    <div class="sep"></div>

    <div class="row"><div class="lbl">Pelanggan:</div><div class="val"><%= invoice.customer_name %></div></div>
    
    <div class="sep"></div>

    <% items.forEach(item => { %>
        <div class="row">
            <div class="lbl" style="width: 55%; font-size: 8px;"><%= item.description %></div>
            <div class="val" style="width: 43%; font-size: 9px;">Rp <%= new Intl.NumberFormat('id-ID').format(item.total_price) %></div>
        </div>
    <% }); %>

    <% if (invoice.discount_amount > 0) { %>
        <div class="row">
            <div class="lbl">DISKON</div>
            <div class="val">- Rp <%= new Intl.NumberFormat('id-ID').format(invoice.discount_amount) %></div>
        </div>
    <% } %>

    <% if (invoice.total_balance > invoice.total_amount) { 
        const tunggakan = invoice.total_balance - invoice.total_amount;
    %>
        <div class="row">
            <div class="lbl">TUNGGAKAN</div>
            <div class="val">Rp <%= new Intl.NumberFormat('id-ID').format(tunggakan) %></div>
        </div>
    <% } %>

    <div class="total-row">
        <div class="lbl">TOTAL BAYAR</div>
        <div class="val">Rp <%= new Intl.NumberFormat('id-ID').format(invoice.total_balance || (invoice.total_amount - (invoice.discount_amount||0))) %></div>
    </div>

    <div class="sep"></div>
    
    <% if (invoice.status === 'paid') { %>
        <div class="paid-badge">LUNAS</div>
    <% } %>
    
    <div style="text-align:center; font-size: 7px; margin-top: 5px; font-weight: normal;">
        Terima kasih atas pembayaran Anda.
    </div>
</body>
</html>
