<%- contentFor('body') %>

<div class="p-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Rekap Tunggakan Pelanggan</h1>
            <p class="text-gray-600 mt-1">Daftar pelanggan yang memiliki tagihan belum lunas (akumulasi beberapa bulan).</p>
        </div>
        <div class="flex gap-2">
            <button onclick="window.print()" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center">
                <i class="fas fa-print mr-2"></i> Print Rekap
            </button>
        </div>
    </div>

    <!-- Filter Card -->
    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-200 mb-6 print:hidden">
        <form method="GET" action="/billing/rekap/tunggakan" class="flex flex-col md:flex-row gap-4 items-end">
            <div class="flex-1 w-full">
                <label class="block text-sm font-medium text-gray-700 mb-1">Cari Pelanggan</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-search text-gray-400"></i>
                    </div>
                    <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>"
                        placeholder="Nama atau ID Pelanggan..."
                        class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all">
                </div>
            </div>
            <div class="flex gap-2 w-full md:w-auto">
                <button type="submit" class="flex-1 md:flex-none bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition-colors">
                    Filter
                </button>
                <a href="/billing/rekap/tunggakan" class="flex-1 md:flex-none bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium transition-colors text-center">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200">
                        <th class="py-3 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">No</th>
                        <th class="py-3 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">Pelanggan</th>
                        <th class="py-3 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider text-center">Bulan Menunggak</th>
                        <th class="py-3 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">Periode Tagihan</th>
                        <th class="py-3 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider text-right">Total Tunggakan</th>
                        <th class="py-3 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider text-center print:hidden">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <% if (arrears && arrears.length > 0) { %>
                        <% 
                        let grandTotal = 0;
                        arrears.forEach((item, index) => { 
                            grandTotal += Number(item.total_arrears);
                            // Highlight customers with >= 3 months of arrears
                            const isHighRisk = item.unpaid_months_count >= 3;
                        %>
                        <tr class="hover:bg-gray-50 transition-colors <%= isHighRisk ? 'bg-red-50/30' : '' %>">
                            <td class="py-3 px-4 text-sm text-gray-600"><%= index + 1 %></td>
                            <td class="py-3 px-4">
                                <div class="font-medium text-gray-900"><%= item.name %></div>
                                <div class="text-xs text-gray-500"><%= item.customer_code || '-' %> | <%= item.phone || '-' %></div>
                            </td>
                            <td class="py-3 px-4 text-center">
                                <span class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-xs font-bold <%= isHighRisk ? 'bg-red-100 text-red-700' : 'bg-orange-100 text-orange-700' %>">
                                    <%= item.unpaid_months_count %> Bulan
                                </span>
                            </td>
                            <td class="py-3 px-4">
                                <div class="text-sm text-gray-700 max-w-xs flex flex-wrap gap-1">
                                    <% 
                                    const periods = item.unpaid_periods ? item.unpaid_periods.split(',') : [];
                                    periods.forEach(p => { 
                                    %>
                                        <span class="inline-block bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded border border-gray-200">
                                            <%= p %>
                                        </span>
                                    <% }); %>
                                </div>
                            </td>
                            <td class="py-3 px-4 text-right">
                                <div class="text-sm font-bold text-red-600">
                                    Rp <%= new Intl.NumberFormat('id-ID').format(item.total_arrears) %>
                                </div>
                            </td>
                            <td class="py-3 px-4 text-center print:hidden">
                                <a href="/billing/tagihan?search=<%= item.customer_code || item.name %>&status=unpaid" class="inline-flex items-center justify-center bg-blue-100 text-blue-700 hover:bg-blue-600 hover:text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors" title="Lihat & Bayar Tagihan">
                                    Detail <i class="fas fa-arrow-right ml-1 text-xs"></i>
                                </a>
                            </td>
                        </tr>
                        <% }); %>
                        
                        <!-- Grand Total Row -->
                        <tr class="bg-gray-100 font-bold border-t-2 border-gray-300">
                            <td colspan="4" class="py-4 px-4 text-right text-gray-800 uppercase text-sm">TOTAL KESELURUHAN TUNGGAKAN:</td>
                            <td class="py-4 px-4 text-right text-red-700 text-base">
                                Rp <%= new Intl.NumberFormat('id-ID').format(grandTotal) %>
                            </td>
                            <td class="print:hidden"></td>
                        </tr>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="py-12 px-4 text-center text-gray-500">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fas fa-check-circle text-4xl text-green-400 mb-3"></i>
                                    <p class="text-lg font-medium text-gray-900">Bagus!</p>
                                    <p class="text-sm">Tidak ada pelanggan yang menunggak saat ini.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    @media print {
        @page { size: landscape; margin: 1cm; }
        body { background: white !important; }
        .print\:hidden { display: none !important; }
        .shadow-sm { box-shadow: none !important; }
        .border { border-color: #ddd !important; }
    }
</style>
