<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>REKAP HUTANG PELANGGAN - <%= new Date().toLocaleDateString('id-ID') %></title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 10pt; color: #333; margin: 20mm 15mm; }
        .header { text-align: center; margin-bottom: 20px; border-bottom: 3px double #333; padding-bottom: 10px; }
        .header h1 { margin: 0; font-size: 18pt; text-transform: uppercase; }
        .header p { margin: 5px 0 0; font-size: 10pt; color: #666; font-weight: bold; }
        .summary { display: flex; justify-content: space-between; margin-bottom: 15px; padding: 10px; background: #f9f9f9; border: 1px solid #ddd; border-radius: 5px; }
        .summary-item { text-align: center; }
        .summary-item .label { font-size: 8pt; text-transform: uppercase; color: #888; }
        .summary-item .value { font-size: 14pt; font-weight: bold; color: #c0392b; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { background: #f2f2f2; color: #000; font-weight: bold; text-transform: uppercase; font-size: 9pt; border: 1px solid #ccc; padding: 8px; }
        td { border: 1px solid #ccc; padding: 8px; vertical-align: top; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .font-bold { font-weight: bold; }
        .text-red { color: #c0392b; }
        .text-orange { color: #e67e22; }
        .footer { margin-top: 30px; text-align: right; font-size: 9pt; }
        .badge { font-family: 'Courier New', monospace; font-size: 8pt; padding: 2px 5px; border-radius: 4px; }
        .badge-danger { background: #fce4e4; color: #c0392b; }
        .badge-warning { background: #fef3cd; color: #856404; }
        @media print {
            .no-print { display: none; }
            body { margin: 0; padding: 10mm; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="margin-bottom: 20px; text-align: center;">
        <button onclick="window.print()" style="padding: 10px 20px; background: #c0392b; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold;">PRINT REKAP HUTANG</button>
        <button onclick="window.close()" style="padding: 10px 20px; background: #ccc; color: #333; border: none; border-radius: 5px; cursor: pointer; margin-left: 10px;">TUTUP</button>
    </div>

    <div class="header">
        <h1>REKAP PELACAKAN HUTANG PELANGGAN</h1>
        <p>TANGGAL REKAP: <%= new Date().toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
    </div>

    <div class="summary">
        <div class="summary-item">
            <div class="label">Total Hutang</div>
            <div class="value">Rp <%= new Intl.NumberFormat('id-ID').format(summary?.total_debt || 0) %></div>
        </div>
        <div class="summary-item">
            <div class="label">Pelanggan Menunggak</div>
            <div class="value" style="color: #e67e22;"><%= summary?.customers_count || 0 %></div>
        </div>
        <div class="summary-item">
            <div class="label">Hutang > 30 Hari</div>
            <div class="value"><%= summary?.overdue_count || 0 %></div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th width="30">NO</th>
                <th>PELANGGAN</th>
                <th width="100">TELEPON</th>
                <th width="120">NO. TAGIHAN</th>
                <th width="100">JUMLAH HUTANG</th>
                <th width="80">UMUR (HARI)</th>
                <th width="80">STATUS</th>
            </tr>
        </thead>
        <tbody>
            <% 
                let grandTotal = 0;
                if (debts && debts.length > 0) { 
                    debts.forEach((debt, index) => { 
                        grandTotal += parseFloat(debt.debt_amount || 0);
                        const daysOld = debt.days_overdue || Math.floor((new Date() - new Date(debt.created_at)) / (1000 * 60 * 60 * 24));
            %>
                <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td>
                        <strong><%= debt.customer_name %></strong>
                        <br><span style="font-size: 8pt; color: #888;"><%= debt.customer_code || '-' %></span>
                    </td>
                    <td class="text-center"><%= debt.customer_phone || '-' %></td>
                    <td class="text-center"><%= debt.invoice_number %></td>
                    <td class="text-right font-bold text-red">Rp <%= new Intl.NumberFormat('id-ID').format(debt.debt_amount) %></td>
                    <td class="text-center">
                        <span class="badge <%= daysOld > 30 ? 'badge-danger' : 'badge-warning' %>">
                            <%= daysOld %> hari
                        </span>
                    </td>
                    <td class="text-center">
                        <span class="badge <%= debt.status === 'resolved' ? '' : 'badge-danger' %>">
                            <%= debt.status === 'resolved' ? 'LUNAS' : 'BELUM LUNAS' %>
                        </span>
                    </td>
                </tr>
            <% 
                    }); 
                } else { 
            %>
                <tr><td colspan="7" class="text-center" style="padding: 30px;">Tidak ada hutang aktif</td></tr>
            <% } %>
        </tbody>
        <tfoot>
            <tr style="background: #f9f9f9;">
                <td colspan="4" class="text-right font-bold">TOTAL KESELURUHAN HUTANG:</td>
                <td class="text-right font-bold text-red" style="font-size: 11pt; border-left: 2px solid #333;">Rp <%= new Intl.NumberFormat('id-ID').format(grandTotal) %></td>
                <td colspan="2"></td>
            </tr>
        </tfoot>
    </table>

    <div class="footer">
        <p>Dicetak oleh Sistem Billing pada <%= new Date().toLocaleString('id-ID') %></p>
        <div style="margin-top: 50px;">
            <p>( __________________________ )</p>
            <p>Admin / Kasir</p>
        </div>
    </div>
</body>
</html>
