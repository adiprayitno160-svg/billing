<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice <%= invoice.invoice_number %> - <%= companyInfo.company_name %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary: #0f172a;
            --accent: #2563eb;
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-500: #64748b;
            --slate-900: #0f172a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: #cbd5e1;
            color: var(--primary);
            -webkit-print-color-adjust: exact;
        }

        /* Canvas */
        .page-a4 {
            background: white;
            width: 210mm;
            min-height: 297mm;
            padding: 15mm;
            margin: 0 auto;
            position: relative;
            box-shadow: 0 0 50px rgba(0,0,0,0.1);
            display: none; /* Controlled by body class */
        }

        .invoice-wrapper {
            border: 1px solid var(--slate-200);
            height: 100%;
            padding: 10mm;
            display: flex;
            flex-direction: column;
        }

        /* Top Bar */
        .top-stripe {
            height: 8px;
            background: var(--accent);
            margin: -10mm -10mm 10mm -10mm;
        }

        /* Header */
        .header-main {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .logo-box h1 {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 28px;
            color: var(--primary);
            letter-spacing: -1px;
        }
        .logo-box p { font-size: 10px; color: var(--slate-500); font-weight: 500; }

        .invoice-meta { text-align: right; }
        .invoice-meta h2 {
            font-family: 'Outfit', sans-serif;
            font-size: 36px;
            font-weight: 900;
            color: var(--slate-100);
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: -10px;
        }
        .invoice-meta .number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 14px;
            font-weight: 700;
            color: var(--primary);
            background: var(--slate-100);
            padding: 4px 12px;
            border-radius: 4px;
            display: inline-block;
        }

        /* Client & Info Grid */
        .main-grid {
            display: grid;
            grid-template-cols: 1fr 1fr;
            gap: 50px;
            margin-bottom: 50px;
            padding-bottom: 30px;
            border-bottom: 1px solid var(--slate-100);
        }

        .label-caps {
            font-size: 10px;
            font-weight: 800;
            color: var(--slate-400);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 12px;
            display: block;
        }

        .client-name {
            font-family: 'Outfit', sans-serif;
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--primary);
        }
        .client-info p { font-size: 13px; color: var(--slate-500); margin-bottom: 4px; }
        .client-info strong { color: var(--primary); }

        .info-list { display: grid; grid-template-cols: 1fr 1fr; gap: 15px; }
        .info-item .val { font-size: 13px; font-weight: 700; color: var(--primary); display: block; }
        .info-item .lbl { font-size: 10px; color: var(--slate-400); font-weight: 600; text-transform: uppercase; }

        .status-badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 800;
        }
        .status-badge.paid { background: #dcfce7; color: #166534; }
        .status-badge.unpaid { background: #fff7ed; color: #9a3412; }
        .status-badge.janji_bayar { background: #f0f9ff; color: #0369a1; }

        /* Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 40px;
        }
        .items-table th {
            text-align: left;
            padding: 12px;
            font-size: 11px;
            font-weight: 800;
            color: var(--slate-500);
            border-bottom: 2px solid var(--primary);
            text-transform: uppercase;
        }
        .items-table td {
            padding: 15px 12px;
            border-bottom: 1px solid var(--slate-100);
            font-size: 13px;
        }
        .items-table .total-col { text-align: right; font-weight: 700; }

        /* Calculation */
        .bottom-section {
            display: grid;
            grid-template-cols: 1.5fr 1fr;
            gap: 40px;
            margin-top: auto;
        }

        .payment-box {
            background: var(--slate-50);
            padding: 20px;
            border-radius: 8px;
        }
        .payment-box h4 { font-size: 11px; font-weight: 800; margin-bottom: 15px; }
        .bank-row { display: flex; gap: 15px; margin-bottom: 10px; align-items: center; }
        .bank-logo { font-weight: 900; font-size: 11px; color: var(--accent); min-width: 40px; }
        .bank-details { font-size: 12px; }
        .bank-details strong { font-family: 'JetBrains Mono', monospace; font-size: 13px; }

        .totals-box { text-align: right; }
        .total-item { display: flex; justify-content: flex-end; gap: 20px; margin-bottom: 8px; font-size: 13px; }
        .total-item .val { width: 120px; font-weight: 700; }
        .grand-total {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 2px solid var(--primary);
            display: flex;
            justify-content: flex-end;
            gap: 20px;
            align-items: baseline;
        }
        .grand-total .val { width: 180px; font-size: 26px; font-weight: 900; color: var(--accent); font-family: 'Outfit', sans-serif; }

        /* UI */
        .no-print-bar {
            position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
            background: rgba(15,23,42,0.9); padding: 10px 20px; border-radius: 50px;
            display: flex; gap: 15px; z-index: 9999; backdrop-filter: blur(10px);
        }
        .ui-btn {
            border: none; padding: 8px 16px; border-radius: 20px; cursor: pointer;
            font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 11px;
            color: white; transition: 0.2s; display: flex; align-items: center; gap: 8px;
        }
        .btn-acc { background: var(--accent); }
        .btn-sec { background: var(--slate-500); }
        .btn-green { background: #10b981; }

        /* Thermal Receipt */
        .page-thermal { display: none; width: 58mm; background: white; padding: 10px; font-family: 'Inter', sans-serif; font-size: 10px; }

        @media print {
            .no-print-bar { display: none !important; }
            body { background: white !important; }
            .page-a4 { display: block !important; box-shadow: none !important; margin: 0 !important; width: 100% !important; padding: 0 !important; }
            .invoice-wrapper { border: none !important; }
            @page { margin: 10mm; }
        }

        body.mode-a4 .page-a4 { display: block; }
        body.mode-thermal .page-thermal { display: block; }
    </style>
</head>

<body class="mode-a4">
    <div class="no-print-bar">
        <button onclick="switchMode('a4')" class="ui-btn btn-acc"><i class="fas fa-file-invoice"></i> A4 FULL</button>
        <button onclick="switchMode('thermal')" class="ui-btn btn-sec"><i class="fas fa-receipt"></i> THERMAL</button>
        <button onclick="window.print()" class="ui-btn btn-green"><i class="fas fa-print"></i> CETAK</button>
        <button onclick="window.close()" class="ui-btn" style="background: #ef4444;"><i class="fas fa-times"></i></button>
    </div>

    <div style="padding: 80px 0;">
        <div class="page-a4">
            <div class="invoice-wrapper">
                <div class="top-stripe"></div>
                
                <div class="header-main">
                    <div class="logo-box">
                        <h1><%= (companyInfo.company_name || 'ID.NET').toUpperCase() %></h1>
                        <p><%= companyInfo.company_address %></p>
                        <p>WA: <%= companyInfo.company_phone %> • <%= companyInfo.company_website %></p>
                    </div>
                    <div class="invoice-meta">
                        <h2>INVOICE</h2>
                        <div class="number">REF <%= invoice.invoice_number %></div>
                    </div>
                </div>

                <div class="main-grid">
                    <div class="client-info">
                        <span class="label-caps">DITAGIHKAN KEPADA</span>
                        <div class="client-name"><%= invoice.customer_name %></div>
                        <p><i class="fas fa-map-marker-alt"></i> <%= invoice.customer_address %></p>
                        <p><i class="fas fa-phone"></i> <%= invoice.customer_phone %></p>
                        <p style="margin-top: 10px;">ID PELANGGAN: <strong><%= invoice.customer_code %></strong></p>
                    </div>
                    
                    <div class="details-info">
                        <span class="label-caps">RINGKASAN TAGIHAN</span>
                        <div class="info-list">
                            <div class="info-item">
                                <span class="lbl">Periode</span>
                                <span class="val"><%= invoice.period %></span>
                            </div>
                            <div class="info-item">
                                <span class="lbl">Tgl Terbit</span>
                                <span class="val"><%= new Date(invoice.created_at).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %></span>
                            </div>
                            <div class="info-item">
                                <span class="lbl">Jatuh Tempo</span>
                                <span class="val" style="color: #ef4444;"><%= new Date(invoice.due_date).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %></span>
                            </div>
                            <div class="info-item">
                                <span class="lbl">Status</span>
                                <div>
                                    <% 
                                        let sL = 'BELUM BAYAR'; let sC = 'unpaid';
                                        if (invoice.status === 'paid') { sL = 'LUNAS'; sC = 'paid'; }
                                        else if (invoice.status === 'overdue') { sL = 'TERLAMBAT'; sC = 'unpaid'; }
                                        else if (invoice.status === 'janji_bayar') { sL = 'JANJI BAYAR'; sC = 'janji_bayar'; }
                                    %>
                                    <span class="status-badge <%= sC %>"><%= sL %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <table class="items-table">
                    <thead>
                        <tr>
                            <th style="width: 60%;">DESKRIPSI PRODUK / LAYANAN</th>
                            <th style="width: 10%; text-align: center;">QTY</th>
                            <th style="width: 15%; text-align: right;">HARGA</th>
                            <th style="width: 15%; text-align: right;">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% items.forEach(item => { %>
                        <tr>
                            <td>
                                <div style="font-weight: 700;"><%= item.description %></div>
                                <div style="font-size: 11px; color: var(--slate-500);">Layanan Internet Unlimited Fiber Optic</div>
                            </td>
                            <td style="text-align: center;">1</td>
                            <td style="text-align: right;">Rp <%= new Intl.NumberFormat('id-ID').format(item.total_price) %></td>
                            <td class="total-col">Rp <%= new Intl.NumberFormat('id-ID').format(item.total_price) %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>

                <div class="bottom-section">
                    <div class="payment-box">
                        <h4>INFORMASI PEMBAYARAN</h4>
                        <div class="bank-row">
                            <div class="bank-logo">BCA</div>
                            <div class="bank-details"><strong>829-034-XXXX</strong><br><span>A/N PT IDNET MEDIA DIGITAL</span></div>
                        </div>
                        <div class="bank-row">
                            <div class="bank-logo" style="color: #f59e0b;">MANDIRI</div>
                            <div class="bank-details"><strong>123-00-098XXXX</strong><br><span>A/N PT IDNET MEDIA DIGITAL</span></div>
                        </div>
                        <div style="margin-top: 15px; border-top: 1px dashed var(--slate-200); padding-top: 10px; font-size: 10px; font-style: italic; color: var(--slate-500);">
                            * Simpan bukti transfer untuk konfirmasi jika diperlukan.
                        </div>
                    </div>

                    <div class="totals-box">
                        <div class="total-item">
                            <span>Subtotal:</span>
                            <span class="val">Rp <%= new Intl.NumberFormat('id-ID').format(invoice.subtotal) %></span>
                        </div>
                        <% if (invoice.discount_amount > 0) { %>
                        <div class="total-item" style="color: #ef4444;">
                            <span>Diskon:</span>
                            <span class="val">- Rp <%= new Intl.NumberFormat('id-ID').format(invoice.discount_amount) %></span>
                        </div>
                        <% } %>
                        <% if (invoice.total_balance > invoice.total_amount) { 
                            const tung = invoice.total_balance - invoice.total_amount;
                        %>
                        <div class="total-item" style="color: #9333ea;">
                            <span>Tunggakan:</span>
                            <span class="val">+ Rp <%= new Intl.NumberFormat('id-ID').format(tung) %></span>
                        </div>
                        <% } %>
                        <div class="grand-total">
                            <span style="font-weight: 800;">TOTAL:</span>
                            <span class="val">Rp <%= new Intl.NumberFormat('id-ID').format(invoice.total_balance || (invoice.total_amount - (invoice.discount_amount||0))) %></span>
                        </div>
                        
                        <div style="margin-top: 40px; display: flex; justify-content: flex-end; gap: 40px; text-align: center;">
                            <div>
                                <p style="font-size: 11px; margin-bottom: 50px;">Pelanggan,</p>
                                <p style="font-size: 12px; font-weight: 800; border-top: 1px solid var(--primary); padding-top: 5px;"><%= invoice.customer_name %></p>
                            </div>
                            <div style="position: relative;">
                                <% if (invoice.status === 'paid') { %><div style="position: absolute; top: -10px; left: 50%; transform: translateX(-50%) rotate(-10deg); border: 3px solid #10b981; color: #10b981; padding: 4px 12px; font-weight: 900; opacity: 0.3;">LUNAS</div><% } %>
                                <p style="font-size: 11px; margin-bottom: 50px;">Kasir Digital,</p>
                                <p style="font-size: 12px; font-weight: 800; border-top: 1px solid var(--primary); padding-top: 5px;">ADMIN ID.NET</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thermal Placeholder -->
        <div class="page-thermal">
            <div style="text-align: center; border-bottom: 1px dashed #000; padding-bottom: 5px; margin-bottom: 5px;">
                <h3 style="margin: 0;"><%= companyInfo.company_name %></h3>
                <p style="font-size: 8px;"><%= companyInfo.company_address %></p>
            </div>
            <div style="font-size: 10px;">
                <%= invoice.invoice_number %> | <%= invoice.customer_name %><br>
                Total: Rp <%= new Intl.NumberFormat('id-ID').format(invoice.total_balance || invoice.total_amount) %>
            </div>
        </div>
    </div>

    <script>
        function switchMode(m) { document.body.className = 'mode-' + m; }
        const p = new URLSearchParams(window.location.search);
        if (p.get('format') === 'thermal') switchMode('thermal');
    </script>
</body>
</html>
