<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Print Invoice - <%= invoice.invoice_number %></title>
    <style>
        /* CSS ULTRA-COMPACT UNTUK THERMAL 58MM - ANTI TERPOTONG */
        @page { size: auto; margin: 0mm; }
        
        * { margin: 0; padding: 0; box-sizing: border-box; color: #000 !important; }
        
        body {
            font-family: 'Tahoma', 'Segoe UI', Arial, sans-serif !important;
            font-size: 9px !important;
            width: 48mm;
            margin: 0 auto;
            padding: 0 2mm;
            background: white;
            line-height: 1.2;
            font-weight: 600;
        }

        .no-print { display: block; text-align: center; padding: 15px; background: #EEE; border-bottom: 1px solid #CCC; margin-bottom: 10px; width: auto !important; }
        @media print { 
            .no-print { display: none !important; } 
            body { width: 48mm; margin: 0 auto; padding: 0 2mm; }
        }

        .receipt {
            padding: 2mm 0 4mm 0;
            clear: both;
            overflow: hidden;
        }

        .header { text-align: center; margin-bottom: 1.5mm; }
        .company-name { font-size: 11px !important; font-weight: bold; text-transform: uppercase; margin-bottom: 1px; letter-spacing: -0.3px; }
        .company-info { font-size: 8px !important; font-weight: normal; }

        /* FLOAT-BASED ROWS - ANTI TERPOTONG */
        .row { clear: both; overflow: hidden; margin-bottom: 0.8mm; border-bottom: none; width: 100%; font-size: 9px !important; }
        .lbl { float: left; width: 35%; text-align: left; font-weight: 600; font-size: 9px !important; }
        .val { float: right; width: 63%; text-align: right; font-weight: 600; font-size: 9px !important; word-break: break-word; }
        
        /* HR / SEPARATOR */
        .sep { border-top: 1px dashed black; height: 1px; margin: 1mm 0; clear: both; }
        .sep-bold { border-top: 1px solid black; height: 1px; margin: 1mm 0; clear: both; }

        .total-row {
            font-size: 10px !important;
            font-weight: bold;
            padding-top: 1.5mm;
            margin-top: 1mm;
            border-top: 1px solid black;
            clear: both;
            overflow: hidden;
        }
        .total-row .lbl { font-size: 10px !important; font-weight: bold; }
        .total-row .val { font-size: 10px !important; font-weight: bold; }

        @media screen {
            body { background: #f0f0f0; padding: 20px; width: auto; max-width: 400px; margin: 0 auto; }
            .receipt { background: white; padding: 15px; margin-bottom: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border-radius: 4px; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()" style="padding: 12px 25px; font-weight: bold; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 5px;">🖨️ CETAK</button>
        <button onclick="window.close()" style="padding: 12px 25px; cursor: pointer; margin-left:10px;">✖️ TUTUP</button>
    </div>

    <div class="receipt">
        <div class="header">
            <div class="company-name"><%= companyInfo?.company_name || 'ID.NET BY DBN' %></div>
            <div style="font-size: 6.5pt; font-weight: 600;">WA: <%= companyInfo?.company_phone %></div>
        </div>

        <div class="sep-bold"></div>

        <div class="row">
            <div class="lbl" style="width: 30%; font-size: 6.5pt;"><%= new Date(invoice.created_at).toLocaleDateString('id-ID') %></div>
            <div class="val" style="width: 68%; font-size: 6.5pt;">#<%= invoice.invoice_number %></div>
        </div>

        <div class="sep"></div>

        <div class="row"><div class="lbl">Pelanggan:</div><div class="val"><%= invoice.customer_name %></div></div>
        <div class="row"><div class="lbl">Jatuh Tempo:</div><div class="val"><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></div></div>

        <div class="sep"></div>

        <% (invoice.items || items || []).forEach(item => { %>
            <div class="row">
                <div class="lbl" style="width: 55%; font-size: 6.5pt;"><%= item.description %></div>
                <div class="val" style="width: 43%; font-size: 7pt;">Rp <%= new Intl.NumberFormat('id-ID').format(item.total_price) %></div>
            </div>
        <% }); %>

        <div class="row">
            <div class="lbl">TOTAL BULAN INI</div>
            <div class="val">Rp <%= new Intl.NumberFormat('id-ID').format(invoice.total_amount) %></div>
        </div>

        <% if (typeof invoice.total_balance !== 'undefined' && invoice.total_balance > invoice.total_amount) { 
            const tunggakan = invoice.total_balance - invoice.total_amount;
            let periodeKet = '';
            if (invoice.unpaid_periods) {
                const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
                const months = invoice.unpaid_periods.split(',')
                    .filter(p => p !== (invoice.raw_period || invoice.period))
                    .map(p => {
                        const [year, month] = p.split('-');
                        const mIdx = parseInt(month) - 1;
                        return (monthNames[mIdx] || month) + ' ' + (year.substring(2));
                    });
                if (months.length > 0) periodeKet = ' (' + months.join(', ') + ')';
            }
        %>
            <div class="row">
                <div class="lbl">TUNGGAKAN<%= periodeKet %></div>
                <div class="val" style="color:red !important;">Rp <%= new Intl.NumberFormat('id-ID').format(tunggakan) %></div>
            </div>
        <% } %>

        <div class="total-row">
            <div class="lbl">TOTAL BAYAR</div>
            <div class="val">Rp <%= new Intl.NumberFormat('id-ID').format(invoice.total_balance || invoice.total_amount) %></div>
        </div>

        <div class="sep"></div>
    </div>
</body>
</html>
