<div class="space-y-8 pb-20">
    <!-- Header with Breadcrumbs & Action -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <nav class="flex mb-3" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 text-xs font-bold uppercase tracking-widest text-slate-400">
                    <li class="inline-flex items-center">
                        <a href="/kasir/dashboard" class="hover:text-indigo-600 transition-colors">Dashboard</a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fas fa-chevron-right text-[10px] mx-2"></i>
                            <a href="/kasir/payments" class="hover:text-indigo-600 transition-colors">Pelanggan</a>
                        </div>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <i class="fas fa-chevron-right text-[10px] mx-2 text-slate-300"></i>
                            <span class="text-slate-600">Profil Detail</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <h1 class="text-4xl font-display font-black text-slate-900 tracking-tight flex items-center gap-4">
                <%= customer.name %>
                <% if (customer.status === 'active') { %>
                    <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-black uppercase tracking-widest rounded-full">ACTIVE</span>
                <% } else if (customer.status === 'isolated') { %>
                    <span class="px-3 py-1 bg-rose-100 text-rose-700 text-[10px] font-black uppercase tracking-widest rounded-full">ISOLATED</span>
                <% } else { %>
                <span class="px-3 py-1 bg-slate-100 text-slate-700 text-[10px] font-black uppercase tracking-widest rounded-full"><%= (customer.status || 'unknown').toUpperCase() %></span>
                <% } %>
            </h1>
        </div>

        <div class="flex items-center gap-3">
            <a href="/kasir/payments" class="px-6 py-3 bg-white border border-slate-200 text-slate-600 rounded-2xl font-bold text-sm hover:bg-slate-50 transition-all shadow-sm">
                <i class="fas fa-arrow-left mr-2"></i> Kembali
            </a>
            <button onclick="window.print()" class="px-6 py-3 bg-indigo-600 text-white rounded-2xl font-bold text-sm hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200">
                <i class="fas fa-print mr-2"></i> Print Profile
            </button>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left: Basic Info & Stats -->
        <div class="lg:col-span-1 space-y-8">
            <!-- Debt Card -->
            <div class="bg-gradient-to-br from-indigo-600 to-violet-700 rounded-3xl p-8 text-white shadow-xl shadow-indigo-200 relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 opacity-10 text-9xl">
                    <i class="fas fa-wallet"></i>
                </div>
                <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80 mb-1">Total Outstanding</p>
                <h3 class="text-3xl font-display font-black mb-6">
                    Rp <%= new Intl.NumberFormat('id-ID').format(totalDebt || 0) %>
                </h3>
                <div class="flex flex-col gap-3">
                    <a href="/kasir/payments?search=<%= customer.customer_code %>" class="w-full py-3 bg-white/20 hover:bg-white/30 backdrop-blur rounded-xl text-center text-sm font-bold transition-all border border-white/20">
                        Bayar Sekarang
                    </a>
                </div>
            </div>

            <!-- Profile Info -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8 space-y-6">
                <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4 pb-4 border-b border-slate-50">Informasi Dasar</h4>
                
                <div class="space-y-4">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400">
                            <i class="fas fa-hashtag"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Customer Code</p>
                            <p class="font-bold text-slate-900"><%= customer.customer_code %></p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">No. WhatsApp</p>
                            <p class="font-bold text-slate-900"><%= customer.phone || '-' %></p>
                            <% if (customer.phone) { %>
                                <a href="https://wa.me/<%= customer.phone.replace(/[^0-9]/g, '') %>" target="_blank" class="text-[10px] font-black text-indigo-600 uppercase hover:underline">Kirim Pesan</a>
                            <% } %>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400">
                            <i class="fas fa-location-dot"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Alamat</p>
                            <p class="text-sm font-semibold text-slate-600 leading-relaxed"><%= customer.address || '-' %></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Network Technical Info -->
            <div class="bg-slate-900 rounded-3xl p-8 text-white relative overflow-hidden">
                <div class="absolute top-4 right-8 opacity-20 transform rotate-12 text-4xl">
                    <i class="fas fa-network-wired"></i>
                </div>
                <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-6 border-b border-slate-800 pb-4">Status Jaringan</h4>
                
                <div class="space-y-5">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase">Metode Koneksi</p>
                        <p class="font-black text-indigo-400"><%= (customer.connection_type || 'unknown').toUpperCase() %></p>
                    </div>
                    <% if (customer.connection_type === 'pppoe') { %>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase">PPPoE ID</p>
                            <p class="font-bold text-sm"><%= customer.pppoe_username || '-' %></p>
                        </div>
                    <% } else if (customer.connection_type === 'static_ip') { %>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase">Static IP</p>
                            <p class="font-bold text-sm"><%= customer.static_ip_address || '-' %></p>
                        </div>
                    <% } %>
                    
                    <div class="grid grid-cols-2 gap-4 pt-4 border-t border-slate-800">
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase">ODC</p>
                            <p class="font-bold text-xs"><%= customer.odc_name || '-' %></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase">ODP</p>
                            <p class="font-bold text-xs"><%= customer.odp_name || '-' %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Invoice & Payment History -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Invoices Table -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 border-b border-slate-50 flex items-center justify-between">
                    <div>
                        <h4 class="text-xl font-display font-black text-slate-900">Riwayat Tagihan</h4>
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mt-1">Status Pembayaran Bulanan</p>
                    </div>
                    <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                        <i class="fas fa-file-invoice-dollar"></i>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50">
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Periode</th>
                                <th class="px-4 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Invoice</th>
                                <th class="px-4 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Total</th>
                                <th class="px-4 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Status</th>
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% if (invoices && invoices.length > 0) { %>
                                <% invoices.forEach(invoice => { %>
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-8 py-5 font-bold text-slate-900"><%= invoice.period %></td>
                                        <td class="px-4 py-5 font-mono text-xs text-slate-500"><%= invoice.invoice_number %></td>
                                        <td class="px-4 py-5 font-black text-slate-900">Rp <%= new Intl.NumberFormat('id-ID').format(invoice.total_amount) %></td>
                                        <td class="px-4 py-5 text-center">
                                            <% if (invoice.status === 'paid') { %>
                                                <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-black uppercase rounded-full">LUNAS</span>
                                            <% } else if (invoice.status === 'overdue') { %>
                                                <span class="px-3 py-1 bg-rose-100 text-rose-700 text-[10px] font-black uppercase rounded-full">OVERDUE</span>
                                            <% } else { %>
                                                <span class="px-3 py-1 bg-amber-100 text-amber-700 text-[10px] font-black uppercase rounded-full"><%= invoice.status.toUpperCase() %></span>
                                            <% } %>
                                        </td>
                                        <td class="px-8 py-5 text-right">
                                            <a href="/kasir/print-invoice/<%= invoice.id %>" target="_blank" class="w-9 h-9 border border-slate-200 rounded-xl inline-flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:border-indigo-200 transition-all">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-8 py-10 text-center text-slate-400 font-bold italic text-sm">
                                        Tidak ada data tagihan
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payments Table -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 border-b border-slate-50 flex items-center justify-between">
                    <div>
                        <h4 class="text-xl font-display font-black text-slate-900">Riwayat Pembayaran</h4>
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mt-1">10 Transaksi Terakhir di Kasir</p>
                    </div>
                    <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                        <i class="fas fa-history"></i>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50">
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Tanggal</th>
                                <th class="px-4 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Jumlah</th>
                                <th class="px-4 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Metode</th>
                                <th class="px-4 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Kasir</th>
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Struk</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% if (payments && payments.length > 0) { %>
                                <% payments.forEach(payment => { %>
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-8 py-5">
                                            <p class="font-bold text-slate-900"><%= new Date(payment.created_at).toLocaleDateString('id-ID') %></p>
                                            <p class="text-[10px] font-bold text-slate-400 uppercase"><%= new Date(payment.created_at).toLocaleTimeString('id-ID') %></p>
                                        </td>
                                        <td class="px-4 py-5 font-black text-emerald-600">Rp <%= new Intl.NumberFormat('id-ID').format(payment.amount) %></td>
                                        <td class="px-4 py-5">
                                            <span class="px-2 py-0.5 border border-slate-200 rounded text-[9px] font-bold text-slate-500 uppercase"><%= payment.payment_method %></span>
                                        </td>
                                        <td class="px-4 py-5 font-semibold text-slate-600 text-sm"><%= payment.notes || '-' %></td>
                                        <td class="px-8 py-5 text-right">
                                            <a href="/kasir/receipt/<%= payment.id %>" target="_blank" class="w-9 h-9 bg-slate-100 rounded-xl inline-flex items-center justify-center text-slate-500 hover:bg-emerald-500 hover:text-white transition-all">
                                                <i class="fas fa-file-alt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-8 py-10 text-center text-slate-400 font-bold italic text-sm">
                                        Tidak ada data pembayaran
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
