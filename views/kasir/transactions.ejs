<!-- Halaman Riwayat Transaksi Kasir - Premium Version -->
<div class="space-y-10 pb-20">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h1 class="text-4xl font-display font-black text-slate-900 tracking-tight">Riwayat Transaksi</h1>
            <p class="text-sm font-semibold text-slate-400 uppercase tracking-[0.2em] mt-2">Log Pembayaran & Verifikasi Kasir</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="bg-indigo-50 px-6 py-3 rounded-2xl border border-indigo-100 flex items-center gap-4 shadow-sm">
                <div class="w-10 h-10 bg-indigo-600 text-white rounded-xl flex items-center justify-center font-black text-sm">
                    <i class="fas fa-coins"></i>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none">Total Data</p>
                    <p class="text-xl font-display font-black text-indigo-600 mt-1"><%= (pagination.total || 0).toLocaleString('id-ID') %></p>
                </div>
            </div>
            <button onclick="printRekapPaid()" class="h-14 px-8 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg shadow-slate-200 flex items-center gap-3">
                <i class="fas fa-file-export text-indigo-400"></i>
                Export Rekap
            </button>
        </div>
    </div>

    <!-- Smart Filters -->
    <div class="bg-white rounded-[2.5rem] p-10 shadow-sm border border-slate-100">
        <form method="GET" action="/kasir/transactions" class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="md:col-span-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3 pl-2">Parameter Pencarian</label>
                <div class="relative">
                    <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-300"></i>
                    <input type="text" name="search" value="<%= search || '' %>"
                        class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-400 focus:bg-white rounded-2xl py-4 pl-14 pr-6 font-semibold text-slate-900 outline-none transition-all placeholder:text-slate-300"
                        placeholder="Nama, Invoice, atau Kode Pelanggan...">
                </div>
            </div>
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3 pl-2">Status Pembayaran</label>
                <select name="status" class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-400 focus:bg-white rounded-2xl py-4 px-6 font-black text-xs text-slate-700 outline-none appearance-none cursor-pointer">
                    <option value="">SEMUA STATUS</option>
                    <option value="paid" <%= status === 'paid' ? 'selected' : '' %>>LUNAS / PAID</option>
                    <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>PENDING VERIFICATION</option>
                    <option value="failed" <%= status === 'failed' ? 'selected' : '' %>>GAGAL / FAILED</option>
                </select>
            </div>
            <div class="flex items-end">
                <button type="submit" class="w-full h-14 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-700 active:scale-95 transition-all shadow-xl shadow-indigo-100">
                    Apply Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Data Table Surface -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
        <% if (transactions && transactions.length > 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
                            <th class="px-10 py-6">Transaction / Date</th>
                            <th class="px-6 py-6">Customer</th>
                            <th class="px-6 py-6">Accounting</th>
                            <th class="px-6 py-6 text-center">Protocol</th>
                            <th class="px-10 py-6 text-right">Operations</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% transactions.forEach(transaction => { %>
                            <tr class="hover:bg-slate-50/80 transition-all group">
                                <td class="px-10 py-6">
                                    <div class="flex items-center gap-5">
                                        <div class="w-12 h-12 bg-white rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 shadow-sm transition-transform group-hover:scale-110 group-hover:text-indigo-500">
                                            <i class="fas fa-fingerprint"></i>
                                        </div>
                                        <div>
                                            <p class="font-mono text-[10px] font-black text-slate-500 tracking-tighter">#<%= transaction.id %></p>
                                            <p class="text-xs font-bold text-slate-900 mt-1">
                                                <%= new Date(transaction.payment_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short' }) %>, 
                                                <span class="text-slate-400"><%= new Date(transaction.payment_date).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %></span>
                                            </p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <p class="font-display font-black text-slate-900"><%= transaction.customer_name || 'Generic Client' %></p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="text-[9px] font-black text-indigo-400 uppercase tracking-widest"><%= transaction.customer_code || '-' %></span>
                                        <span class="text-[9px] font-bold text-slate-300">•</span>
                                        <span class="text-[9px] font-mono text-slate-400"><%= transaction.invoice_number || 'TRX_ONLY' %></span>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <p class="font-display font-black text-slate-900">Rp <%= (transaction.amount || 0).toLocaleString('id-ID') %></p>
                                    <% 
                                    let statusColor = 'slate';
                                    let sText = (transaction.gateway_status || 'pending').toUpperCase();
                                    if (sText === 'PAID' || sText === 'SETTLEMENT' || sText === 'SUCCESS') statusColor = 'emerald';
                                    else if (sText === 'FAILED' || sText === 'CANCEL' || sText === 'EXPIRE') statusColor = 'rose';
                                    else if (sText === 'PENDING') statusColor = 'amber';
                                    %>
                                    <span class="inline-flex items-center px-2 py-0.5 mt-1.5 bg-<%= statusColor %>-50 text-<%= statusColor %>-600 text-[8px] font-black tracking-widest rounded-full border border-<%= statusColor %>-100">
                                        <%= sText %>
                                    </span>
                                </td>
                                <td class="px-6 py-6 text-center">
                                    <% 
                                    let mIcon = 'fa-money-bill-wave';
                                    let mText = (transaction.payment_method || 'cash').toUpperCase();
                                    if (mText === 'TRANSFER') mIcon = 'fa-university';
                                    else if (mText === 'EWALLET') mIcon = 'fa-mobile-screen-button';
                                    else if (mText === 'QRIS') mIcon = 'fa-qrcode';
                                    %>
                                    <div class="inline-flex flex-col items-center">
                                        <i class="fas <%= mIcon %> text-slate-300 text-lg"></i>
                                        <span class="text-[8px] font-black text-slate-400 mt-2 tracking-widest"><%= mText %></span>
                                    </div>
                                </td>
                                <td class="px-10 py-6 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <% if (transaction.payment_proof_url) { %>
                                            <button onclick="viewProof('<%= transaction.payment_proof_url %>')" class="w-10 h-10 inline-flex items-center justify-center rounded-xl bg-slate-50 border border-slate-100 text-slate-400 hover:text-indigo-600 transition-all" title="View Proof">
                                                <i class="fas fa-image text-sm"></i>
                                            </button>
                                        <% } %>
                                        <button onclick="viewTransaction(<%= transaction.id %>)" class="w-10 h-10 inline-flex items-center justify-center rounded-xl bg-slate-50 border border-slate-100 text-indigo-500 hover:bg-indigo-600 hover:text-white transition-all shadow-sm" title="Quick Details">
                                            <i class="fas fa-eye text-sm"></i>
                                        </button>
                                        <% if (sText === 'PAID' || sText === 'SETTLEMENT' || sText === 'SUCCESS' || sText === 'COMPLETED') { %>
                                            <a href="/kasir/receipt/<%= transaction.id %>" target="_blank" class="h-10 px-4 inline-flex items-center justify-center rounded-xl bg-emerald-500 text-white font-black text-[10px] tracking-widest hover:bg-emerald-600 shadow-lg shadow-emerald-100 transition-all">
                                                RECEIPT
                                            </a>
                                            <button onclick="sendNotification(<%= transaction.id %>, this)" class="w-10 h-10 inline-flex items-center justify-center rounded-xl bg-blue-50 border border-blue-100 text-blue-500 hover:bg-blue-500 hover:text-white transition-all shadow-sm" title="Kirim Notifikasi WA">
                                                <i class="fab fa-whatsapp text-sm"></i>
                                            </button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Enhanced Pagination -->
            <div class="px-10 py-8 border-t border-slate-50 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-6">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                    Records <%= ((pagination.page - 1) * pagination.limit) + 1 %> — <%= Math.min(pagination.page * pagination.limit, pagination.total) %> of <%= pagination.total %>
                </p>
                
                <div class="flex items-center gap-2">
                    <% if (pagination.page > 1) { %>
                        <a href="?page=<%= pagination.page - 1 %>&search=<%= search %>&status=<%= status %>" class="w-10 h-10 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:text-indigo-600 transition-all"><i class="fas fa-chevron-left text-xs"></i></a>
                    <% } %>
                    
                    <span class="h-10 px-4 inline-flex items-center justify-center rounded-xl bg-indigo-600 text-white font-black text-xs">
                        <%= pagination.page %>
                    </span>
                    
                    <% if (pagination.page < pagination.pages) { %>
                        <a href="?page=<%= pagination.page + 1 %>&search=<%= search %>&status=<%= status %>" class="w-10 h-10 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:text-indigo-600 transition-all"><i class="fas fa-chevron-right text-xs"></i></a>
                    <% } %>
                </div>
            </div>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-24 grayscale opacity-40">
                <i class="fas fa-receipt text-6xl mb-4 text-slate-200"></i>
                <p class="font-black text-slate-400 uppercase tracking-widest">No Transaction Records</p>
                <a href="/kasir/payments" class="mt-6 text-xs font-black text-indigo-500 hover:underline">Start New Payment <i class="fas fa-arrow-right ml-2 text-[10px]"></i></a>
            </div>
        <% } %>
    </div>
</div>

<!-- Premium Modals -->
<!-- Glass Proof View -->
<div id="proofModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm hidden items-center justify-center z-[100] px-6">
    <div class="bg-white rounded-[2.5rem] max-w-2xl w-full shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300">
        <div class="p-8 border-b border-slate-50 flex items-center justify-between">
            <h3 class="text-xl font-display font-black text-slate-900">BUKTI TRANSFER</h3>
            <button onclick="closeProofModal()" class="w-10 h-10 rounded-2xl bg-slate-50 text-slate-400 hover:text-rose-500 transition-all">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="p-10 bg-slate-50/50">
            <img id="proofImage" src="" class="w-full h-auto rounded-3xl shadow-xl border-4 border-white">
        </div>
    </div>
</div>

<!-- Detailed Drilldown Modal -->
<div id="transactionDetailModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md hidden items-center justify-center z-[100] px-6">
    <div class="bg-white rounded-[3rem] shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden animate-in slide-in-from-bottom-10 duration-500">
        <div class="p-10 pb-6 flex items-center justify-between">
            <div>
                <h3 class="text-2xl font-display font-black text-slate-900">TRANSACTION INTEL</h3>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Full Drilldown & Context</p>
            </div>
            <button onclick="closeTransactionModal()" class="w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 hover:text-indigo-600 transition-all">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div id="transactionDetailContent" class="p-10 pt-0 overflow-y-auto max-h-[70vh] custom-scrollbar">
            <!-- Content will be injected -->
        </div>
    </div>
</div>

<script>
async function viewTransaction(paymentId) {
    const modal = document.getElementById('transactionDetailModal');
    const content = document.getElementById('transactionDetailContent');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    content.innerHTML = '<div class="flex flex-col items-center justify-center py-20"><i class="fas fa-circle-notch fa-spin text-4xl text-indigo-500 mb-4"></i><p class="text-[10px] font-black text-slate-400 tracking-widest uppercase">Fetching Intel...</p></div>';
    
    try {
        const response = await fetch(`/kasir/api/payment/${paymentId}`);
        const data = await response.json();
        
        if (data.success) {
            const p = data.data;
            const statusColor = p.gateway_status === 'paid' || p.gateway_status === 'settlement' ? 'emerald' : 
                               p.gateway_status === 'pending' ? 'amber' : 'rose';
            
            content.innerHTML = `
                <div class="space-y-8">
                    <div class="grid grid-cols-2 gap-6 bg-slate-50 p-8 rounded-[2rem] border border-slate-100">
                        <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Transaction ID</p>
                            <p class="font-mono font-black text-slate-900 text-lg">#${p.id}</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Status Protocol</p>
                            <span class="px-3 py-1 bg-${statusColor}-500 text-white text-[9px] font-black tracking-widest rounded-lg">${(p.gateway_status || 'PENDING').toUpperCase()}</span>
                        </div>
                        <div class="col-span-2 space-y-1 pt-4 border-t border-slate-200">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Client Identity</p>
                            <p class="font-display font-black text-slate-900 text-xl">${p.customer_name || 'N/A'}</p>
                            <p class="text-xs font-bold text-indigo-500 uppercase tracking-widest">${p.customer_code || '---'}</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-8 px-4">
                        <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Accounting Amount</p>
                            <p class="text-2xl font-display font-black text-emerald-600">Rp ${(p.amount || 0).toLocaleString('id-ID')}</p>
                        </div>
                         <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Channel / Method</p>
                            <p class="text-sm font-black text-slate-900 uppercase tracking-tight">${p.payment_method || 'CASH'}</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Time Registered</p>
                            <p class="text-sm font-black text-slate-700">${new Date(p.payment_date).toLocaleString('id-ID')}</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Linked Invoice</p>
                            <p class="text-sm font-black text-indigo-500">${p.invoice_number || 'TRX_ONLY'}</p>
                        </div>
                    </div>

                    ${p.notes ? `
                    <div class="bg-indigo-50/30 p-8 rounded-[2rem] border border-indigo-100/50">
                        <p class="text-[9px] font-black text-indigo-400 uppercase tracking-widest mb-2">Internal Notes</p>
                        <p class="text-sm font-semibold text-slate-700 leading-relaxed">${p.notes}</p>
                    </div>
                    ` : ''}

                    <div class="pt-6 flex gap-4">
                         <a href="/kasir/payment-records/print/${p.id}" target="_blank" class="flex-1 h-14 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest flex items-center justify-center gap-3">
                            <i class="fas fa-print opacity-40"></i>
                            Evidence Record
                        </a>
                        ${p.gateway_status === 'paid' || p.gateway_status === 'settlement' ? `
                             <a href="/kasir/receipt/${p.id}" target="_blank" class="flex-1 h-14 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest flex items-center justify-center gap-3 shadow-lg shadow-emerald-100">
                                <i class="fas fa-receipt opacity-40"></i>
                                Sales Receipt
                            </a>
                        ` : ''}
                    </div>
                </div>
            `;
        }
    } catch (e) { console.error(e); }
}

function closeTransactionModal() { document.getElementById('transactionDetailModal').classList.add('hidden'); document.getElementById('transactionDetailModal').classList.remove('flex'); }
function viewProof(url) { document.getElementById('proofImage').src = url; document.getElementById('proofModal').classList.remove('hidden'); document.getElementById('proofModal').classList.add('flex'); }
function closeProofModal() { document.getElementById('proofModal').classList.add('hidden'); document.getElementById('proofModal').classList.remove('flex'); }

function printRekapPaid() {
    const params = new URLSearchParams(window.location.search);
    params.delete('page');
    window.open('/billing/rekap/transactions?' + params.toString(), '_blank');
}

async function sendNotification(paymentId, btn) {
    if (btn.disabled) return;
    const originalHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-circle-notch fa-spin text-sm"></i>';
    
    try {
        const resp = await fetch(`/kasir/api/send-notification/${paymentId}`, { method: 'POST' });
        const data = await resp.json();
        
        if (data.success) {
            btn.innerHTML = '<i class="fas fa-check text-sm"></i>';
            btn.classList.remove('bg-blue-50', 'text-blue-500', 'border-blue-100');
            btn.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500');
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                btn.classList.remove('bg-emerald-500', 'text-white', 'border-emerald-500');
                btn.classList.add('bg-blue-50', 'text-blue-500', 'border-blue-100');
            }, 3000);
        } else {
            alert('Gagal mengirim notifikasi: ' + (data.message || 'Unknown error'));
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }
    } catch (e) {
        console.error('Notification error:', e);
        alert('Error: ' + e.message);
        btn.innerHTML = originalHtml;
        btn.disabled = false;
    }
}
</script>
