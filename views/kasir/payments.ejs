<!-- Halaman Pembayaran Kasir - Premium Refined Version -->
<div class="space-y-10 pb-20">
    <!-- Page Title & Stats Overview -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
        <div>
            <h1 class="text-4xl font-display font-black text-slate-900 tracking-tight">Proses Pembayaran</h1>
            <p class="text-sm font-semibold text-slate-400 uppercase tracking-[0.2em] mt-2">Sistem Loket Pembayaran & Penagihan</p>
        </div>
        
        <!-- Live Quick Stats -->
        <div class="flex flex-wrap gap-4">
            <div class="bg-white px-6 py-4 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
                <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600">
                    <i class="fas fa-file-invoice-dollar text-xl"></i>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Pending Bills</p>
                    <p class="text-xl font-display font-black text-slate-900" id="totalPendingCount_Display"><%= recentCustomers.filter(c => c.pending_count > 0).length %></p>
                </div>
            </div>
            <div class="bg-white px-6 py-4 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
                <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                    <i class="fas fa-bolt text-xl"></i>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Active Customers</p>
                    <p class="text-xl font-display font-black text-slate-900"><%= recentCustomers.filter(c => c.status === 'active').length %></p>
                </div>
            </div>
        </div>
    </div>


    <!-- Filter Bar -->
    <div class="flex items-center gap-4 mb-8">
        <a href="/kasir/payments" class="px-6 py-3 rounded-2xl <%= !currentMonth ? 'bg-indigo-600 text-white shadow-lg' : 'bg-white text-slate-500 border border-slate-100 hover:bg-slate-50' %> font-black text-xs uppercase tracking-widest transition-all">SEMUA TAGIHAN</a>
        <a href="/kasir/payments?month=current" class="px-6 py-3 rounded-2xl <%= currentMonth ? 'bg-indigo-600 text-white shadow-lg' : 'bg-white text-slate-500 border border-slate-100 hover:bg-slate-50' %> font-black text-xs uppercase tracking-widest transition-all">BULAN BERJALAN</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        <!-- Action Center (Left) -->
        <div class="lg:col-span-8 space-y-10">
            
            <!-- Step 1: Smart Search -->
            <div class="bg-white rounded-[2.5rem] p-10 shadow-sm border border-slate-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50 rounded-full -mr-16 -mt-16 transition-all group-hover:scale-110"></div>
                
                <div class="relative z-10">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-10 h-10 bg-indigo-600 text-white rounded-xl flex items-center justify-center font-black text-sm shadow-lg shadow-indigo-200">1</div>
                        <h3 class="text-xl font-display font-black text-slate-900">IDENTIFIKASI PELANGGAN</h3>
                    </div>

                    <div class="relative">
                        <i class="fas fa-search absolute left-6 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                        <input type="text" id="customerSearch" 
                            class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-400 focus:bg-white rounded-2xl py-6 pl-16 pr-8 text-xl font-semibold text-slate-900 placeholder:text-slate-400 transition-all shadow-inner outline-none"
                            placeholder="Ketik Nama, Kode, atau No. Telepon..." autofocus>
                    </div>

                    <!-- Search Feedback: Results (Dynamic) -->
                    <div id="searchResults" class="hidden mt-8 animate-in slide-in-from-top-4 duration-300">
                        <div class="flex items-center justify-between mb-4 px-2">
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Hasil Pencarian</span>
                        </div>
                        <div id="customerList" class="grid grid-cols-1 gap-3 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2: Customer Detail & Invoice Focus -->
            <div id="customerInfoCard" class="hidden animate-in zoom-in-95 duration-500">
                <div class="bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
                    <!-- Section Header -->
                    <div class="p-10 border-b border-slate-50 flex items-center justify-between bg-slate-50/30">
                        <div class="flex items-center gap-5">
                            <div class="w-10 h-10 bg-emerald-500 text-white rounded-xl flex items-center justify-center font-black text-sm shadow-lg shadow-emerald-200">2</div>
                            <div>
                                <h3 class="text-xl font-display font-black text-slate-900">BILLING DETAILS</h3>
                                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Verification & Statement</p>
                            </div>
                        </div>
                        <button onclick="resetForm()" class="w-12 h-12 rounded-2xl bg-white border border-slate-200 text-slate-400 hover:text-rose-500 hover:border-rose-200 transition-all group">
                            <i class="fas fa-times group-hover:rotate-90 transition-transform"></i>
                        </button>
                    </div>

                    <div class="p-10 space-y-10">
                        <!-- Profile Highlight Area -->
                        <div id="customerInfo" class="bg-indigo-50/50 border border-indigo-100/50 rounded-3xl p-8">
                            <!-- Populated by JS -->
                        </div>

                        <!-- Active Invoices Section -->
                        <div id="invoicesSection">
                            <div class="flex items-center justify-between mb-6">
                                <div class="flex items-center gap-4">
                                    <h4 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-3">
                                        <i class="fas fa-receipt text-indigo-500"></i>
                                        Daftar Tagihan
                                    </h4>
                                    <span id="invoiceCount" class="px-4 py-1.5 bg-indigo-100 text-indigo-700 rounded-full text-[10px] font-black tracking-widest"></span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button onclick="toggleAllInvoices(true)" class="px-3 py-1.5 bg-slate-100 hover:bg-indigo-100 text-slate-500 hover:text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all">BAYAR SEMUA</button>
                                    <button onclick="toggleAllInvoices(false)" class="px-3 py-1.5 bg-slate-100 hover:bg-rose-100 text-slate-500 hover:text-rose-600 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all">BATAL SEMUA</button>
                                </div>
                            </div>
                            <div id="invoicesList" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <!-- Populated by JS -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Checkout Sidebar (Right) -->
        <div class="lg:col-span-4">
            <div class="sticky top-10">
                <div id="paymentCard" class="hidden animate-in slide-in-from-right-10 duration-500">
                    <div class="bg-slate-900 rounded-[2.5rem] shadow-2xl shadow-slate-900/40 overflow-hidden text-white">
                        <!-- Step 3 Header -->
                        <div class="p-10 pb-6 border-b border-slate-800">
                            <div class="flex items-center gap-4 mb-2">
                                <div class="w-10 h-10 bg-indigo-500 text-white rounded-xl flex items-center justify-center font-black text-sm">3</div>
                                <h3 class="text-xl font-display font-black uppercase tracking-tight">CHEKOUT LOKET</h3>
                            </div>
                            <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">Finalize Transaction</p>
                        </div>

                        <form id="paymentForm" action="/kasir/payments" method="POST" class="p-10 space-y-8">
                            <input type="hidden" name="customerId" id="customerId">
                            <input type="hidden" name="paymentType" id="paymentType">
                            <input type="hidden" name="amount" id="hiddenAmount">
                            <div id="selectedInvoiceInputs"></div>

                            <!-- Type Selector -->
                            <div class="space-y-4">
                                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Metode Bayar</label>
                                <div class="grid grid-cols-3 gap-3">
                                    <div data-type="full" class="payment-type-btn p-4 rounded-2xl border border-slate-800 bg-slate-800/50 hover:border-indigo-500/50 transition-all flex flex-col items-center gap-2 cursor-pointer">
                                        <i class="fas fa-check-double text-emerald-400"></i>
                                        <span class="text-[10px] font-black uppercase tracking-widest">FULL</span>
                                    </div>
                                    <div data-type="partial" class="payment-type-btn p-4 rounded-2xl border border-slate-800 bg-slate-800/50 hover:border-indigo-500/50 transition-all flex flex-col items-center gap-2 cursor-pointer">
                                        <i class="fas fa-split text-amber-400"></i>
                                        <span class="text-[10px] font-black uppercase tracking-widest">CICIL</span>
                                    </div>
                                    <div data-type="debt" class="payment-type-btn p-4 rounded-2xl border border-slate-800 bg-slate-800/50 hover:border-indigo-500/50 transition-all flex flex-col items-center gap-2 cursor-pointer">
                                        <i class="fas fa-hourglass-start text-rose-400"></i>
                                        <span class="text-[10px] font-black uppercase tracking-widest">DEBT</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Balance / Amount Control -->
                            <div id="balanceField" class="hidden p-6 rounded-3xl bg-indigo-500/10 border border-indigo-500/20 space-y-4">
                                <div class="flex items-center justify-between">
                                    <span class="text-[10px] font-black text-indigo-300 uppercase tracking-widest">Store Credits</span>
                                    <span id="displayAccountBalance" class="font-mono text-sm font-bold text-white">Rp 0</span>
                                </div>
                                <div id="useBalanceContainer" class="flex items-center gap-3">
                                    <input type="checkbox" name="useBalance" id="useBalance" value="true" class="w-5 h-5 rounded-lg border-slate-700 bg-slate-800 text-indigo-500 focus:ring-0">
                                    <label for="useBalance" class="text-xs font-bold text-slate-300">Potong Saldo</label>
                                </div>
                            </div>

                            <div id="amountField" class="hidden space-y-3">
                                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Jumlah Penyetoran</label>
                                <div class="relative">
                                    <span class="absolute left-6 top-1/2 -translate-y-1/2 font-black text-indigo-400">Rp</span>
                                    <input type="text" id="amount" class="w-full bg-slate-800 border-2 border-slate-700 focus:border-indigo-500 rounded-2xl py-4 pl-14 pr-6 font-black text-xl text-white outline-none transition-all placeholder:text-slate-600" placeholder="0">
                                </div>
                                <div class="flex justify-between items-center text-[10px] font-black text-slate-500">
                                    <span>TOTAL BILL:</span>
                                    <span id="totalDue" class="text-rose-400">Rp 0</span>
                                </div>
                            </div>

                            <!-- Payment Channel -->
                            <div id="paymentMethodField" class="hidden space-y-3">
                                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Channel Pembayaran</label>
                                <select name="paymentMethod" id="paymentMethod" class="w-full bg-slate-800 border-2 border-slate-700 focus:border-indigo-500 rounded-2xl py-4 px-6 font-bold text-sm text-white outline-none appearance-none cursor-pointer">
                                    <option value="cash">💵 TUNAI / CASH</option>
                                    <option value="transfer">🏦 BANK TRANSFER</option>
                                    <option value="ewallet">📱 E-WALLET</option>
                                    <option value="qris">📊 QRIS DYNAMIC</option>
                                </select>
                            </div>

                            <!-- Dynamic Summary Area -->
                            <div id="paymentSummary" class="hidden p-8 rounded-3xl bg-indigo-600 shadow-xl shadow-indigo-900/20 space-y-6">
                                <div class="flex justify-between items-center border-b border-white/10 pb-4">
                                    <span class="text-[10px] font-black text-indigo-200 uppercase tracking-widest">Nett Payable</span>
                                    <span class="font-mono text-sm font-bold" id="summarySubtotal">Rp 0</span>
                                </div>
                                <div class="flex justify-between items-end">
                                    <span class="text-[10px] font-black text-indigo-100 uppercase tracking-widest">Final Transaction</span>
                                    <span class="text-3xl font-display font-black text-white leading-none" id="summaryTotal">Rp 0</span>
                                </div>
                            </div>

                            <!-- Cash Received Input (for cash only) -->
                            <div id="cashCalculation" class="hidden space-y-3 p-6 rounded-3xl bg-slate-800 border border-slate-700">
                                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Uang Diterima</label>
                                <div class="relative">
                                    <span class="absolute left-6 top-1/2 -translate-y-1/2 font-black text-emerald-400">Rp</span>
                                    <input type="text" id="cashReceived" class="w-full bg-slate-900 border-2 border-slate-700 focus:border-emerald-500 rounded-2xl py-4 pl-14 pr-6 font-black text-xl text-white outline-none transition-all placeholder:text-slate-700" placeholder="0">
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Kembalian:</span>
                                    <span id="change" class="text-xl font-black text-emerald-400">Rp 0</span>
                                </div>
                            </div>

                            <!-- Notes -->
                            <div class="space-y-3">
                                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Catatan Loket</label>
                                <textarea name="notes" id="notes" rows="2" class="w-full bg-slate-800 border-2 border-slate-700 focus:border-indigo-500 rounded-2xl p-4 text-sm text-white outline-none transition-all placeholder:text-slate-600" placeholder="Keterangan tambahan..."></textarea>
                            </div>

                            <!-- Execution Buttons -->
                            <div class="pt-6 space-y-4">
                                <button type="submit" id="submitPaymentBtn" class="w-full py-6 bg-emerald-500 hover:bg-emerald-600 active:scale-95 text-slate-900 rounded-3xl font-black text-lg tracking-tight shadow-xl shadow-emerald-500/20 transition-all flex items-center justify-center gap-3">
                                    <span id="submitBtnText">KONFIRMASI BAYAR</span>
                                    <span id="submitBtnLoading" class="hidden"><i class="fas fa-circle-notch fa-spin"></i></span>
                                </button>
                                <button type="button" onclick="resetForm()" class="w-full py-4 text-slate-500 font-bold text-xs uppercase tracking-widest hover:text-white transition-colors">Aborsi Transaksi</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Management: Recently Active Customers -->
    <div id="customerListTable" class="animate-in slide-in-from-bottom-10 duration-700">
        <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
            <div class="p-10 border-b border-slate-50 bg-slate-50/20 flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h3 class="text-2xl font-display font-black text-slate-900">Queue Pelanggan</h3>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">Status Penagihan & Isolir Terkini</p>
                </div>
                
                <!-- Category Tabs -->
                <div class="flex bg-slate-100 p-1.5 rounded-2xl gap-1">
                    <button class="tab-btn px-6 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest <%= !currentMonth ? 'active' : '' %>" data-tab="pending" onclick="switchTab('pending')">PENDING</button>
                    <button class="tab-btn px-6 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest <%= currentMonth ? 'active' : '' %>" data-tab="current" onclick="filterCurrentMonth()">BULAN INI</button>
                    <button class="tab-btn px-6 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all" data-tab="paid" onclick="switchTab('paid')">LUNAS</button>
                    <button class="tab-btn px-6 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all" data-tab="isolated" onclick="switchTab('isolated')">ISOLIR</button>
                </div>
            </div>

            <div class="overflow-x-auto min-h-[400px]">
                <% if (recentCustomers && recentCustomers.length > 0) { %>
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
                                <th class="px-10 py-6">Identity</th>
                                <th class="px-6 py-6">Connectivity</th>
                                <th class="px-6 py-6">Statement</th>
                                <th class="px-6 py-6 text-right">Accounting</th>
                                <th class="px-10 py-6 text-right">Action Desk</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% recentCustomers.forEach(customer => {
                                const isIsolated = (customer.is_isolated == 1 || customer.status === 'isolated');
                                const tabType = isIsolated ? 'isolated' : (customer.pending_count > 0 ? 'pending' : 'paid');
                            %>
                                <tr class="hover:bg-slate-50/80 transition-all group customer-row" data-customer-json='<%= JSON.stringify(customer).replace(/'/g, "&#39;") %>' data-tab-type="<%= tabType %>">
                                    <td class="px-10 py-6">
                                        <div class="flex items-center gap-5">
                                            <div class="w-12 h-12 bg-white rounded-2xl border border-slate-100 flex items-center justify-center text-indigo-500 shadow-sm transition-transform group-hover:scale-110">
                                                <i class="fas fa-user-astronaut text-lg"></i>
                                            </div>
                                            <div>
                                                <p class="font-display font-black text-slate-900 leading-none"><%= customer.name %></p>
                                                <div class="flex gap-2 items-center mt-2">
                                                    <p class="font-mono text-[10px] font-bold text-slate-400 uppercase tracking-tighter"><%= customer.customer_code %></p>
                                                    <% if (customer.pending_periods) { %>
                                                        <span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[8px] font-black uppercase rounded tracking-widest"><%= customer.pending_periods %></span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-6">
                                        <p class="text-xs font-bold text-slate-700 flex items-center gap-2">
                                            <i class="fas fa-wifi text-indigo-400"></i>
                                            <%= customer.package_name || 'Generic Link' %>
                                        </p>
                                        <p class="text-[10px] font-bold text-slate-400 mt-1"><%= customer.phone || 'NO_CONTACT' %></p>
                                    </td>
                                    <td class="px-6 py-6">
                                        <% if (isIsolated) { %>
                                            <span class="px-3 py-1 bg-rose-50 text-rose-600 text-[9px] font-black tracking-widest rounded-full border border-rose-100 group-hover:bg-rose-500 group-hover:text-white transition-colors">ISOLATED</span>
                                        <% } else { %>
                                            <span class="px-3 py-1 bg-emerald-50 text-emerald-600 text-[9px] font-black tracking-widest rounded-full border border-emerald-100">ACTIVE</span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-6 text-right">
                                        <p class="font-mono font-black <%= (customer.total_pending || 0) > 0 ? 'text-rose-500' : 'text-slate-400' %>">
                                            Rp <%= (customer.total_pending || 0).toLocaleString('id-ID') %>
                                        </p>
                                        <p class="text-[9px] font-bold text-indigo-400 mt-1">CREDIT: Rp <%= (customer.account_balance || 0).toLocaleString('id-ID') %></p>
                                    </td>
                                    <td class="px-10 py-6 text-right space-x-2">
                                        <!-- Profile View (Full Feature) -->
                                        <a href="/kasir/customers/<%= customer.id %>" class="w-10 h-10 inline-flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-400 hover:text-indigo-600 hover:border-indigo-200 shadow-sm transition-all" title="View Profile">
                                            <i class="fas fa-id-badge text-sm"></i>
                                        </a>
                                        <!-- Quick Pay -->
                                        <button class="quick-pay-btn px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-indigo-700 shadow-lg shadow-indigo-100 active:scale-95 transition-all">
                                            Pay
                                        </button>
                                        <!-- WhatsApp Notification -->
                                        <button onclick="sendInvoiceNotification('<%= customer.id %>', this)" class="w-10 h-10 inline-flex items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 border border-emerald-100 hover:bg-emerald-500 hover:text-white transition-all ml-1" title="Send WhatsApp Reminder">
                                            <i class="fab fa-whatsapp text-lg"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="flex flex-col items-center justify-center py-20 grayscale opacity-40">
                        <i class="fas fa-folder-open text-6xl mb-4 text-slate-200"></i>
                        <p class="font-black text-slate-400 uppercase tracking-widest">No Active Records</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<style>
    .payment-type-btn.selected {
        background-color: #6366f1 !important;
        border-color: #818cf8 !important;
        color: white !important;
        box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.4);
        transform: translateY(-2px);
    }
    
    .tab-btn.active {
        background-color: white;
        color: #6366f1;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }
</style>

<script>
    let searchTimeout;
    let selectedCustomer = null;
    let pendingInvoices = [];
    let selectedPaymentType = null;
    let totalDueAmount = 0;

    // Initialize UI
    document.addEventListener('DOMContentLoaded', () => {
        // Switch to pending tab by default
        switchTab('pending');
        
        // Setup Search
        const searchInput = document.getElementById('customerSearch');
        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.trim();
            clearTimeout(searchTimeout);
            if (query.length < 2) {
                document.getElementById('searchResults').classList.add('hidden');
                return;
            }
            searchTimeout = setTimeout(() => searchCustomers(query), 400);
        });

        // Setup payment type buttons
        document.querySelectorAll('.payment-type-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const type = btn.dataset.type;
                selectPaymentType(type, btn);
            });
        });

        // Setup quick pay buttons in table
        document.querySelectorAll('.quick-pay-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const row = btn.closest('.customer-row');
                const customerData = JSON.parse(row.dataset.customerJson);
                selectCustomerFromTable(customerData);
            });
        });

        // Money formatting for inputs
        document.getElementById('amount').addEventListener('input', formatAndCalculate);
        document.getElementById('cashReceived').addEventListener('input', formatAndCalculate);
        document.getElementById('paymentMethod').addEventListener('change', toggleCashSection);
        document.getElementById('useBalance').addEventListener('change', updatePaymentSummary);
    });

    function switchTab(tab) {
        if (tab === 'current') {
            filterCurrentMonth();
            return;
        }
        
        // If we were on 'current' month filter (server-side), redirect back to base payments
        if (window.location.search.includes('month=current')) {
            window.location.href = '/kasir/payments';
            return;
        }

        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.tab === tab);
        });
        document.querySelectorAll('.customer-row').forEach(row => {
            row.classList.toggle('hidden', row.dataset.tabType !== tab);
        });
    }

    function filterCurrentMonth() {
        window.location.href = '/kasir/payments?month=current';
    }

    async function searchCustomers(query) {
        try {
            const response = await fetch(`/kasir/api/search-customer?q=${encodeURIComponent(query)}`);
            const data = await response.json();
            const resultList = document.getElementById('customerList');
            
            if (data.success && data.data.length > 0) {
                resultList.innerHTML = data.data.map(cust => `
                    <div class="flex items-center justify-between p-4 bg-slate-50 hover:bg-white border border-transparent hover:border-indigo-100 rounded-3xl cursor-pointer transition-all group" onclick='selectCustomer(${JSON.stringify(cust).replace(/'/g, "&#39;")})'>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center font-black">
                                <i class="fas fa-search-dollar"></i>
                            </div>
                            <div>
                                <p class="font-black text-slate-900">${cust.name}</p>
                                <div class="flex gap-2 items-center">
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">${cust.customer_code}</p>
                                    ${cust.pending_periods ? `<span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[8px] font-black uppercase rounded tracking-widest">${cust.pending_periods}</span>` : ''}
                                </div>
                            </div>
                        </div>
                        <i class="fas fa-chevron-right text-slate-300 group-hover:text-indigo-400 group-hover:translate-x-1 transition-all"></i>
                    </div>
                `).join('');
                document.getElementById('searchResults').classList.remove('hidden');
            } else {
                resultList.innerHTML = '<p class="text-center py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest italic">No customers matched your query</p>';
                document.getElementById('searchResults').classList.remove('hidden');
            }
        } catch (e) {
            console.error('Search error:', e);
        }
    }

    function selectCustomerFromTable(cust) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        document.getElementById('customerSearch').value = cust.name;
        selectCustomer(cust);
    }

    async function selectCustomer(cust) {
        selectedCustomer = cust;
        document.getElementById('searchResults').classList.add('hidden');
        document.getElementById('customerListTable').classList.add('hidden');

        // Render mini profile
        const isIsolated = (cust.status === 'isolated');
        document.getElementById('customerInfo').innerHTML = `
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                     <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                        <i class="fas fa-user-check text-xl"></i>
                    </div>
                    <div>
                        <p class="text-2xl font-display font-black text-slate-900">${cust.name}</p>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">${cust.customer_code} • ${cust.phone || 'NO_CONTACT'}</p>
                    </div>
                </div>
                <span class="px-4 py-1.5 ${isIsolated ? 'bg-rose-500' : 'bg-emerald-500'} text-white text-[10px] font-black tracking-widest rounded-xl shadow-lg">${isIsolated ? 'ISOLATED' : 'ACTIVE'}</span>
            </div>
            <div class="grid grid-cols-2 gap-4 mt-6">
                 <div class="p-4 bg-white rounded-2xl border border-indigo-100/50">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">DATA PACKAGE</p>
                    <p class="text-sm font-black text-slate-700">${cust.package_name || '-'}</p>
                 </div>
                 <div class="p-4 bg-white rounded-2xl border border-indigo-100/50">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">ACCOUNT CREDIT</p>
                    <p class="text-sm font-black text-indigo-600">Rp ${(parseFloat(cust.account_balance) || 0).toLocaleString('id-ID')}</p>
                 </div>
            </div>
        `;

        document.getElementById('displayAccountBalance').textContent = `Rp ${(parseFloat(cust.account_balance) || 0).toLocaleString('id-ID')}`;
        document.getElementById('useBalanceContainer').classList.toggle('hidden', (parseFloat(cust.account_balance) || 0) <= 0);
        document.getElementById('customerId').value = cust.id;
        document.getElementById('customerInfoCard').classList.remove('hidden');
        document.getElementById('paymentCard').classList.remove('hidden');

        await loadInvoices(cust.id);
    }

    async function loadInvoices(id) {
        try {
            // Fetch with ASC sort (oldest first) and include items for breakdown
            const resp = await fetch(`/kasir/api/customer/${id}/invoices?sort=asc&includeItems=true`);
            const data = await resp.json();
            if(!data.success) return;
            
            pendingInvoices = data.data;
            
            document.getElementById('invoiceCount').textContent = `${pendingInvoices.length} BILLS`;
            
            if(pendingInvoices.length === 0) {
                document.getElementById('invoicesList').innerHTML = '<div class="col-span-2 py-10 text-center grayscale opacity-50"><i class="fas fa-check-circle text-4xl mb-4 text-emerald-500"></i><p class="font-black text-slate-400 uppercase tracking-widest text-xs">No Pending Invoices Found</p></div>';
                totalDueAmount = 0;
                updatePaymentSummary();
                return;
            }

            document.getElementById('invoicesList').innerHTML = pendingInvoices.map(inv => {
                const isOverdue = inv.status === 'overdue';
                const dueDate = new Date(inv.due_date);
                const diffTime = Math.abs(new Date() - dueDate);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                const overdueBadge = isOverdue ? `<span class="bg-rose-500 text-white text-[8px] font-black px-2 py-1 rounded-md ml-2">${diffDays} HARI</span>` : '';

                // Breakdown of items
                const itemsHtml = (inv.items || []).map(item => `
                    <div class="flex justify-between items-center text-[10px] py-1 border-b border-slate-100 last:border-0 border-dashed">
                        <span class="text-slate-500 font-bold flex items-center gap-2">
                             ${item.description.toLowerCase().includes('hutang') || item.description.toLowerCase().includes('carry over') ? '<i class="fas fa-history text-rose-400"></i>' : '<i class="fas fa-globe text-indigo-400"></i>'}
                             ${item.description.toUpperCase()}
                        </span>
                        <span class="text-slate-900 font-black">Rp ${parseFloat(item.amount).toLocaleString('id-ID')}</span>
                    </div>
                `).join('');

                return `
                <div class="div-invoice-card p-6 bg-slate-50 border border-slate-100 rounded-3xl group hover:border-indigo-200 transition-all cursor-pointer relative overflow-hidden" 
                     data-invoice-id="${inv.id}" data-amount="${(parseFloat(inv.remaining_amount) || parseFloat(inv.total_amount) || 0)}">
                    
                    <div class="flex items-start gap-4 mb-4">
                        <div class="checkbox-container pt-1">
                             <input type="checkbox" class="invoice-checkbox w-5 h-5 rounded-lg border-indigo-200 bg-white text-indigo-600 focus:ring-0 cursor-pointer" 
                             data-invoice-id="${inv.id}" onchange="updateSelectedTotal()" checked>
                        </div>
                        <div class="flex-1">
                            <div class="flex justify-between items-start">
                                 <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none">Invoice Period ${overdueBadge}</p>
                                    <p class="text-sm font-black text-slate-900 mt-2">${inv.period}</p>
                                 </div>
                                 <span class="text-[10px] font-black text-indigo-400 font-mono">${inv.invoice_number}</span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-1 mb-4 bg-white/50 p-3 rounded-2xl border border-slate-100">
                        ${itemsHtml}
                    </div>

                    <div class="pt-4 border-t border-slate-200 flex justify-between items-end">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Amount Due</span>
                        <span class="text-xl font-display font-black text-slate-900">Rp ${(parseFloat(inv.remaining_amount) || parseFloat(inv.total_amount) || 0).toLocaleString('id-ID')}</span>
                    </div>
                </div>
            `}).join('');
            
            // Add click event for the card (to toggle checkbox)
            document.querySelectorAll('.div-invoice-card').forEach(card => {
                card.addEventListener('click', (e) => {
                    if (e.target.tagName === 'INPUT') return;
                    const cb = card.querySelector('.invoice-checkbox');
                    cb.checked = !cb.checked;
                    updateSelectedTotal();
                });
            });

            updateSelectedTotal();
        } catch(e) { console.error(e); }
    }

    function toggleAllInvoices(checked) {
        document.querySelectorAll('.invoice-checkbox').forEach(cb => {
            cb.checked = checked;
        });
        updateSelectedTotal();
    }

    function updateSelectedTotal() {
        totalDueAmount = 0;
        const selectedIds = [];
        const container = document.getElementById('selectedInvoiceInputs');
        container.innerHTML = '';

        document.querySelectorAll('.invoice-checkbox:checked').forEach(cb => {
            const card = cb.closest('.div-invoice-card');
            const amt = parseFloat(card.dataset.amount) || 0;
            totalDueAmount += amt;
            selectedIds.push(cb.dataset.invoiceId);
            
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'selectedInvoiceIds[]';
            input.value = cb.dataset.invoiceId;
            container.appendChild(input);
        });

        document.getElementById('totalDue').textContent = `Rp ${totalDueAmount.toLocaleString('id-ID')}`;
        
        if (selectedPaymentType === 'full') {
            document.getElementById('amount').value = totalDueAmount.toLocaleString('id-ID');
        }
        
        updatePaymentSummary();
    }

    function selectPaymentType(type, element) {
        selectedPaymentType = type;
        document.getElementById('paymentType').value = type;
        
        document.querySelectorAll('.payment-type-btn').forEach(b => b.classList.remove('selected'));
        element.classList.add('selected');

        document.getElementById('amountField').classList.toggle('hidden', type !== 'partial');
        document.getElementById('paymentMethodField').classList.toggle('hidden', type === 'debt');
        document.getElementById('paymentSummary').classList.remove('hidden');
        
        if(type === 'full') {
            document.getElementById('amount').value = totalDueAmount.toLocaleString('id-ID');
        } else if (type === 'partial') {
            document.getElementById('amount').value = '';
        }
        
        toggleCashSection();
        updatePaymentSummary();
    }

    function formatAndCalculate(e) {
        let val = e.target.value.replace(/\D/g, '');
        e.target.value = val ? parseInt(val).toLocaleString('id-ID') : '';
        updatePaymentSummary();
    }

    function toggleCashSection() {
        const isCash = document.getElementById('paymentMethod').value === 'cash';
        const isDebt = selectedPaymentType === 'debt';
        document.getElementById('cashCalculation').classList.toggle('hidden', !isCash || isDebt);
        updatePaymentSummary();
    }

    function updatePaymentSummary() {
        let payAmount = 0;
        let useBal = document.getElementById('useBalance').checked;
        let bal = parseFloat(selectedCustomer?.account_balance) || 0;
        let usedFromBal = useBal ? Math.min(bal, totalDueAmount) : 0;

        if (selectedPaymentType === 'full') {
            payAmount = Math.max(0, totalDueAmount - usedFromBal);
            document.getElementById('amount').value = totalDueAmount.toLocaleString('id-ID');
        } else if (selectedPaymentType === 'partial') {
            payAmount = parseFloat(document.getElementById('amount').value.replace(/\D/g, '')) || 0;
        } else if (selectedPaymentType === 'debt') {
            payAmount = 0;
        }

        document.getElementById('summarySubtotal').textContent = `Rp ${totalDueAmount.toLocaleString('id-ID')}`;
        document.getElementById('summaryTotal').textContent = `Rp ${payAmount.toLocaleString('id-ID')}`;
        
        // Kembalian
        const cashRec = parseFloat(document.getElementById('cashReceived').value.replace(/\D/g, '')) || 0;
        const change = Math.max(0, cashRec - payAmount);
        document.getElementById('change').textContent = `Rp ${change.toLocaleString('id-ID')}`;

        document.getElementById('hiddenAmount').value = payAmount;
    }

    async function sendInvoiceNotification(customerId, btn) {
        if (!confirm('Kirim notifikasi tagihan melalui WhatsApp?')) return;
        
        const originalContent = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';
        btn.disabled = true;

        try {
            const response = await fetch(`/kasir/api/send-invoice-notification/${customerId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            
            if (data.success) {
                alert('✅ ' + data.message);
                btn.classList.remove('bg-emerald-50', 'text-emerald-600');
                btn.classList.add('bg-blue-500', 'text-white');
                btn.innerHTML = '<i class="fas fa-check"></i>';
            } else {
                alert('❌ ' + data.message);
                btn.innerHTML = originalContent;
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Gagal mengirim notifikasi');
            btn.innerHTML = originalContent;
            btn.disabled = false;
        }
    }

    function resetForm() {
        selectedCustomer = null;
        selectedPaymentType = null;
        document.getElementById('paymentForm').reset();
        document.getElementById('customerInfoCard').classList.add('hidden');
        document.getElementById('paymentCard').classList.add('hidden');
        document.getElementById('customerListTable').classList.remove('hidden');
        document.getElementById('searchResults').classList.add('hidden');
        document.getElementById('customerSearch').value = '';
        document.querySelectorAll('.payment-type-btn').forEach(b => b.classList.remove('selected'));
        document.getElementById('selectedInvoiceInputs').innerHTML = '';
    }

    // Auto-open Receipt if payment success
    window.onload = function() {
        const urlParams = new URLSearchParams(window.location.search);
        const paymentId = urlParams.get('success_payment_id');
        if (paymentId) {
            Swal.fire({
                title: 'Pembayaran Berhasil!',
                text: 'Apakah Anda ingin mencetak struk pembayaran?',
                icon: 'success',
                showCancelButton: true,
                confirmButtonText: 'Cetak Struk',
                cancelButtonText: 'Lanjutkan',
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#64748b'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.open(`/kasir/receipt/${paymentId}`, '_blank', 'width=450,height=600');
                }
                // Clean up URL
                const newUrl = window.location.pathname + (urlParams.get('month') ? '?month=' + urlParams.get('month') : '');
                window.history.replaceState({}, document.title, newUrl);
            });
        }
    };

    // Handle Form Submit
    document.getElementById('paymentForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        if(!selectedPaymentType) return alert('Pilih jenis pembayaran!');
        
        const btn = document.getElementById('submitPaymentBtn');
        btn.disabled = true;
        document.getElementById('submitBtnText').classList.add('hidden');
        document.getElementById('submitBtnLoading').classList.remove('hidden');
        
        e.target.submit();
    });
</script>
