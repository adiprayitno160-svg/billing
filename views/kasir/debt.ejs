<!-- Halaman Daftar Hutang Kasir - Premium Version -->
<div class="space-y-10 pb-20">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h1 class="text-4xl font-display font-black text-slate-900 tracking-tight">Daftar Hutang</h1>
            <p class="text-sm font-semibold text-slate-400 uppercase tracking-[0.2em] mt-2">Daftar Tagihan Berstatus Hutang / Tertunda</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="bg-indigo-50 px-6 py-3 rounded-2xl border border-indigo-100 flex items-center gap-4 shadow-sm">
                <div class="w-10 h-10 bg-indigo-600 text-white rounded-xl flex items-center justify-center font-black text-sm">
                    <i class="fas fa-hand-holding-dollar"></i>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none">Total Tagihan</p>
                    <p class="text-xl font-display font-black text-indigo-600 mt-1"><%= (pagination.total || 0).toLocaleString('id-ID') %></p>
                </div>
            </div>
            <a href="/kasir/payments" class="h-14 px-8 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg shadow-slate-200 flex items-center gap-3">
                <i class="fas fa-plus text-indigo-400"></i>
                Proses Pembayaran
            </a>
        </div>
    </div>

    <!-- Smart Filters -->
    <div class="bg-white rounded-[2.5rem] p-10 shadow-sm border border-slate-100">
        <form method="GET" action="/kasir/debt" class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="md:col-span-3">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3 pl-2">Cari Pelanggan atau Invoice</label>
                <div class="relative">
                    <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-300"></i>
                    <input type="text" name="search" value="<%= search || '' %>"
                        class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-400 focus:bg-white rounded-2xl py-4 pl-14 pr-6 font-semibold text-slate-900 outline-none transition-all placeholder:text-slate-300"
                        placeholder="Nama, Invoice, atau Kode Pelanggan...">
                </div>
            </div>
            <div class="flex items-end">
                <button type="submit" class="w-full h-14 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-700 active:scale-95 transition-all shadow-xl shadow-indigo-100">
                    Apply Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Data Table Surface -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
        <% if (debts && debts.length > 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
                            <th class="px-10 py-6">Invoice / Period</th>
                            <th class="px-6 py-6">Customer</th>
                            <th class="px-6 py-6 font-mono text-center">Amount Due</th>
                            <th class="px-6 py-6 text-center">Status</th>
                            <th class="px-10 py-6 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% debts.forEach(debt => { %>
                            <tr class="hover:bg-slate-50/80 transition-all group">
                                <td class="px-10 py-6">
                                    <div class="flex items-center gap-5">
                                        <div class="w-12 h-12 bg-white rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 shadow-sm group-hover:text-amber-500">
                                            <i class="fas fa-file-invoice-dollar"></i>
                                        </div>
                                        <div>
                                            <p class="font-mono text-[10px] font-black text-slate-500 tracking-tighter"><%= debt.invoice_number %></p>
                                            <p class="text-xs font-bold text-slate-900 mt-1">
                                                Periode <%= debt.period %>
                                            </p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <p class="font-display font-black text-slate-900"><%= debt.customer_name %></p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="text-[9px] font-black text-indigo-400 uppercase tracking-widest"><%= debt.customer_code %></span>
                                        <span class="text-[9px] font-bold text-slate-300">•</span>
                                        <span class="text-[9px] font-mono text-slate-400"><%= debt.customer_phone %></span>
                                    </div>
                                </td>
                                <td class="px-6 py-6 text-center">
                                    <p class="font-display font-black text-rose-600">Rp <%= (debt.remaining_amount || debt.total_amount).toLocaleString('id-ID') %></p>
                                    <p class="text-[9px] font-bold text-slate-400 mt-1">Total Tagihan: <%= (debt.total_amount || 0).toLocaleString('id-ID') %></p>
                                </td>
                                <td class="px-6 py-6 text-center">
                                    <span class="inline-flex items-center px-3 py-1 bg-amber-50 text-amber-600 text-[9px] font-black tracking-[0.1em] rounded-full border border-amber-100 uppercase">
                                        <i class="fas fa-clock mr-2 text-[8px]"></i> HUTANG
                                    </span>
                                </td>
                                <td class="px-10 py-6 text-right">
                                    <a href="/kasir/customers/<%= debt.customer_id %>" class="h-10 px-6 inline-flex items-center justify-center rounded-xl bg-slate-900 text-white font-black text-[10px] tracking-widest hover:bg-slate-800 shadow-lg shadow-slate-100 transition-all">
                                        BAYAR SEKARANG
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Enhanced Pagination -->
            <div class="px-10 py-8 border-t border-slate-50 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-6">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                    Records <%= ((pagination.page - 1) * pagination.limit) + 1 %> — <%= Math.min(pagination.page * pagination.limit, pagination.total) %> of <%= pagination.total %>
                </p>
                
                <div class="flex items-center gap-2">
                    <% if (pagination.page > 1) { %>
                        <a href="?page=<%= pagination.page - 1 %>&search=<%= search %>" class="w-10 h-10 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:text-indigo-600 transition-all"><i class="fas fa-chevron-left text-xs"></i></a>
                    <% } %>
                    
                    <span class="h-10 px-4 inline-flex items-center justify-center rounded-xl bg-indigo-600 text-white font-black text-xs">
                        <%= pagination.page %>
                    </span>
                    
                    <% if (pagination.page < pagination.pages) { %>
                        <a href="?page=<%= pagination.page + 1 %>&search=<%= search %>" class="w-10 h-10 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:text-indigo-600 transition-all"><i class="fas fa-chevron-right text-xs"></i></a>
                    <% } %>
                </div>
            </div>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-24 grayscale opacity-40">
                <i class="fas fa-hand-holding-dollar text-6xl mb-4 text-slate-200"></i>
                <p class="font-black text-slate-400 uppercase tracking-widest">Tidak ada data hutang aktif</p>
            </div>
        <% } %>
    </div>
</div>
